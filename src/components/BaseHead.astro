---
import '../styles/global.css'
import { CONTACT, SITE, SOCIAL } from '../data/site'
import { getSiteSettings } from '../lib/sanity/client'

interface Props {
	title: string
	description: string
	image?: string
	pageType?: 'website' | 'article'
	/** ISO 8601 date string for article:published_time */
	publishedTime?: string
	/** ISO 8601 date string for article:modified_time */
	modifiedTime?: string
}

const {
	title,
	description,
	image = '/images/og-fallback.png',
	pageType = 'website',
	publishedTime,
	modifiedTime,
} = Astro.props
const canonicalURL = new URL(Astro.url.pathname, Astro.site)

// Fetch breadcrumb labels from Sanity (fallback to hardcoded defaults)
let breadcrumbLabels: Record<string, string> = {}
try {
	const settings = await getSiteSettings()
	if (settings?.breadcrumbLabels) {
		breadcrumbLabels = settings.breadcrumbLabels
	}
} catch (error) {
	console.error('[BaseHead] Site settings fetch failed:', error)
}

const defaultLabels: Record<string, string> = {
	beranda: 'Beranda',
	tentang: 'Tentang Kami',
	program: 'Program',
	kegiatan: 'Kegiatan',
	donasi: 'Donasi',
	kontak: 'Kontak',
	galeri: 'Galeri',
	blog: 'Blog',
	faq: 'FAQ',
}
const labels = { ...defaultLabels, ...breadcrumbLabels }

// Generate breadcrumb items from URL path
const pathParts = Astro.url.pathname.split('/').filter(Boolean)
const breadcrumbItems = [{ '@type': 'ListItem', position: 1, name: labels.beranda, item: SITE.url }]
let currentPath = ''
pathParts.forEach((part) => {
	currentPath += `/${part}`
	breadcrumbItems.push({
		'@type': 'ListItem',
		position: breadcrumbItems.length + 1,
		name: labels[part] || part.charAt(0).toUpperCase() + part.slice(1),
		item: `${SITE.url}${currentPath}`,
	})
})
const ogImageURL = new URL(image, Astro.url)
const isFallback = image === '/images/og-fallback.png' || image === '/logo-yayasan.webp'
const ogImageWidth = isFallback ? '1024' : '1200'
const ogImageHeight = isFallback ? '1024' : '630'
const ogImageType = image.endsWith('.png') ? 'image/png' : 'image/webp'
---

<meta charset="utf-8" />
<meta name="viewport" content="width=device-width,initial-scale=1" />
<meta name="theme-color" content="#052e16" />
<meta name="theme-color" content="#0c0a09" media="(prefers-color-scheme: dark)" />
<meta name="color-scheme" content="light dark" />
<meta name="robots" content="index, follow" />
<meta name="author" content={SITE.name} />
<meta name="application-name" content={SITE.shortName} />
<meta name="mobile-web-app-capable" content="yes" />
<meta name="apple-mobile-web-app-capable" content="yes" />
<meta name="apple-mobile-web-app-status-bar-style" content="black-translucent" />
<meta name="format-detection" content="telephone=no" />
<meta name="referrer" content="origin-when-cross-origin" />

<!-- Content Security Policy -->
<meta
  http-equiv="Content-Security-Policy"
  content="default-src 'self'; script-src 'self' 'unsafe-inline' 'unsafe-eval' https://*.sentry.io; style-src 'self' 'unsafe-inline'; font-src 'self'; img-src 'self' data: blob: https://cdn.sanity.io; connect-src 'self' https://*.ingest.us.sentry.io; base-uri 'self'; form-action 'self'"
/>

<!-- Critical @font-face — inlined to eliminate render-blocking external CSS -->
<style is:inline>
@font-face {
	font-family: 'Plus Jakarta Sans';
	font-style: normal;
	font-weight: 700 800;
	font-display: swap;
	src: url('/fonts/PlusJakartaSans-cyrillic-ext-700.woff2') format('woff2');
	unicode-range: U+0460-052F, U+1C80-1C8A, U+20B4, U+2DE0-2DFF, U+A640-A69F, U+FE2E-FE2F;
}
@font-face {
	font-family: 'Plus Jakarta Sans';
	font-style: normal;
	font-weight: 700 800;
	font-display: swap;
	src: url('/fonts/PlusJakartaSans-vietnamese-700.woff2') format('woff2');
	unicode-range: U+0102-0103, U+0110-0111, U+0128-0129, U+0168-0169, U+01A0-01A1, U+01AF-01B0, U+0300-0301, U+0303-0304, U+0308-0309, U+0323, U+0329, U+1EA0-1EF9, U+20AB;
}
@font-face {
	font-family: 'Plus Jakarta Sans';
	font-style: normal;
	font-weight: 700 800;
	font-display: swap;
	src: url('/fonts/PlusJakartaSans-latin-ext-700.woff2') format('woff2');
	unicode-range: U+0100-02BA, U+02BD-02C5, U+02C7-02CC, U+02CE-02D7, U+02DD-02FF, U+0304, U+0308, U+0329, U+1D00-1DBF, U+1E00-1E9F, U+1EF2-1EFF, U+2020, U+20A0-20AB, U+20AD-20C0, U+2113, U+2C60-2C7F, U+A720-A7FF;
}
@font-face {
	font-family: 'Plus Jakarta Sans';
	font-style: normal;
	font-weight: 700 800;
	font-display: swap;
	src: url('/fonts/PlusJakartaSans-latin-700.woff2') format('woff2');
	unicode-range: U+0000-00FF, U+0131, U+0152-0153, U+02BB-02BC, U+02C6, U+02DA, U+02DC, U+0304, U+0308, U+0329, U+2000-206F, U+20AC, U+2122, U+2191, U+2193, U+2212, U+2215, U+FEFF, U+FFFD;
}
@font-face {
	font-family: 'Inter';
	font-style: normal;
	font-weight: 100 900;
	font-display: swap;
	src: url('/fonts/Inter-cyrillic-ext.woff2') format('woff2');
	unicode-range: U+0460-052F, U+1C80-1C8A, U+20B4, U+2DE0-2DFF, U+A640-A69F, U+FE2E-FE2F;
}
@font-face {
	font-family: 'Inter';
	font-style: normal;
	font-weight: 100 900;
	font-display: swap;
	src: url('/fonts/Inter-cyrillic.woff2') format('woff2');
	unicode-range: U+0301, U+0400-045F, U+0490-0491, U+04B0-04B1, U+2116;
}
@font-face {
	font-family: 'Inter';
	font-style: normal;
	font-weight: 100 900;
	font-display: swap;
	src: url('/fonts/Inter-greek-ext.woff2') format('woff2');
	unicode-range: U+1F00-1FFF;
}
@font-face {
	font-family: 'Inter';
	font-style: normal;
	font-weight: 100 900;
	font-display: swap;
	src: url('/fonts/Inter-greek.woff2') format('woff2');
	unicode-range: U+0370-0377, U+037A-037F, U+0384-038A, U+038C, U+038E-03A1, U+03A3-03FF;
}
@font-face {
	font-family: 'Inter';
	font-style: normal;
	font-weight: 100 900;
	font-display: swap;
	src: url('/fonts/Inter-vietnamese.woff2') format('woff2');
	unicode-range: U+0102-0103, U+0110-0111, U+0128-0129, U+0168-0169, U+01A0-01A1, U+01AF-01B0, U+0300-0301, U+0303-0304, U+0308-0309, U+0323, U+0329, U+1EA0-1EF9, U+20AB;
}
@font-face {
	font-family: 'Inter';
	font-style: normal;
	font-weight: 100 900;
	font-display: swap;
	src: url('/fonts/Inter-latin-ext.woff2') format('woff2');
	unicode-range: U+0100-02BA, U+02BD-02C5, U+02C7-02CC, U+02CE-02D7, U+02DD-02FF, U+0304, U+0308, U+0329, U+1D00-1DBF, U+1E00-1E9F, U+1EF2-1EFF, U+2020, U+20A0-20AB, U+20AD-20C0, U+2113, U+2C60-2C7F, U+A720-A7FF;
}
@font-face {
	font-family: 'Inter';
	font-style: normal;
	font-weight: 100 900;
	font-display: swap;
	src: url('/fonts/Inter-latin.woff2') format('woff2');
	unicode-range: U+0000-00FF, U+0131, U+0152-0153, U+02BB-02BC, U+02C6, U+02DA, U+02DC, U+0304, U+0308, U+0329, U+2000-206F, U+20AC, U+2122, U+2191, U+2193, U+2212, U+2215, U+FEFF, U+FFFD;
}
</style>

<!-- Web Vitals monitoring script -->
<meta name="msapplication-TileColor" content="#052e16" />
<link rel="icon" type="image/svg+xml" href="/favicon.svg" sizes="any" />
<link rel="icon" type="image/png" sizes="16x16" href="/favicon-16x16.png" />
<link rel="icon" type="image/png" sizes="32x32" href="/favicon-32x32.png" />
<link rel="icon" type="image/png" sizes="48x48" href="/favicon-48x48.png" />
<link rel="icon" type="image/png" sizes="192x192" href="/favicon-192x192.png" />
<link rel="icon" href="/favicon.ico" sizes="16x16 32x32 48x48" />
<link rel="apple-touch-icon" href="/logo-yayasan-sm.webp" sizes="256x256" />
<link rel="manifest" href="/site.webmanifest" />
<link rel="sitemap" href="/sitemap-index.xml" />
<link rel="preconnect" href="https://cdn.sanity.io" crossorigin />
<link rel="dns-prefetch" href="https://cdn.sanity.io" />
<meta name="generator" content={Astro.generator} />

<link rel="canonical" href={canonicalURL} />

<title>{title} — {SITE.shortName}</title>
<meta name="title" content={`${title} — ${SITE.shortName}`} />
<meta name="description" content={description} />

<meta property="og:type" content={pageType} />
<meta property="og:locale" content="id_ID" />
<meta property="og:site_name" content={SITE.shortName} />
<meta property="og:url" content={Astro.url} />
<meta property="og:title" content={`${title} — ${SITE.shortName}`} />
<meta property="og:description" content={description} />
<meta property="og:image" content={ogImageURL} />
<meta property="og:image:width" content={ogImageWidth} />
<meta property="og:image:height" content={ogImageHeight} />
<meta property="og:image:alt" content={SITE.shortName} />
<meta property="og:image:type" content={ogImageType} />

<meta name="twitter:card" content={isFallback ? "summary" : "summary_large_image"} />
<meta name="twitter:url" content={Astro.url} />
<meta name="twitter:title" content={`${title} — ${SITE.shortName}`} />
<meta name="twitter:description" content={description} />
<meta name="twitter:image" content={ogImageURL} />
<meta name="twitter:image:alt" content={SITE.shortName} />

<script is:inline type="application/ld+json" set:html={JSON.stringify({
	"@context": "https://schema.org",
	"@type": "WebSite",
	"@id": `${SITE.url}/#website`,
	"url": SITE.url,
	"name": SITE.shortName,
	"description": SITE.description,
	"potentialAction": {
		"@type": "SearchAction",
		"target": {
			"@type": "EntryPoint",
			"urlTemplate": `${SITE.url}/?q={search_term_string}`
		},
		"query-input": "required name=search_term_string"
	}
})}></script>

<script is:inline type="application/ld+json" set:html={JSON.stringify({
	"@context": "https://schema.org",
	"@type": "Organization",
	"@id": `${SITE.url}/#organization`,
	"name": SITE.name,
	"alternateName": SITE.shortName,
	"description": SITE.description,
	"url": SITE.url,
	"logo": `${SITE.url}/logo-yayasan.webp`,
	"foundingDate": SITE.foundedDate,
	"address": {
		"@type": "PostalAddress",
		"streetAddress": CONTACT.address.street + ', ' + CONTACT.address.village + ', ' + CONTACT.address.district,
		"addressLocality": CONTACT.address.city,
		"addressRegion": CONTACT.address.province,
		"postalCode": CONTACT.address.postalCode,
		"addressCountry": "ID",
	},
	"contactPoint": [
		{
			"@type": "ContactPoint",
			"telephone": CONTACT.phone,
			"contactType": "customer service",
			"email": CONTACT.email,
		},
	],
	"sameAs": [
		SOCIAL.facebook.url,
		SOCIAL.instagram.url,
		SOCIAL.youtube.url,
		SOCIAL.tiktok.url,
	],
})}></script>

{breadcrumbItems.length > 1 && (
	<script is:inline type="application/ld+json" set:html={JSON.stringify({
		"@context": "https://schema.org",
		"@type": "BreadcrumbList",
		"@id": `${canonicalURL}#breadcrumb`,
		"itemListElement": breadcrumbItems,
	})}></script>
)}

{pageType === 'article' && publishedTime && (
	<script is:inline type="application/ld+json" set:html={JSON.stringify({
		"@context": "https://schema.org",
		"@type": "Article",
		"@id": `${canonicalURL}#article`,
		"headline": title,
		"description": description,
		"image": ogImageURL,
		"datePublished": publishedTime,
		"dateModified": modifiedTime || publishedTime,
		"author": {
			"@type": "Organization",
			"@id": `${SITE.url}/#organization`,
		},
		"publisher": {
			"@type": "Organization",
			"@id": `${SITE.url}/#organization`,
		},
		"mainEntityOfPage": {
			"@type": "WebPage",
			"@id": canonicalURL,
		},
	})}></script>
)}
