---
/**
 * Stats Section Component
 *
 * Displays key statistics in a responsive grid.
 * Used on homepage to show impact metrics.
 */
interface StatItem {
	number: string
	label: string
}

interface Props {
	stats: StatItem[]
}

const { stats } = Astro.props
---

<section class="bg-surface-secondary pb-8 sm:pb-16 lg:pb-24">
	<div class="relative -mt-6 sm:-mt-12 z-10 mx-auto max-w-6xl px-4 sm:px-6 lg:px-8">
	<div class="stats-grid grid grid-cols-2 gap-3 sm:gap-4 lg:grid-cols-4">
		{stats.map((stat) => (
			<div class="stats-card rounded-lg sm:rounded-xl bg-surface-elevated p-4 sm:p-6 shadow-lg border border-border-secondary/60 dark:border-white/5 text-center transition-all duration-300 ease-out hover:-translate-y-1.5 hover:shadow-xl hover:shadow-primary-500/5 dark:hover:shadow-primary-500/5 hover:border-primary-500/30 dark:hover:border-primary-400/20">
				<p class="text-2xl sm:text-3xl font-extrabold text-primary-700 dark:text-primary-300 tabular-nums">
					{stat.number}
				</p>
				<p class="mt-1 text-sm text-text-secondary dark:text-text-secondary">{stat.label}</p>
			</div>
		))}
		</div>
	</div>
</section>

<style is:global>
	.stats-grid {
		--stagger-delay: 0.15s;
	}
	.stats-card {
		animation: fade-in-up 0.6s ease-out both;
	}
	.stats-card:nth-child(1) { animation-delay: calc(var(--stagger-delay) * 1); }
	.stats-card:nth-child(2) { animation-delay: calc(var(--stagger-delay) * 2); }
	.stats-card:nth-child(3) { animation-delay: calc(var(--stagger-delay) * 3); }
	.stats-card:nth-child(4) { animation-delay: calc(var(--stagger-delay) * 4); }
</style>