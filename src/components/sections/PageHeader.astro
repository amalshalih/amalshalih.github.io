---
import Container from '@components/ui/Container.astro'

interface Props {
	label: string
	title: string
	description?: string
	gradient?: 'br' | 'r' | 'b' | 'tl' | 'tr' | 'bl'
	class?: string
}

const { label, title, description, gradient = 'br', class: className } = Astro.props

const gradientMap: Record<string, string> = {
	br: 'bg-gradient-to-br from-primary-800 to-primary-900',
	r: 'bg-gradient-to-r from-primary-800 to-primary-900',
	b: 'bg-gradient-to-b from-primary-800 to-primary-900',
	tl: 'bg-gradient-to-tl from-primary-800 to-primary-900',
	tr: 'bg-gradient-to-tr from-primary-800 to-primary-900',
	bl: 'bg-gradient-to-bl from-primary-800 to-primary-900',
}
---

<section class:list={[gradientMap[gradient], 'text-white dark:text-white', className]}>
	<Container as="div" class="py-6 sm:py-8 lg:py-12">
		<p class="mb-2 text-xs sm:text-sm font-semibold uppercase tracking-widest text-gold-300 dark:text-gold-300">
			{label}
		</p>
		<h1 class="text-2xl sm:text-3xl lg:text-5xl font-extrabold text-white dark:text-white">{title}</h1>
		{description && (
			<p class="mt-2 sm:mt-3 max-w-2xl text-sm sm:text-base lg:text-lg text-primary-100 dark:text-primary-200">{description}</p>
		)}
		<slot name="after" />
	</Container>
</section>
