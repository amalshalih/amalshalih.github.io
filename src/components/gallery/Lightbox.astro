---
interface Props {
	images: Array<{
		id: string
		name: string
		thumbnailUrl: string
		fullUrl: string
	}>
}

const { images } = Astro.props
---

<div
  id="lightbox"
  class="fixed inset-0 z-[100] hidden items-center justify-center bg-black/90 backdrop-blur-md transition-all duration-300 opacity-0"
  role="dialog"
  aria-modal="true"
  aria-label="Image viewer"
>
  <!-- Top Bar: Title & Close Button -->
  <div class="absolute top-0 inset-x-0 z-20 flex items-center justify-between p-4 bg-gradient-to-b from-black/60 to-transparent">
    <div class="flex flex-col min-w-0 pr-4">
      <h3 id="lightbox-title" class="text-white font-medium text-sm sm:text-base md:text-lg truncate drop-shadow-md"></h3>
      <span id="lightbox-counter" class="text-white/60 text-xs sm:text-sm font-medium mt-0.5"></span>
    </div>
    <button
      id="lightbox-close"
      class="flex items-center justify-center h-10 w-10 sm:h-11 sm:w-11 rounded-full bg-white/10 border border-white/10 text-white hover:bg-white/20 hover:scale-105 active:scale-95 transition-all duration-200 focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-primary-500 cursor-pointer"
      aria-label="Tutup"
    >
      <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg>
    </button>
  </div>

  <!-- Navigation Buttons (Hidden on mobile, swiping is preferred there) -->
  <button
    id="lightbox-prev"
    class="hidden md:flex absolute left-6 top-1/2 -translate-y-1/2 z-10 items-center justify-center h-14 w-14 rounded-full bg-white/10 border border-white/10 text-white hover:bg-white/20 hover:scale-105 active:scale-95 transition-all duration-200 focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-primary-500 cursor-pointer"
    aria-label="Foto sebelumnya"
  >
    <svg xmlns="http://www.w3.org/2000/svg" width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="15 18 9 12 15 6"/></svg>
  </button>

  <button
    id="lightbox-next"
    class="hidden md:flex absolute right-6 top-1/2 -translate-y-1/2 z-10 items-center justify-center h-14 w-14 rounded-full bg-white/10 border border-white/10 text-white hover:bg-white/20 hover:scale-105 active:scale-95 transition-all duration-200 focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-primary-500 cursor-pointer"
    aria-label="Foto berikutnya"
  >
    <svg xmlns="http://www.w3.org/2000/svg" width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="9 18 15 12 9 6"/></svg>
  </button>

  <!-- Main Image Container -->
  <div id="lightbox-image-container" class="relative w-full h-full flex items-center justify-center p-4 sm:p-12 md:p-20 overflow-hidden select-none cursor-grab active:cursor-grabbing">
    <!-- Loading Spinner -->
    <div id="lightbox-spinner" class="absolute z-10 flex flex-col items-center gap-3 text-white/80">
      <svg class="animate-spin h-10 w-10" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" aria-hidden="true">
        <circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="3"></circle>
        <path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4z"></path>
      </svg>
      <span class="text-xs font-medium tracking-wide">Memuat foto...</span>
    </div>

    <!-- The Image -->
    <img
      id="lightbox-image"
      src=""
      alt=""
      class="max-w-full max-h-full object-contain rounded shadow-2xl transition-opacity duration-300 opacity-0 pointer-events-none"
      style="transform-origin: center center; will-change: transform;"
    />
  </div>

  <!-- Bottom Control Bar: Zoom & Reset -->
  <div class="absolute bottom-6 left-1/2 -translate-x-1/2 z-20 flex items-center gap-2 px-4 py-2 rounded-full bg-black/40 border border-white/10 backdrop-blur-md">
    <button
      id="lightbox-zoom-out"
      class="flex items-center justify-center h-9 w-9 rounded-full text-white/80 hover:text-white hover:bg-white/10 transition-colors focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-primary-500 cursor-pointer"
      aria-label="Perkecil"
    >
      <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/><line x1="8" y1="11" x2="14" y2="11"/></svg>
    </button>
    <button
      id="lightbox-zoom-reset"
      class="text-xs font-semibold px-2 py-1 rounded text-white/80 hover:text-white hover:bg-white/10 transition-colors focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-primary-500 cursor-pointer min-w-10 text-center"
      aria-label="Reset Zoom"
    >
      100%
    </button>
    <button
      id="lightbox-zoom-in"
      class="flex items-center justify-center h-9 w-9 rounded-full text-white/80 hover:text-white hover:bg-white/10 transition-colors focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-primary-500 cursor-pointer"
      aria-label="Perbesar"
    >
      <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/><line x1="11" y1="8" x2="11" y2="14"/><line x1="8" y1="11" x2="14" y2="11"/></svg>
    </button>
  </div>
</div>

<script define:vars={{ images }} is:inline>
(() => {
  const lightbox = document.getElementById('lightbox');
  const lightboxImage = document.getElementById('lightbox-image');
  const lightboxImageContainer = document.getElementById('lightbox-image-container');
  const lightboxClose = document.getElementById('lightbox-close');
  const lightboxPrev = document.getElementById('lightbox-prev');
  const lightboxNext = document.getElementById('lightbox-next');
  const lightboxZoomIn = document.getElementById('lightbox-zoom-in');
  const lightboxZoomOut = document.getElementById('lightbox-zoom-out');
  const lightboxZoomReset = document.getElementById('lightbox-zoom-reset');
  const lightboxCounter = document.getElementById('lightbox-counter');
  const lightboxTitle = document.getElementById('lightbox-title');
  const lightboxSpinner = document.getElementById('lightbox-spinner');

  if (!lightbox || !images.length) return;

  let currentIndex = 0;
  let zoomLevel = 1;
  let panX = 0;
  let panY = 0;
  let isDragging = false;
  let startX = 0;
  let startY = 0;

  function openLightbox(index) {
    currentIndex = index;
    zoomLevel = 1;
    panX = 0;
    panY = 0;
    
    // Show lightbox container and trigger transition
    lightbox.classList.remove('hidden');
    lightbox.classList.add('flex');
    // Force reflow
    void lightbox.offsetWidth;
    lightbox.classList.remove('opacity-0');
    
    document.body.style.overflow = 'hidden';
    updateImage();
  }

  function closeLightbox() {
    lightbox.classList.add('opacity-0');
    // Wait for opacity transition to finish
    setTimeout(() => {
      lightbox.classList.add('hidden');
      lightbox.classList.remove('flex');
      document.body.style.overflow = '';
      zoomLevel = 1;
      panX = 0;
      panY = 0;
      if (lightboxImage) {
        lightboxImage.src = '';
        lightboxImage.classList.add('opacity-0');
      }
    }, 300);
  }

  function updateImage() {
    if (!lightboxImage || !images[currentIndex]) return;
    
    const img = images[currentIndex];
    
    // Reset zoom and panning
    zoomLevel = 1;
    panX = 0;
    panY = 0;
    updateImageTransform();
    updateZoomIndicator();

    // Show spinner & hide current image
    lightboxSpinner?.classList.remove('hidden');
    lightboxImage.classList.add('opacity-0');
    
    // Load new image
    lightboxImage.src = img.fullUrl;
    lightboxImage.alt = img.name;
    
    // Set title and counter
    if (lightboxTitle) {
      lightboxTitle.textContent = img.name.replace(/\.[^/.]+$/, '').replace(/[_-]/g, ' ');
    }
    if (lightboxCounter) {
      lightboxCounter.textContent = `${currentIndex + 1} / ${images.length}`;
    }
  }

  // Handle image load
  lightboxImage.addEventListener('load', () => {
    lightboxSpinner?.classList.add('hidden');
    lightboxImage.classList.remove('opacity-0');
  });

  function prevImage() {
    currentIndex = (currentIndex - 1 + images.length) % images.length;
    updateImage();
  }

  function nextImage() {
    currentIndex = (currentIndex + 1) % images.length;
    updateImage();
  }

  function updateImageTransform() {
    if (!lightboxImage) return;
    lightboxImage.style.transform = `translate(${panX}px, ${panY}px) scale(${zoomLevel})`;
    
    // Adjust cursor style based on zoom
    if (zoomLevel > 1) {
      lightboxImageContainer?.classList.remove('cursor-grab', 'active:cursor-grabbing');
      lightboxImageContainer?.classList.add('cursor-move');
    } else {
      lightboxImageContainer?.classList.remove('cursor-move');
      lightboxImageContainer?.classList.add('cursor-grab');
    }
  }

  function updateZoomIndicator() {
    if (lightboxZoomReset) {
      lightboxZoomReset.textContent = `${Math.round(zoomLevel * 100)}%`;
    }
  }

  function zoomIn() {
    zoomLevel = Math.min(zoomLevel + 0.5, 4);
    updateImageTransform();
    updateZoomIndicator();
  }

  function zoomOut() {
    zoomLevel = Math.max(zoomLevel - 0.5, 0.5);
    // Reset pan if zoomed out to or below 100%
    if (zoomLevel <= 1) {
      panX = 0;
      panY = 0;
    }
    updateImageTransform();
    updateZoomIndicator();
  }

  function resetZoom() {
    zoomLevel = 1;
    panX = 0;
    panY = 0;
    updateImageTransform();
    updateZoomIndicator();
  }

  // --- Zoom Buttons ---
  lightboxZoomIn?.addEventListener('click', (e) => { e.stopPropagation(); zoomIn(); });
  lightboxZoomOut?.addEventListener('click', (e) => { e.stopPropagation(); zoomOut(); });
  lightboxZoomReset?.addEventListener('click', (e) => { e.stopPropagation(); resetZoom(); });

  // --- Close & Nav Event Listeners ---
  lightboxClose?.addEventListener('click', (e) => { e.stopPropagation(); closeLightbox(); });
  lightboxPrev?.addEventListener('click', (e) => { e.stopPropagation(); prevImage(); });
  lightboxNext?.addEventListener('click', (e) => { e.stopPropagation(); nextImage(); });

  // Click outside to close (only if clicking the container backdrop, not controls or image)
  lightbox?.addEventListener('click', (e) => {
    if (e.target === lightbox || e.target === lightboxImageContainer) {
      closeLightbox();
    }
  });

  // Keyboard navigation
  document.addEventListener('keydown', (e) => {
    if (lightbox.classList.contains('hidden') || lightbox.classList.contains('opacity-0')) return;
    
    if (e.key === 'Escape') closeLightbox();
    else if (e.key === 'ArrowLeft') prevImage();
    else if (e.key === 'ArrowRight') nextImage();
    else if (e.key === '+' || e.key === '=') zoomIn();
    else if (e.key === '-') zoomOut();
    else if (e.key === '0') resetZoom();
  });

  // --- Touch Swipe & Drag/Pan Implementation ---
  let touchStartX = 0;
  let touchStartY = 0;
  let isSwiping = false;

  lightboxImageContainer?.addEventListener('mousedown', (e) => {
    // Left click only
    if (e.button !== 0) return;
    e.preventDefault();
    isDragging = true;
    startX = e.clientX - panX;
    startY = e.clientY - panY;
  });

  window.addEventListener('mousemove', (e) => {
    if (!isDragging) return;
    
    if (zoomLevel > 1) {
      panX = e.clientX - startX;
      panY = e.clientY - startY;
      updateImageTransform();
    }
  });

  window.addEventListener('mouseup', () => {
    isDragging = false;
  });

  // Touch support for swipe (navigate) and pan (zoom)
  lightboxImageContainer?.addEventListener('touchstart', (e) => {
    if (e.touches.length === 1) {
      touchStartX = e.touches[0].clientX;
      touchStartY = e.touches[0].clientY;
      startX = touchStartX - panX;
      startY = touchStartY - panY;
      isDragging = true;
      isSwiping = zoomLevel === 1; // Only swipe to change image if not zoomed in
    }
  }, { passive: true });

  lightboxImageContainer?.addEventListener('touchmove', (e) => {
    if (!isDragging || e.touches.length !== 1) return;
    
    const touchX = e.touches[0].clientX;
    const touchY = e.touches[0].clientY;

    if (zoomLevel > 1) {
      panX = touchX - startX;
      panY = touchY - startY;
      updateImageTransform();
    } else if (isSwiping) {
      // Swipe preview feedback could go here, but simple swipe detection on touchend is sufficient
    }
  }, { passive: true });

  lightboxImageContainer?.addEventListener('touchend', (e) => {
    if (!isDragging) return;
    isDragging = false;
    
    if (isSwiping && e.changedTouches.length === 1) {
      const touchEndX = e.changedTouches[0].clientX;
      const touchEndY = e.changedTouches[0].clientY;
      const diffX = touchStartX - touchEndX;
      const diffY = touchStartY - touchEndY;
      
      // Horizontal swipe must be larger than vertical drag
      if (Math.abs(diffX) > 60 && Math.abs(diffY) < 100) {
        if (diffX > 0) {
          nextImage();
        } else {
          prevImage();
        }
      }
    }
  }, { passive: true });

  window.openLightbox = openLightbox;
})();
</script>

