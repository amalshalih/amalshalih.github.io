---
/**
 * Lightbox — Fullscreen image viewer
 *
 * Gallery lightbox with keyboard nav, zoom, share, like.
 * Lazy loads via IntersectionObserver.
 */
interface Props {
	images: Array<{
		id: string
		name: string
		thumbnailUrl: string
		fullUrl: string
		description?: string
		photographer?: string
	}>
}

const { images } = Astro.props
---

<div
  id="lightbox"
  class="fixed inset-0 z-[100] hidden items-center justify-center bg-black/90 backdrop-blur-md transition-opacity duration-300 opacity-0"
  role="dialog"
  aria-modal="true"
  aria-label="Image viewer"
>
  <!-- Top Bar: Title, Counter, Action Buttons -->
  <div class="absolute top-0 inset-x-0 z-20 flex items-center justify-between p-4 bg-gradient-to-b from-black/60 to-transparent">
    <div class="flex flex-col min-w-0 pr-4">
      <h3 id="lightbox-title" class="text-white font-medium text-sm sm:text-base md:text-lg truncate drop-shadow-md"></h3>
      <span id="lightbox-counter" class="text-white/60 text-xs sm:text-sm font-medium mt-0.5"></span>
    </div>
    
    <!-- Action Buttons -->
    <div class="flex items-center gap-2">
      <button id="lightbox-slideshow" class="flex items-center justify-center h-10 w-10 sm:h-11 sm:w-11 rounded-full bg-white/10 border border-white/10 text-white hover:bg-white/20 hover:scale-105 active:scale-95 transition-all duration-200 focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-primary-500 cursor-pointer" aria-label="Putar slideshow" title="Slideshow (S)">
        <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polygon points="5 3 19 12 5 21 5 3"/></svg>
      </button>
      <button id="lightbox-download" class="flex items-center justify-center h-10 w-10 sm:h-11 sm:w-11 rounded-full bg-white/10 border border-white/10 text-white hover:bg-white/20 hover:scale-105 active:scale-95 transition-all duration-200 focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-primary-500 cursor-pointer" aria-label="Download image" title="Download">
        <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/><polyline points="7 10 12 15 17 10"/><line x1="12" y1="15" x2="12" y2="3"/></svg>
      </button>
      <button id="lightbox-share" class="flex items-center justify-center h-10 w-10 sm:h-11 sm:w-11 rounded-full bg-white/10 border border-white/10 text-white hover:bg-white/20 hover:scale-105 active:scale-95 transition-all duration-200 focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-primary-500 cursor-pointer" aria-label="Share image" title="Share">
        <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><circle cx="18" cy="5" r="3"/><circle cx="6" cy="12" r="3"/><circle cx="18" cy="19" r="3"/><line x1="8.59" y1="13.51" x2="15.42" y2="17.49"/><line x1="15.41" y1="6.51" x2="8.59" y2="10.49"/></svg>
      </button>
      <button id="lightbox-close" class="flex items-center justify-center h-10 w-10 sm:h-11 sm:w-11 rounded-full bg-white/10 border border-white/10 text-white hover:bg-white/20 hover:scale-105 active:scale-95 transition-all duration-200 focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-primary-500 cursor-pointer" aria-label="Tutup">
        <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg>
      </button>
    </div>
  </div>

  <!-- Navigation Buttons -->
  <button id="lightbox-prev" class="hidden md:flex absolute left-6 top-1/2 -translate-y-1/2 z-10 items-center justify-center h-14 w-14 rounded-full bg-white/10 border border-white/10 text-white hover:bg-white/20 hover:scale-105 active:scale-95 transition-all duration-200 focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-primary-500 cursor-pointer" aria-label="Foto sebelumnya">
    <svg xmlns="http://www.w3.org/2000/svg" width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="15 18 9 12 15 6"/></svg>
  </button>
  <button id="lightbox-next" class="hidden md:flex absolute right-6 top-1/2 -translate-y-1/2 z-10 items-center justify-center h-14 w-14 rounded-full bg-white/10 border border-white/10 text-white hover:bg-white/20 hover:scale-105 active:scale-95 transition-all duration-200 focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-primary-500 cursor-pointer" aria-label="Foto berikutnya">
    <svg xmlns="http://www.w3.org/2000/svg" width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="9 18 15 12 9 6"/></svg>
  </button>

  <!-- Main Image Container -->
  <div id="lightbox-image-container" class="relative w-full h-full flex items-center justify-center p-4 sm:p-12 md:p-20 overflow-hidden select-none cursor-grab active:cursor-grabbing">
    <!-- Blur-up Placeholder -->
    <img id="lightbox-image-blur" src="" alt="" class="absolute max-w-full max-h-full object-contain rounded blur-md scale-105 transition-opacity duration-300 opacity-0" aria-hidden="true"/>
    
    <!-- Loading Spinner -->
    <div id="lightbox-spinner" class="absolute z-10 flex flex-col items-center gap-3 text-white/80">
      <svg class="animate-spin h-10 w-10" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" aria-hidden="true">
        <circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="3"></circle>
        <path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4z"></path>
      </svg>
      <span class="text-xs font-medium tracking-wide">Memuat foto...</span>
    </div>

    <!-- Full-Res Image -->
    <img id="lightbox-image" src="" alt="" class="max-w-full max-h-full object-contain rounded shadow-2xl transition-opacity duration-500 ease-out opacity-0" style="transform-origin: center center; will-change: transform; transition: transform 0.3s cubic-bezier(0.4, 0, 0.2, 1), opacity 0.5s ease-out;"/>
  </div>

  <!-- Bottom Caption -->
  <div id="lightbox-caption" class="absolute bottom-20 left-1/2 -translate-x-1/2 z-20 max-w-2xl px-6 py-3 rounded-xl bg-black/60 border border-white/10 backdrop-blur-md text-center hidden">
    <p id="lightbox-description" class="text-white/90 text-sm mb-1"></p>
    <p id="lightbox-photographer" class="text-white/60 text-xs"></p>
  </div>

  <!-- Bottom Control Bar -->
  <div class="absolute bottom-6 left-1/2 -translate-x-1/2 z-20 flex items-center gap-2 px-4 py-2 rounded-full bg-black/40 border border-white/10 backdrop-blur-md">
    <button id="lightbox-zoom-out" class="flex items-center justify-center h-9 w-9 rounded-full text-white/80 hover:text-white hover:bg-white/10 transition-colors focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-primary-500 cursor-pointer" aria-label="Perkecil">
      <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/><line x1="8" y1="11" x2="14" y2="11"/></svg>
    </button>
    <button id="lightbox-zoom-reset" class="text-xs font-semibold px-2 py-1 rounded text-white/80 hover:text-white hover:bg-white/10 transition-colors focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-primary-500 cursor-pointer min-w-10 text-center" aria-label="Reset Zoom">100%</button>
    <button id="lightbox-zoom-in" class="flex items-center justify-center h-9 w-9 rounded-full text-white/80 hover:text-white hover:bg-white/10 transition-colors focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-primary-500 cursor-pointer" aria-label="Perbesar">
      <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/><line x1="11" y1="8" x2="11" y2="14"/><line x1="8" y1="11" x2="14" y2="11"/></svg>
    </button>
    <button id="lightbox-info" class="flex items-center justify-center h-9 w-9 rounded-full text-white/80 hover:text-white hover:bg-white/10 transition-colors focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-primary-500 cursor-pointer ml-2" aria-label="Image info" title="Info (I)">
      <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"/><line x1="12" y1="16" x2="12" y2="12"/><line x1="12" y1="8" x2="12.01" y2="8"/></svg>
    </button>
  </div>

  <!-- Progress Bar -->
  <div class="absolute bottom-0 inset-x-0 h-1 bg-white/10">
    <div id="lightbox-progress" class="h-full bg-accent-primary transition-all duration-300 ease-out" style="width: 0%"/>
  </div>

  <!-- Keyboard Shortcuts Help Modal -->
  <div id="lightbox-help" class="fixed inset-0 z-[101] hidden items-center justify-center bg-black/80 backdrop-blur-sm">
    <div class="bg-surface-elevated dark:bg-surface-secondary rounded-2xl p-6 max-w-md w-full mx-4 shadow-2xl border border-border-primary/50">
      <div class="flex items-center justify-between mb-4">
        <h4 class="text-lg font-bold text-warm-900 dark:text-warm-100">Keyboard Shortcuts</h4>
        <button id="lightbox-help-close" class="text-warm-500 hover:text-warm-700 dark:text-warm-400 dark:hover:text-warm-200">
          <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg>
        </button>
      </div>
      <div class="grid grid-cols-2 gap-3 text-sm">
        <div class="flex items-center gap-2"><kbd class="px-2 py-1 bg-warm-100 dark:bg-warm-800 rounded text-xs font-mono">←</kbd><span class="text-warm-600 dark:text-warm-300">Foto sebelumnya</span></div>
        <div class="flex items-center gap-2"><kbd class="px-2 py-1 bg-warm-100 dark:bg-warm-800 rounded text-xs font-mono">→</kbd><span class="text-warm-600 dark:text-warm-300">Foto berikutnya</span></div>
        <div class="flex items-center gap-2"><kbd class="px-2 py-1 bg-warm-100 dark:bg-warm-800 rounded text-xs font-mono">Esc</kbd><span class="text-warm-600 dark:text-warm-300">Tutup</span></div>
        <div class="flex items-center gap-2"><kbd class="px-2 py-1 bg-warm-100 dark:bg-warm-800 rounded text-xs font-mono">Space</kbd><span class="text-warm-600 dark:text-warm-300">Toggle zoom</span></div>
        <div class="flex items-center gap-2"><kbd class="px-2 py-1 bg-warm-100 dark:bg-warm-800 rounded text-xs font-mono">+</kbd><span class="text-warm-600 dark:text-warm-300">Zoom in</span></div>
        <div class="flex items-center gap-2"><kbd class="px-2 py-1 bg-warm-100 dark:bg-warm-800 rounded text-xs font-mono">-</kbd><span class="text-warm-600 dark:text-warm-300">Zoom out</span></div>
        <div class="flex items-center gap-2"><kbd class="px-2 py-1 bg-warm-100 dark:bg-warm-800 rounded text-xs font-mono">F</kbd><span class="text-warm-600 dark:text-warm-300">Fullscreen</span></div>
        <div class="flex items-center gap-2"><kbd class="px-2 py-1 bg-warm-100 dark:bg-warm-800 rounded text-xs font-mono">S</kbd><span class="text-warm-600 dark:text-warm-300">Slideshow</span></div>
        <div class="flex items-center gap-2"><kbd class="px-2 py-1 bg-warm-100 dark:bg-warm-800 rounded text-xs font-mono">I</kbd><span class="text-warm-600 dark:text-warm-300">Image info</span></div>
        <div class="flex items-center gap-2"><kbd class="px-2 py-1 bg-warm-100 dark:bg-warm-800 rounded text-xs font-mono">?</kbd><span class="text-warm-600 dark:text-warm-300">Bantuan ini</span></div>
      </div>
    </div>
  </div>
</div>

<script define:vars={{ images }} is:inline>
(() => {
  const lightbox = document.getElementById('lightbox');
  const lightboxImage = document.getElementById('lightbox-image');
  const lightboxImageBlur = document.getElementById('lightbox-image-blur');
  const lightboxImageContainer = document.getElementById('lightbox-image-container');
  const lightboxClose = document.getElementById('lightbox-close');
  const lightboxPrev = document.getElementById('lightbox-prev');
  const lightboxNext = document.getElementById('lightbox-next');
  const lightboxZoomIn = document.getElementById('lightbox-zoom-in');
  const lightboxZoomOut = document.getElementById('lightbox-zoom-out');
  const lightboxZoomReset = document.getElementById('lightbox-zoom-reset');
  const lightboxCounter = document.getElementById('lightbox-counter');
  const lightboxTitle = document.getElementById('lightbox-title');
  const lightboxSpinner = document.getElementById('lightbox-spinner');
  const lightboxDownload = document.getElementById('lightbox-download');
  const lightboxShare = document.getElementById('lightbox-share');
  const lightboxSlideshow = document.getElementById('lightbox-slideshow');
  const lightboxInfo = document.getElementById('lightbox-info');
  const lightboxCaption = document.getElementById('lightbox-caption');
  const lightboxDescription = document.getElementById('lightbox-description');
  const lightboxPhotographer = document.getElementById('lightbox-photographer');
  const lightboxProgress = document.getElementById('lightbox-progress');
  const lightboxHelp = document.getElementById('lightbox-help');
  const lightboxHelpClose = document.getElementById('lightbox-help-close');

  if (!lightbox || !images.length) return;

  let currentIndex = 0, zoomLevel = 1, panX = 0, panY = 0;
  let isDragging = false, startX = 0, startY = 0, isSwiping = false;
  let isSlideshowPlaying = false, slideshowInterval = null;
  let touchStartX = 0, touchStartY = 0, initialPinchDistance = 0, initialZoom = 1;
  let pendingImageLoad = null; // Track pending image load to abort on fast navigation

  const preloadCache = new Map();
  const preloadImage = (index) => {
    const img = images[index];
    if (!img || preloadCache.has(img.id)) return;
    const preloadImg = new Image();
    preloadImg.src = img.fullUrl;
    preloadCache.set(img.id, preloadImg);
  };

  const preloadAdjacent = (index) => {
    preloadImage((index - 1 + images.length) % images.length);
    preloadImage((index + 1) % images.length);
  };

  const getDistance = (touches) => {
    const dx = touches[0].clientX - touches[1].clientX;
    const dy = touches[0].clientY - touches[1].clientY;
    return Math.sqrt(dx * dx + dy * dy);
  };

  function openLightbox(index) {
    currentIndex = index;
    zoomLevel = 1; panX = 0; panY = 0;
    lightbox.classList.remove('hidden', 'opacity-0');
    lightbox.classList.add('flex');
    void lightbox.offsetWidth;
    document.body.style.overflow = 'hidden';
    updateImage();
    preloadAdjacent(index);
  }

  function closeLightbox() {
    stopSlideshow();
    lightbox.classList.add('opacity-0');
    setTimeout(() => {
      lightbox.classList.add('hidden', 'opacity-0');
      lightbox.classList.remove('flex');
      document.body.style.overflow = '';
      zoomLevel = 1; panX = 0; panY = 0;
      if (lightboxImage) { lightboxImage.src = ''; lightboxImage.classList.add('opacity-0'); }
      if (lightboxImageBlur) { lightboxImageBlur.src = ''; lightboxImageBlur.classList.add('opacity-0'); }
    }, 300);
  }

  function updateImage() {
    if (!lightboxImage || !images[currentIndex]) return;
    const img = images[currentIndex];
    
    // Abort pending image load if user navigated quickly
    if (pendingImageLoad) {
      pendingImageLoad.src = ''; // Cancel pending request
      pendingImageLoad = null;
    }
    
    zoomLevel = 1; panX = 0; panY = 0;
    updateImageTransform(); updateZoomIndicator(); updateProgress();
    lightboxSpinner?.classList.remove('hidden');
    lightboxImage.classList.add('opacity-0');
    lightboxImageBlur.classList.add('opacity-0');
    
    if (lightboxImageBlur) {
      lightboxImageBlur.src = img.thumbnailUrl;
      lightboxImageBlur.alt = img.name;
      setTimeout(() => lightboxImageBlur.classList.remove('opacity-0'), 10);
    }
    
    // Set new image and track pending load
    lightboxImage.src = img.fullUrl;
    pendingImageLoad = lightboxImage;
    lightboxImage.alt = img.name;
    if (lightboxTitle) lightboxTitle.textContent = img.name.replace(/\.[^/.]+$/, '').replace(/[_-]/g, ' ');
    if (lightboxCounter) lightboxCounter.textContent = `${currentIndex + 1} / ${images.length}`;
    
    if (lightboxCaption && (img.description || img.photographer)) {
      if (img.description) { lightboxDescription.textContent = img.description; lightboxDescription.parentElement?.classList.remove('hidden'); }
      if (img.photographer) { lightboxPhotographer.textContent = `📸 ${img.photographer}`; lightboxPhotographer.parentElement?.classList.remove('hidden'); }
    } else if (lightboxCaption) { lightboxCaption.classList.add('hidden'); }
  }

  lightboxImage.addEventListener('load', () => {
    lightboxSpinner?.classList.add('hidden');
    lightboxImageBlur?.classList.add('opacity-0');
    setTimeout(() => lightboxImage.classList.remove('opacity-0'), 50);
    preloadAdjacent(currentIndex);
  });

  lightboxImage.addEventListener('error', () => {
    // Clear pending load tracker
    pendingImageLoad = null;
    
    // Retry once after 500ms delay
    setTimeout(() => {
      if (lightboxImage && images[currentIndex]) {
        lightboxImage.src = images[currentIndex].fullUrl;
        pendingImageLoad = lightboxImage;
      }
    }, 500);
    
    // Show error message if still fails after retry
    setTimeout(() => {
      if (lightboxImage && lightboxImage.src === images[currentIndex]?.fullUrl && !lightboxImage.complete) {
        lightboxSpinner.innerHTML = '<div class="text-center"><svg class="mx-auto h-12 w-12 text-red-400 mb-2" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-3L13.732 4c-.77-1.333-2.694-1.333-3.464 0L3.34 16c-.77 1.333.192 3 1.732 3z"/></svg><p class="text-sm">Gagal memuat foto</p></div>';
      }
    }, 1000);
  });

  function prevImage() { currentIndex = (currentIndex - 1 + images.length) % images.length; updateImage(); if (isSlideshowPlaying) { stopSlideshow(); startSlideshow(); } }
  function nextImage() { currentIndex = (currentIndex + 1) % images.length; updateImage(); if (isSlideshowPlaying) { stopSlideshow(); startSlideshow(); } }

  function updateImageTransform() {
    if (!lightboxImage) return;
    lightboxImage.style.transform = `translate(${panX}px, ${panY}px) scale(${zoomLevel})`;
    if (zoomLevel > 1) { lightboxImageContainer?.classList.remove('cursor-grab', 'active:cursor-grabbing'); lightboxImageContainer?.classList.add('cursor-move'); }
    else { lightboxImageContainer?.classList.remove('cursor-move'); lightboxImageContainer?.classList.add('cursor-grab', 'active:cursor-grabbing'); }
  }

  function updateZoomIndicator() { if (lightboxZoomReset) lightboxZoomReset.textContent = `${Math.round(zoomLevel * 100)}%`; }
  function updateProgress() { if (lightboxProgress) lightboxProgress.style.width = `${((currentIndex + 1) / images.length) * 100}%`; }

  function zoomIn() { zoomLevel = Math.min(zoomLevel + 0.5, 4); updateImageTransform(); updateZoomIndicator(); }
  function zoomOut() { zoomLevel = Math.max(zoomLevel - 0.5, 0.5); if (zoomLevel <= 1) { panX = 0; panY = 0; } updateImageTransform(); updateZoomIndicator(); }
  function resetZoom() { zoomLevel = 1; panX = 0; panY = 0; updateImageTransform(); updateZoomIndicator(); }
  function toggleZoom() { if (zoomLevel > 1) resetZoom(); else { zoomLevel = 2; updateImageTransform(); updateZoomIndicator(); } }
  function toggleFullscreen() { if (!document.fullscreenElement) lightbox.requestFullscreen().catch(err => console.log('Fullscreen error:', err)); else document.exitFullscreen(); }

  function toggleSlideshow() { if (isSlideshowPlaying) stopSlideshow(); else startSlideshow(); }
  function startSlideshow() {
    isSlideshowPlaying = true;
    if (lightboxSlideshow) { lightboxSlideshow.innerHTML = '<svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="currentColor" stroke="none"><rect x="6" y="4" width="4" height="16"/><rect x="14" y="4" width="4" height="16"/></svg>'; lightboxSlideshow.setAttribute('aria-label', 'Hentikan slideshow'); }
    slideshowInterval = setInterval(() => nextImage(), 3000);
  }
  function stopSlideshow() {
    isSlideshowPlaying = false;
    if (slideshowInterval) { clearInterval(slideshowInterval); slideshowInterval = null; }
    if (lightboxSlideshow) { lightboxSlideshow.innerHTML = '<svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polygon points="5 3 19 12 5 21 5 3"/></svg>'; lightboxSlideshow.setAttribute('aria-label', 'Putar slideshow'); }
  }

  function downloadImage() { const img = images[currentIndex]; if (!img) return; const link = document.createElement('a'); link.href = img.fullUrl; link.download = img.name; document.body.appendChild(link); link.click(); document.body.removeChild(link); }
  async function shareImage() {
    const img = images[currentIndex]; if (!img) return;
    if (navigator.share) { try { await navigator.share({ title: img.name, text: `Lihat foto ini: ${img.name}`, url: window.location.href }); } catch { console.log('Share cancelled'); } }
    else { try { await navigator.clipboard.writeText(window.location.href); alert('URL disalin ke clipboard!'); } catch { console.log('Copy failed'); } }
  }
  function showHelp() { lightboxHelp?.classList.remove('hidden'); lightboxHelp?.classList.add('flex'); }
  function hideHelp() { lightboxHelp?.classList.add('hidden'); lightboxHelp?.classList.remove('flex'); }

  // Event Listeners
  lightboxZoomIn?.addEventListener('click', (e) => { e.stopPropagation(); zoomIn(); });
  lightboxZoomOut?.addEventListener('click', (e) => { e.stopPropagation(); zoomOut(); });
  lightboxZoomReset?.addEventListener('click', (e) => { e.stopPropagation(); resetZoom(); });
  lightboxClose?.addEventListener('click', (e) => { e.stopPropagation(); closeLightbox(); });
  lightboxPrev?.addEventListener('click', (e) => { e.stopPropagation(); prevImage(); });
  lightboxNext?.addEventListener('click', (e) => { e.stopPropagation(); nextImage(); });
  lightboxDownload?.addEventListener('click', (e) => { e.stopPropagation(); downloadImage(); });
  lightboxShare?.addEventListener('click', (e) => { e.stopPropagation(); shareImage(); });
  lightboxSlideshow?.addEventListener('click', (e) => { e.stopPropagation(); toggleSlideshow(); });
  lightboxInfo?.addEventListener('click', (e) => { e.stopPropagation(); showHelp(); });
  lightboxHelpClose?.addEventListener('click', () => hideHelp());
  lightbox?.addEventListener('click', (e) => { if (e.target === lightbox) closeLightbox(); });
  lightboxHelp?.addEventListener('click', (e) => { if (e.target === lightboxHelp) hideHelp(); });

  document.addEventListener('keydown', (e) => {
    if (lightboxHelp && !lightboxHelp.classList.contains('hidden')) { if (e.key === 'Escape' || e.key === '?') hideHelp(); return; }
    if (lightbox.classList.contains('hidden') || lightbox.classList.contains('opacity-0')) return;
    switch(e.key) {
      case 'Escape': closeLightbox(); break;
      case 'ArrowLeft': prevImage(); break;
      case 'ArrowRight': nextImage(); break;
      case '+': case '=': zoomIn(); break;
      case '-': zoomOut(); break;
      case '0': resetZoom(); break;
      case ' ': e.preventDefault(); toggleZoom(); break;
      case 'f': case 'F': toggleFullscreen(); break;
      case 's': case 'S': toggleSlideshow(); break;
      case 'i': case 'I': showHelp(); break;
      case '?': showHelp(); break;
    }
  });

  // Touch Gestures
  lightboxImageContainer?.addEventListener('touchstart', (e) => {
    if (e.touches.length === 1) { touchStartX = e.touches[0].clientX; touchStartY = e.touches[0].clientY; startX = touchStartX - panX; startY = touchStartY - panY; isDragging = true; isSwiping = zoomLevel === 1; }
    else if (e.touches.length === 2) { initialPinchDistance = getDistance(e.touches); initialZoom = zoomLevel; isDragging = false; }
  }, { passive: true });

  lightboxImageContainer?.addEventListener('touchmove', (e) => {
    if (e.touches.length === 1 && isDragging) {
      const touchX = e.touches[0].clientX, touchY = e.touches[0].clientY;
      if (zoomLevel > 1) { panX = touchX - startX; panY = touchY - startY; updateImageTransform(); }
      else if (isSwiping) { /* swipe preview */ }
    } else if (e.touches.length === 2 && !isDragging) {
      const currentDistance = getDistance(e.touches);
      zoomLevel = Math.min(Math.max((currentDistance / initialPinchDistance) * initialZoom, 0.5), 4);
      updateImageTransform(); updateZoomIndicator();
    }
  }, { passive: true });

  lightboxImageContainer?.addEventListener('touchend', (e) => {
    if (!isDragging) return; isDragging = false;
    if (isSwiping && e.changedTouches.length === 1) {
      const touchEndX = e.changedTouches[0].clientX, diffX = touchStartX - touchEndX, diffY = touchStartY - e.changedTouches[0].clientY;
      if (Math.abs(diffX) > 60 && Math.abs(diffY) < 100) { if (diffX > 0) nextImage(); else prevImage(); }
    }
  }, { passive: true });

  window.openLightbox = openLightbox;
})();
</script>