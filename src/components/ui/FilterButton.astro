---
/**
 * FilterButton Component
 *
 * Reusable filter toggle button for product/category filtering.
 * Handles active/inactive states with proper accessibility attributes.
 *
 * @label - Required. Button text
 * @active - Whether button is currently selected
 * @onClick - Click handler (passes category ID)
 * @categoryId - Category ID for data attribute
 * @class - Additional Tailwind classes
 */
interface Props {
	label: string
	active?: boolean
	onClick?: (categoryId: string) => void
	categoryId: string
	class?: string
}

const { label, active = false, onClick, categoryId, class: className } = Astro.props

// Base styles for all filter buttons
const baseStyles =
	'px-5 py-2 border-2 border-accent-primary rounded-full cursor-pointer font-semibold transition-all duration-300 ease-out hover:bg-accent-primary hover:text-white active:scale-95'

// Active state styles (inline styles for dynamic background)
const activeStyles = active
	? 'bg-accent-primary text-white'
	: 'bg-surface-elevated text-accent-primary'

const classes = [baseStyles, activeStyles, className].filter(Boolean).join(' ')
---

<button
	type="button"
	class={classes}
	data-category={categoryId}
	data-selected={active.toString()}
	aria-pressed={active.toString()}
	onclick={() => onClick?.(categoryId)}
>
	{label}
</button>