---
/**
 * Container — Max-width centered wrapper
 *
 * Use `as` prop to render as div/section/article.
 * Default max-width: 6xl (72rem). Responsive padding.
 */
// Container component for consistent page widths
const { as: Tag = 'div', class: className, id } = Astro.props
---

<Tag class:list={['mx-auto max-w-6xl px-4 sm:px-6 lg:px-8', className]} {...(id && { id })}>
	<slot />
</Tag>
