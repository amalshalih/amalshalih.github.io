---
import type Icon from './Icon.astro'

type IconName = Parameters<typeof Icon>[0]['name']

/**
 * Accordion Component
 *
 * Reusable accordion/expandable section with smooth animation.
 * Uses native <details> element for accessibility.
 *
 * @title - Accordion header text
 * @icon - Icon name (optional, shown before title)
 * @iconColor - Icon color variant ('primary', 'gold', 'default')
 * @defaultOpen - If true, accordion starts open
 * @class - Additional classes for wrapper
 * @headerClass - Additional classes for header
 * @contentClass - Additional classes for content area
 */
interface Props {
	title: string
	icon?: IconName
	iconColor?: 'primary' | 'gold' | 'default'
	defaultOpen?: boolean
	class?: string
	headerClass?: string
	contentClass?: string
}

const {
	title,
	icon,
	iconColor = 'default',
	defaultOpen = false,
	class: className,
	headerClass,
	contentClass,
} = Astro.props

// Icon color variants
const iconColors: Record<string, string> = {
	primary: 'bg-primary-50 dark:bg-primary-900/40 text-primary-600 dark:text-primary-400',
	gold: 'bg-gold-50 dark:bg-gold-900/40 text-gold-600 dark:text-gold-400',
	default: 'bg-primary-50 dark:bg-primary-900/40 text-primary-600 dark:text-primary-400',
}

const iconClass = iconColors[iconColor]
---

<details
	class:list={[
		'group rounded-2xl bg-surface-elevated dark:bg-surface-secondary shadow-sm border border-border-secondary/60 dark:border-white/5 open:border-primary-200 dark:open:border-primary-600 transition-all duration-200',
		className,
	]}
	open={defaultOpen}
>
	<summary
		class:list={[
			'flex cursor-pointer items-center justify-between gap-4 p-5 sm:p-6 font-semibold text-text-primary select-none',
			'style="list-style: none;"',
			headerClass,
		]}
	>
		<span class="flex items-center gap-3">
			{icon && (
				<span class={`flex h-10 w-10 items-center justify-center rounded-lg ${iconClass} shrink-0`}>
					<Icon name={icon as IconName} size={5} />
				</span>
			)}
			<span class="text-base">{title}</span>
		</span>
		<svg
			class="w-5 h-5 text-text-muted shrink-0 transition-transform duration-300 group-open:rotate-180"
			fill="none"
			viewBox="0 0 24 24"
			stroke="currentColor"
			stroke-width="2"
			aria-hidden="true"
		>
			<path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7" />
		</svg>
	</summary>
	<div class:list={['accordion-reveal px-5 sm:px-6 pb-5 sm:pb-6', contentClass]}>
		<slot />
	</div>
</details>