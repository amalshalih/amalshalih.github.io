---
import Button from '@components/ui/Button.astro'
import Heading from '@components/ui/Heading.astro'
import Icon from '@components/ui/Icon.astro'

interface Action {
	label: string
	href?: string
	/** Untuk filter button (data-filter="all") */
	datasetFilter?: string
}

interface Props {
	title: string
	description: string
	icon?: string
	emoji?: string
	action?: Action
}

const { title, description, icon, emoji, action } = Astro.props
---

<div class="flex flex-col items-center justify-center py-16 sm:py-24 text-center">
	{icon && (
		<div class="mb-3 rounded-full bg-warm-50 dark:bg-warm-900 p-4 sm:p-6 text-warm-500 dark:text-warm-400">
			<Icon name={icon as 'image' | 'book' | 'heart' | 'globe'} size={10} class="sm:size-16" aria-hidden="true" />
		</div>
	)}
	{emoji && <div class="mb-3 text-5xl sm:text-6xl">{emoji}</div>}
	<Heading level="h2" size="lg" class="text-warm-900 dark:text-warm-100">{title}</Heading>
	<p class="mt-2 max-w-xs text-sm sm:text-base text-warm-600 dark:text-warm-400">{description}</p>
	{action && (
		<div class="mt-6">
			{action.href ? (
				<Button variant="primary" href={action.href}>{action.label}</Button>
			) : (
				<button
					type="button"
					class="inline-flex items-center gap-2 rounded-lg bg-primary-700 dark:bg-primary-500 px-6 py-3 text-sm font-semibold text-white hover:bg-primary-800 dark:hover:bg-primary-400 transition-colors shadow-sm"
					data-filter={action.datasetFilter}
				>
					<Icon name="globe" size={4} aria-hidden="true" />
					{action.label}
				</button>
			)}
		</div>
	)}
</div>
