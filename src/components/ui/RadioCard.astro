---
/**
 * RadioCard — Selectable card for radio groups
 *
 * Renders a `<button role="radio">` styled as a selectable card
 * with icon, title, and description. Designed for subject/topic
 * selection in forms.
 *
 * The checked state is managed externally via CSS attribute selectors
 * on `data-selected`. JavaScript handles toggling.
 *
 * @example
 *   <RadioCard value="donasi" icon="heart"
 *     label="Konfirmasi Donasi" description="Laporan & konfirmasi transfer" />
 *   <RadioCard value="info" icon="book"
 *     label="Informasi Program" description="Tanya tentang program" />
 */
import Icon from '@components/ui/Icon.astro'

interface Props {
	value: string
	icon: string
	label: string
	description: string
	/** id for aria-describedby on the button; also used on the description <span> */
	describedBy: string
	class?: string
}

const { value, icon, label, description, describedBy, class: className } = Astro.props

const cardClass =
	'subjek-card relative flex flex-col items-center gap-1.5 rounded-xl border-2 border-warm-200 dark:border-warm-800 bg-white dark:bg-surface-secondary p-4 transition-all hover:border-primary-300 dark:hover:border-primary-600 hover:bg-primary-50/40 dark:hover:bg-primary-900/30 data-[selected=true]:border-primary-800 data-[selected=true]:bg-primary-50 dark:data-[selected=true]:border-primary-500 dark:data-[selected=true]:bg-primary-950 focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-primary-500/20 dark:focus-visible:ring-primary-400/30 cursor-pointer'
---

<button
	type="button"
	role="radio"
	aria-checked="false"
	data-value={value}
	class:list={[cardClass, className]}
	aria-describedby={describedBy}
>
	<div
		class="subjek-check absolute top-2 right-2 hidden data-[selected=true]:block text-primary-600 dark:text-primary-400"
		aria-hidden="true"
	>
		<svg class="h-4 w-4" fill="currentColor" viewBox="0 0 20 20">
			<path
				fill-rule="evenodd"
				d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z"
				clip-rule="evenodd"
			/>
		</svg>
	</div>
	<Icon
		name={icon}
		size={5}
		class="subjek-icon text-warm-400 dark:text-warm-500 data-[selected=true]:text-primary-600 dark:data-[selected=true]:text-primary-400"
		aria-hidden="true"
	/>
	<span class="text-sm font-semibold text-text-primary">{label}</span>
	<span id={describedBy} class="text-xs text-text-muted leading-tight">{description}</span>
</button>
