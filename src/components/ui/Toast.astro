---
/**
 * Toast notification component
 * Shows user-friendly error/success messages
 */

interface Props {
	type?: 'error' | 'success' | 'info'
	message: string
	duration?: number
}

const { type = 'info', message, duration = 5000 } = Astro.props
---

<div
	class="fixed bottom-4 right-4 z-50 transform transition-all duration-300 ease-in-out"
	data-toast
	role="alert"
	aria-live="polite"
>
	<div
		class="rounded-lg px-4 py-3 shadow-lg max-w-sm"
		class:bg-red-100={type === 'error'}
		class:border-red-500={type === 'error'}
		class:text-red-800={type === 'error'}
		class:bg-green-100={type === 'success'}
		class:border-green-500={type === 'success'}
		class:text-green-800={type === 'success'}
		class:bg-blue-100={type === 'info'}
		class:border-blue-500={type === 'info'}
		class:text-blue-800={type === 'info'}
	>
		<div class="flex items-start">
			<div class="flex-1">
				<p class="text-sm font-medium">{message}</p>
			</div>
			<button
				type="button"
				class="ml-4 inline-flex text-gray-400 hover:text-gray-600 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-blue-500 rounded-md"
				onclick="this.closest('[data-toast]')?.remove()"
				aria-label="Close notification"
			>
				<svg class="h-5 w-5" viewBox="0 0 20 20" fill="currentColor">
					<path
						fill-rule="evenodd"
						d="M4.293 4.293a1 1 0 011.414 0L10 8.586l4.293-4.293a1 1 0 111.414 1.414L11.414 10l4.293 4.293a1 1 0 01-1.414 1.414L10 11.414l-4.293 4.293a1 1 0 01-1.414-1.414L8.586 10 4.293 5.707a1 1 0 010-1.414z"
						clip-rule="evenodd"
					/>
				</svg>
			</button>
		</div>
	</div>
</div>

<script>
	// Auto-dismiss after duration
	const toast = document.querySelector('[data-toast]')
	if (toast) {
		setTimeout(() => {
			toast.style.opacity = '0'
			toast.style.transform = 'translateY(1rem)'
			setTimeout(() => toast.remove(), 300)
		}, duration)
	}
</script>