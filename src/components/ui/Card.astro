---
/**
 * Card — Content card container
 *
 * Variants: default, hover, overflow, plain.
 * When href is set, renders as <a> with card styling.
 */
interface Props {
	variant?: 'default' | 'hover' | 'overflow' | 'plain'
	padding?: 'sm' | 'md' | 'lg'
	class?: string
	href?: string
	'aria-label'?: string
}

const {
	variant = 'default',
	padding = 'md',
	href,
	class: className,
	'aria-label': ariaLabel,
} = Astro.props

const base =
	'rounded-xl sm:rounded-2xl bg-surface-elevated dark:bg-warm-900 shadow-sm dark:shadow-surface-inverse/20 transition-all duration-300 ease-out border border-border-secondary/60 dark:border-white/5'

const variants: Record<string, string> = {
	default: 'p-4 sm:p-6',
	hover:
		'p-4 sm:p-6 hover:-translate-y-1.5 hover:shadow-lg hover:shadow-primary-500/5 dark:hover:shadow-primary-500/5 hover:border-primary-500/30 dark:hover:border-primary-400/20',
	overflow: 'overflow-hidden shadow-sm',
	plain: 'p-4 sm:p-6',
}

const paddingMap: Record<string, string> = {
	sm: 'p-3 sm:p-4',
	md: 'p-4 sm:p-6',
	lg: 'p-5 sm:p-8',
}

const classes = [
	base,
	variants[variant],
	variant === 'default' || variant === 'overflow' || variant === 'hover' ? '' : paddingMap[padding],
	className,
]
---

{
	href ? (
		<a href={href} class:list={classes} aria-label={ariaLabel}>
			<slot />
		</a>
	) : (
		<div class:list={classes}>
			<slot />
		</div>
	)
}
