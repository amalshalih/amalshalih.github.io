---
interface Props {
	variant?: 'primary' | 'gold' | 'whatsapp' | 'outline' | 'outline-light' | 'secondary' | 'ghost'
	size?: 'sm' | 'md' | 'lg'
	href?: string
	type?: 'submit' | 'button' | 'reset'
	class?: string
	id?: string
	target?: string
	rel?: string
	'aria-label'?: string
}

const {
	variant = 'primary',
	size = 'md',
	href,
	type,
	class: className,
	id,
	target,
	rel,
	['aria-label']: ariaLabel,
} = Astro.props

const hasClass = (pattern: string) =>
	className && className.split(' ').some((c) => c.startsWith(pattern))

const base = [
	'inline-flex items-center justify-center gap-2 font-semibold active:scale-95',
	hasClass('rounded-') ? '' : 'rounded-lg',
	hasClass('hover:scale-') ? '' : 'hover:scale-[1.02]',
	hasClass('transition-') ? '' : 'transition-all duration-300 ease-out',
]
	.filter(Boolean)
	.join(' ')

const variants: Record<string, string> = {
	primary:
		'bg-accent-primary dark:bg-accent-primary text-text-on-primary dark:text-text-primary hover:bg-primary-800 dark:hover:bg-primary-500 focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-accent-primary focus-visible:ring-offset-2 dark:focus-visible:ring-offset-surface-inverse',
	gold: 'bg-accent-gold text-primary-950 hover:bg-gold-400 focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-accent-gold focus-visible:ring-offset-2 dark:focus-visible:ring-offset-surface-inverse',
	whatsapp:
		'bg-green-700 dark:bg-green-600 text-text-on-primary hover:bg-green-800 dark:hover:bg-green-500 focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-green-500 focus-visible:ring-offset-2 dark:focus-visible:ring-offset-surface-inverse',
	outline:
		'border border-border-primary dark:border-border-secondary text-text-primary dark:text-text-secondary hover:bg-surface-secondary dark:hover:bg-surface-inverse hover:text-text-primary dark:hover:text-text-inverse focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-accent-primary focus-visible:ring-offset-2 dark:focus-visible:ring-offset-surface-inverse',
	'outline-light':
		'border border-white/20 text-text-on-primary hover:bg-white/10 focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-white/50 focus-visible:ring-offset-2',
	secondary:
		'bg-surface-subtle dark:bg-warm-800 text-text-secondary dark:text-text-primary hover:bg-warm-200 dark:hover:bg-warm-700 focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-warm-400 focus-visible:ring-offset-2 dark:focus-visible:ring-offset-surface-inverse',
	ghost:
		'bg-transparent text-text-primary dark:text-text-secondary hover:bg-surface-subtle dark:hover:bg-surface-inverse hover:text-text-primary dark:hover:text-text-inverse focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-accent-primary focus-visible:ring-offset-2 dark:focus-visible:ring-offset-surface-inverse',
}

const sizes: Record<string, string> = {
	sm: 'px-3 py-2 text-xs sm:py-1.5',
	md: 'px-4 py-2.5 text-sm sm:px-5 sm:py-3',
	lg: 'px-5 py-3 text-sm sm:px-7 sm:py-3.5 sm:text-base',
}

const classes = [base, variants[variant], sizes[size], className]
---

{
	href ? (
		<a href={href} target={target} rel={rel} class:list={classes} aria-label={ariaLabel}>
			<slot />
		</a>
	) : (
		<button type={type} id={id} class:list={classes} aria-label={ariaLabel}>
			<slot />
		</button>
	)
}
