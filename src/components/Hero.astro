---
export interface Props {
	title: string
	subtitle?: string
	image?: string
	category?: string
	date?: string
	variant?: 'article' | 'event' | 'donation'
	showScrollIndicator?: boolean
}

const { title, subtitle, image, category, date, showScrollIndicator } = Astro.props
---

<div
	class="relative w-full overflow-hidden {Astro.props.variant === 'donation' ? 'bg-gradient-to-br from-primary-700 to-primary-900' : 'bg-primary-950'}"
>
	{image && (
		<div class="relative aspect-[16/9] overflow-hidden">
			<img
				src={image}
				alt={title}
				class="absolute inset-0 size-full object-cover transition-transform duration-700 hover:scale-[1.02]"
				loading="eager"
				decoding="async"
				fetchpriority="high"
			/>
			<div class="absolute inset-0 bg-gradient-to-b from-primary-950/60 via-primary-950/20 to-primary-950/80 backdrop-blur-[1px]" />
			<div
				class="absolute inset-0"
				style="mask-image: linear-gradient(to bottom, transparent 0%, black 25%, black 75%, transparent 100%); -webkit-mask-image: linear-gradient(to bottom, transparent 0%, black 25%, black 75%, transparent 100%);"
			/>
		</div>
	)}

	<div class="absolute bottom-0 left-0 right-0 p-4 pb-8 sm:p-8 sm:pb-12 lg:p-12 lg:pb-16">
		<div class="mx-auto max-w-3xl">
			{category && (
				<div class="mb-3 sm:mb-4 transform transition-all duration-300 hover:scale-[1.05]">
					<span
						class="inline-block rounded-full bg-primary-500/30 backdrop-blur-sm px-3 sm:px-4 py-1 text-[10px] sm:text-xs font-semibold text-primary-100 border border-primary-400/30 shadow-lg"
					>
						{category}
					</span>
				</div>
			)}

			<h1 class="text-xl sm:text-2xl lg:text-5xl font-extrabold leading-tight tracking-tight text-white drop-shadow-xl">
				{title}
			</h1>

			{subtitle && (
				<p class="mt-3 text-sm sm:text-base text-primary-300/90 drop-shadow-md">
					{subtitle}
				</p>
			)}

			{date && (
				<time datetime={date} class="mt-3 block text-xs sm:text-sm text-primary-300/90 drop-shadow-md font-medium tracking-wide">
					{date}
				</time>
			)}
		</div>
	</div>

	{showScrollIndicator && (
		<div class="absolute bottom-4 left-1/2 -translate-x-1/2 flex flex-col items-center gap-1 opacity-60">
			<span class="text-[10px] text-white uppercase tracking-widest">Scroll untuk melihat konten</span>
			<div class="w-px h-6 bg-gradient-to-b from-white to-transparent" />
		</div>
	)}
</div>

<style>
	:global(.hero-image-container) {
		position: relative;
		overflow: hidden;
		width: 100%;
		height: 0;
		padding-top: 56.25%;
	}

	:global(.hero-image) {
		position: absolute;
		top: 0;
		left: 0;
		width: 100%;
		height: 100%;
		object-fit: cover;
		transition: transform 0.7s ease;
	}

	@media (prefers-reduced-motion: reduce) {
		:global(.hero-image) {
			transition: none;
		}
	}
</style>
