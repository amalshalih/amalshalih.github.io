	#main-header.menu-open #header-capsule {
		background: rgba(0, 40, 15, 0.95) !important;
		backdrop-filter: blur(16px) !important;
		color: white !important;
	}
	#main-header.menu-open .desktop-nav-link,
	#main-header.menu-open #logo-text-1,
	#main-header.menu-open #logo-text-2,
	#main-header.menu-open #logo-text-mobile {
		color: white !important;
	}
	#main-header.menu-open #logo-text-2 {
		color: rgba(255,255,255,0.7) !important;
	}
	#main-header.menu-open .menu-icon {
		color: white !important;
	}
	/* Blog detail — lighter bg when menu open */
	body:has([data-page*="/blog/"]) #main-header.menu-open #header-capsule {
		background: rgba(255, 255, 255, 0.97) !important;
		color: #1c1917 !important;
	}
	@media (prefers-color-scheme: dark) {
		body:has([data-page*="/blog/"]) #main-header.menu-open #header-capsule {
			background: rgba(12, 10, 9, 0.97) !important;
			color: #f5f5f4 !important;
		}
	}
</style>
