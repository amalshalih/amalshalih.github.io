---
import { NAV_ITEMS } from '../lib/constants'
import { getSiteSettings } from '../lib/sanity/client'
import Button from './ui/Button.astro'
import Icon from './ui/Icon.astro'

interface Props {
	currentPage?: string
}

const { currentPage } = Astro.props

const isHomepage = currentPage === '/'
const isBlogDetail = currentPage?.startsWith('/blog/')

let navItems = NAV_ITEMS

try {
	const ss = await getSiteSettings()
	if (ss && ss.navItems && ss.navItems.length > 0) {
		navItems = ss.navItems
	}
} catch (error) {
	console.error('[Navbar] Sanity siteSettings fetch failed:', error)
}
---

<header
	id="main-header"
	class={`sticky top-0 z-50 w-full transition-all duration-500 ease-in-out pt-0 px-0 ${
		currentPage === '/' || currentPage?.startsWith('/blog/')
			? 'bg-transparent'
			: 'bg-white dark:bg-warm-950 border-b border-primary-100 dark:border-warm-800'
	}`}
	data-page={currentPage}
>
	<!-- Floating Glassmorphism Capsule -->
	<div
		id="header-capsule"
		class={`mx-auto w-full max-w-none rounded-none border border-transparent transition-all duration-500 ease-in-out ${
			isHomepage
				? 'bg-transparent text-white'
				: isBlogDetail
					? 'bg-transparent text-warm-900 dark:text-white'
					: 'bg-white/90 dark:bg-warm-950/80 backdrop-blur-md text-primary-800 dark:text-warm-200'
		}`}
	>
		<nav id="header-nav" class="mx-auto flex items-center justify-between px-4 py-3.5 sm:py-4 sm:px-8 transition-all duration-500 ease-in-out">
			<a href="/" class="flex items-center gap-2 sm:gap-3 shrink-0 transition-all duration-200 hover:opacity-90 active:scale-98">
				<img src="/logo-yayasan-sm.webp" alt="Logo Yayasan ASIB" class="h-10 w-10 sm:h-12 sm:w-12 rounded-full object-cover" width="48" height="48" fetchpriority="high" decoding="async" />
				<div class="hidden sm:block whitespace-nowrap">
					<p id="logo-text-1" class={`text-sm font-bold leading-tight transition-colors duration-300 ${isHomepage ? 'text-white' : isBlogDetail ? 'text-warm-900 dark:text-white' : 'text-primary-800 dark:text-warm-200'}`}>Yayasan Amal Shalih</p>
					<p id="logo-text-2" class={`text-xs transition-colors duration-300 ${isHomepage ? 'text-white/70' : isBlogDetail ? 'text-warm-600 dark:text-white/70' : 'text-warm-700 dark:text-warm-400'}`}>Insan Bantul</p>
				</div>
				<div class="sm:hidden">
					<p id="logo-text-mobile" class={`text-sm font-bold transition-colors duration-300 ${isHomepage ? 'text-white' : isBlogDetail ? 'text-warm-900 dark:text-white' : 'text-primary-800 dark:text-warm-200'}`}>Yayasan ASIB</p>
				</div>
			</a>

			<!-- Desktop Nav -->
			<div class="hidden sm:flex items-center justify-end gap-1 overflow-hidden">
				<div class="flex items-center gap-1 overflow-x-auto scrollbar-hide whitespace-nowrap snap-x snap-mandatory min-w-0 max-w-[320px] lg:max-w-none">
					{navItems.map((item) => (
						<a
							href={item.href}
							aria-current={currentPage === item.href ? 'page' : undefined}
							class={`desktop-nav-link rounded-lg px-3 py-2 text-sm font-medium transition-colors shrink-0 snap-start ${
								currentPage === item.href
									? isHomepage
										? 'bg-white/20 text-white'
										: isBlogDetail
											? 'bg-warm-100 dark:bg-white/20 text-warm-900 dark:text-white'
											: 'bg-primary-50 dark:bg-warm-800 text-primary-700 dark:text-warm-200'
									: isHomepage
										? 'text-white/80 hover:bg-white/10 hover:text-white'
										: isBlogDetail
											? 'text-warm-700/80 dark:text-white/80 hover:bg-warm-100 dark:hover:bg-white/10 hover:text-warm-900 dark:hover:text-white'
											: 'text-warm-700 dark:text-warm-300 hover:bg-warm-100 dark:hover:bg-warm-800 hover:text-warm-800 dark:hover:text-warm-100'
							}`}
						>
							{item.label}
						</a>
					))}
				</div>
				<Button
					href="/donasi"
					variant="primary"
					class="ml-2 px-4 py-2 text-sm shrink-0 font-semibold"
				>
					Donasi
				</Button>
			</div>

			<!-- Mobile Menu Button -->
			<button
				id="mobile-menu-button"
				type="button"
				class={`sm:hidden p-1.5 rounded-lg transition-colors duration-200 focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-offset-2 ${
					isHomepage
						? 'text-white hover:bg-white/10 focus-visible:ring-white focus-visible:ring-offset-primary-900'
						: isBlogDetail
							? 'text-warm-900 dark:text-white hover:bg-warm-100 dark:hover:bg-white/10 focus-visible:ring-warm-900 dark:focus-visible:ring-white focus-visible:ring-offset-2 dark:focus-visible:ring-offset-warm-950'
							: 'text-primary-800 dark:text-warm-200 hover:bg-primary-50 dark:hover:bg-warm-800 focus-visible:ring-primary-500 focus-visible:ring-offset-2 dark:focus-visible:ring-offset-warm-950'
				}`}
				aria-expanded="false"
				aria-controls="mobile-menu"
				aria-label="Buka menu navigasi"
			>
				<Icon name="menu" size={5} class="menu-icon" aria-hidden="true" />
				<Icon name="close" size={5} class="close-icon hidden" aria-hidden="true" />
			</button>
		</nav>

		<!-- Mobile Nav Drawer -->
		<div
			id="mobile-menu"
			class={`sm:hidden w-full transition-all duration-300 ease-in-out max-h-0 overflow-hidden opacity-0 rounded-b-2xl ${
				isHomepage
					? 'bg-primary-950/95 backdrop-blur-lg'
					: isBlogDetail
						? 'bg-white/95 dark:bg-warm-950/95 backdrop-blur-lg'
						: 'bg-white/95 dark:bg-warm-900/95 backdrop-blur-lg'
			}`}
			aria-hidden="true"
		>
			<div class={`flex flex-col p-4 pt-0 space-y-1 border-t ${isHomepage ? 'border-white/10' : isBlogDetail ? 'border-warm-100 dark:border-warm-800' : 'border-warm-100 dark:border-warm-800'}`}>
				{navItems.map((item) => (
					<a
						href={item.href}
						aria-current={currentPage === item.href ? 'page' : undefined}
						class={`rounded-lg px-4 py-3 text-base font-medium transition-colors ${
							currentPage === item.href
								? isHomepage
									? 'bg-white/20 text-white'
									: isBlogDetail
										? 'bg-warm-100 dark:bg-white/20 text-warm-900 dark:text-white'
										: 'bg-primary-50 dark:bg-warm-800 text-primary-700 dark:text-warm-200'
								: isHomepage
									? 'text-white/80 hover:bg-white/10 hover:text-white'
									: isBlogDetail
										? 'text-warm-700 dark:text-warm-300 hover:bg-warm-100 dark:hover:bg-warm-800 hover:text-warm-800 dark:hover:text-warm-100'
										: 'text-warm-700 dark:text-warm-300 hover:bg-warm-100 dark:hover:bg-warm-800 hover:text-warm-800 dark:hover:text-warm-100'
						}`}
					>
						{item.label}
					</a>
				))}
				<div class={`pt-3 border-t ${isHomepage ? 'border-white/10' : isBlogDetail ? 'border-warm-100 dark:border-warm-800' : 'border-warm-100 dark:border-warm-800'}`}>
					<a
						href="/donasi"
						class="block w-full text-center rounded-lg bg-primary-700 dark:bg-primary-600 px-4 py-3 text-base font-semibold text-white hover:bg-primary-800 dark:hover:bg-primary-500 transition-colors"
					>
						Donasi Sekarang
					</a>
				</div>
			</div>
		</div>
	</div>
</header>

<script>
	const menuButton = document.getElementById('mobile-menu-button');
	const mobileMenu = document.getElementById('mobile-menu');
	const menuIcon = menuButton?.querySelector('.menu-icon');
	const closeIcon = menuButton?.querySelector('.close-icon');

	function getFocusableElements() {
		if (!mobileMenu) return [];
		return Array.from(
			mobileMenu.querySelectorAll('a[href], button:not([disabled])')
		).filter((el) => el instanceof HTMLElement && el.offsetParent !== null) as HTMLElement[];
	}

	function toggleMenu() {
		if (!menuButton || !mobileMenu || !menuIcon || !closeIcon) return;

		const isExpanded = menuButton.getAttribute('aria-expanded') === 'true';
		menuButton.setAttribute('aria-expanded', String(!isExpanded));
		mobileMenu.setAttribute('aria-hidden', String(isExpanded));

		if (!isExpanded) {
			mobileMenu.classList.remove('max-h-0', 'opacity-0');
			mobileMenu.classList.add('max-h-96', 'opacity-100');
			menuIcon.classList.add('hidden');
			closeIcon.classList.remove('hidden');
			const firstLink = mobileMenu.querySelector('a');
			if (firstLink instanceof HTMLElement) {
				firstLink.focus();
			}
		} else {
			mobileMenu.classList.remove('max-h-96', 'opacity-100');
			mobileMenu.classList.add('max-h-0', 'opacity-0');
			menuIcon.classList.remove('hidden');
			closeIcon.classList.add('hidden');
			menuButton.focus();
		}
	}

	menuButton?.addEventListener('click', toggleMenu);

	document.addEventListener('keydown', (e) => {
		if (!menuButton || menuButton.getAttribute('aria-expanded') !== 'true') return;

		if (e.key === 'Escape') {
			e.preventDefault();
			toggleMenu();
			return;
		}

		if (e.key === 'Tab') {
			const focusables = getFocusableElements();
			if (focusables.length === 0) return;
			const first = focusables[0];
			const last = focusables[focusables.length - 1];
			const active = document.activeElement;

			if (e.shiftKey) {
				if (active === first || !mobileMenu?.contains(active as Node)) {
					e.preventDefault();
					last.focus();
				}
			} else {
				if (active === last || !mobileMenu?.contains(active as Node)) {
					e.preventDefault();
					first.focus();
				}
			}
		}
	});

	document.addEventListener('click', (e) => {
		if (
			menuButton?.getAttribute('aria-expanded') === 'true' &&
			!mobileMenu?.contains(e.target as Node) &&
			!menuButton?.contains(e.target as Node)
		) {
			toggleMenu();
		}
	});

	const header = document.getElementById('main-header');
	const capsule = document.getElementById('header-capsule');
	const nav = document.getElementById('header-nav');
	const logoText1 = document.getElementById('logo-text-1');
	const logoText2 = document.getElementById('logo-text-2');
	const logoTextMobile = document.getElementById('logo-text-mobile');
	const isHomepage = header?.dataset.page === '/';
	const isBlogDetail = header?.dataset.page?.startsWith('/blog/');
	const isTransparentPage = isHomepage || isBlogDetail;

	let lastIsScrolled: boolean | undefined = undefined;

	function handleScroll() {
		if (!header || !capsule || !nav) return;
		const isScrolled = window.scrollY > 40;

		if (isScrolled === lastIsScrolled) return;
		lastIsScrolled = isScrolled;

		if (isScrolled) {
			// Scrolled state: glassmorphism capsule with solid background
			// All pages get the same scrolled look regardless of page type
			header.classList.remove('pt-0', 'px-0', 'bg-white', 'border-b', 'border-primary-100', 'dark:bg-warm-950', 'dark:border-warm-800');
			header.classList.add('pt-3', 'sm:pt-4', 'px-3', 'sm:px-4');

			capsule.className = "mx-auto max-w-6xl rounded-2xl bg-white/90 dark:bg-warm-950/80 backdrop-blur-md shadow-lg shadow-primary-900/5 dark:shadow-warm-900/20 text-primary-800 dark:text-warm-200 transition-all duration-500 ease-in-out";
			nav.className = "flex items-center justify-between px-4 py-2.5 sm:py-3 sm:px-6 transition-all duration-500 ease-in-out";

			// Switch to solid colors for all pages when scrolled
			if (isTransparentPage) {
				if (logoText1) { logoText1.className = "text-sm font-bold leading-tight transition-colors duration-300 text-primary-800 dark:text-warm-200"; }
				if (logoText2) { logoText2.className = "text-xs transition-colors duration-300 text-warm-700 dark:text-warm-400"; }
				if (logoTextMobile) { logoTextMobile.className = "text-sm font-bold transition-colors duration-300 text-primary-800 dark:text-warm-200"; }
				if (menuButton) {
					menuButton.className = "sm:hidden p-1.5 rounded-lg transition-colors duration-200 focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-offset-2 text-primary-800 dark:text-warm-200 hover:bg-primary-50 dark:hover:bg-warm-800 focus-visible:ring-primary-500 focus-visible:ring-offset-2 dark:focus-visible:ring-offset-warm-950";
				}

				const links = document.querySelectorAll('.desktop-nav-link');
				links.forEach(link => {
					const isCurrent = link.getAttribute('aria-current') === 'page';
					if (isCurrent) {
						link.className = "desktop-nav-link rounded-lg px-3 py-2 text-sm font-medium transition-colors shrink-0 snap-start bg-primary-50 dark:bg-warm-800 text-primary-700 dark:text-warm-200";
					} else {
						link.className = "desktop-nav-link rounded-lg px-3 py-2 text-sm font-medium transition-colors shrink-0 snap-start text-warm-700 dark:text-warm-300 hover:bg-warm-100 dark:hover:bg-warm-800 hover:text-warm-800 dark:hover:text-warm-100";
					}
				});
			}
		} else {
			// Scroll top state
			header.classList.remove('pt-3', 'sm:pt-4', 'px-3', 'sm:px-4');
			header.classList.add('pt-0', 'px-0');

			if (isHomepage) {
				// Homepage: transparent + white text on dark green hero bg
				header.classList.add('bg-transparent');
				header.classList.remove('bg-white', 'border-b', 'border-primary-100', 'dark:bg-warm-950', 'dark:border-warm-800');
				capsule.className = "mx-auto w-full max-w-none rounded-none border border-transparent bg-transparent text-white transition-all duration-500 ease-in-out";
				nav.className = "flex items-center justify-between px-4 py-3.5 sm:py-4 sm:px-8 transition-all duration-500 ease-in-out";

				if (logoText1) { logoText1.className = "text-sm font-bold leading-tight transition-colors duration-300 text-white"; }
				if (logoText2) { logoText2.className = "text-xs transition-colors duration-300 text-white/70"; }
				if (logoTextMobile) { logoTextMobile.className = "text-sm font-bold transition-colors duration-300 text-white"; }
				if (menuButton) {
					menuButton.className = "sm:hidden p-1.5 rounded-lg transition-colors duration-200 focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-offset-2 text-white hover:bg-white/10 focus-visible:ring-white focus-visible:ring-offset-primary-900";
				}

				const links = document.querySelectorAll('.desktop-nav-link');
				links.forEach(link => {
					const isCurrent = link.getAttribute('aria-current') === 'page';
					if (isCurrent) {
						link.className = "desktop-nav-link rounded-lg px-3 py-2 text-sm font-medium transition-colors shrink-0 snap-start bg-white/20 text-white";
					} else {
						link.className = "desktop-nav-link rounded-lg px-3 py-2 text-sm font-medium transition-colors shrink-0 snap-start text-white/80 hover:bg-white/10 hover:text-white";
					}
				});

				// Mobile menu: dark overlay for homepage
				const mobileMenu = document.getElementById('mobile-menu');
				if (mobileMenu) {
					mobileMenu.className = "sm:hidden w-full transition-all duration-300 ease-in-out max-h-0 overflow-hidden opacity-0 rounded-b-2xl bg-primary-950/95 backdrop-blur-lg";
					const mobileMenuBorder = mobileMenu.querySelector('.border-t');
					if (mobileMenuBorder) {
						mobileMenuBorder.classList.remove('border-warm-100', 'dark:border-warm-800');
						mobileMenuBorder.classList.add('border-white/10');
					}
					const mobileLinks = mobileMenu.querySelectorAll('a');
					mobileLinks.forEach(link => {
						const isCurrent = link.getAttribute('aria-current') === 'page';
						if (isCurrent) {
							link.className = "rounded-lg px-4 py-3 text-base font-medium transition-colors bg-white/20 text-white";
						} else {
							link.className = "rounded-lg px-4 py-3 text-base font-medium transition-colors text-white/80 hover:bg-white/10 hover:text-white";
						}
					});
					const donateSection = mobileMenu.querySelector('.pt-3');
					if (donateSection) {
						donateSection.classList.remove('border-warm-100', 'dark:border-warm-800');
						donateSection.classList.add('border-white/10');
					}
				}
			} else if (isBlogDetail) {
				// Blog detail: transparent + theme-aware text (light hero bg on light theme)
				header.classList.add('bg-transparent');
				header.classList.remove('bg-white', 'border-b', 'border-primary-100', 'dark:bg-warm-950', 'dark:border-warm-800');
				capsule.className = "mx-auto w-full max-w-none rounded-none border border-transparent bg-transparent transition-all duration-500 ease-in-out";
				nav.className = "flex items-center justify-between px-4 py-3.5 sm:py-4 sm:px-8 transition-all duration-500 ease-in-out";

				// Dark text on light theme, light text on dark theme
				if (logoText1) { logoText1.className = "text-sm font-bold leading-tight transition-colors duration-300 text-warm-900 dark:text-white"; }
				if (logoText2) { logoText2.className = "text-xs transition-colors duration-300 text-warm-600 dark:text-white/70"; }
				if (logoTextMobile) { logoTextMobile.className = "text-sm font-bold transition-colors duration-300 text-warm-900 dark:text-white"; }
				if (menuButton) {
					menuButton.className = "sm:hidden p-1.5 rounded-lg transition-colors duration-200 focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-offset-2 text-warm-900 dark:text-white hover:bg-warm-100 dark:hover:bg-white/10 focus-visible:ring-warm-900 dark:focus-visible:ring-white focus-visible:ring-offset-2 dark:focus-visible:ring-offset-warm-950";
				}

				const links = document.querySelectorAll('.desktop-nav-link');
				links.forEach(link => {
					const isCurrent = link.getAttribute('aria-current') === 'page';
					if (isCurrent) {
						link.className = "desktop-nav-link rounded-lg px-3 py-2 text-sm font-medium transition-colors shrink-0 snap-start bg-warm-100 dark:bg-white/20 text-warm-900 dark:text-white";
					} else {
						link.className = "desktop-nav-link rounded-lg px-3 py-2 text-sm font-medium transition-colors shrink-0 snap-start text-warm-700/80 dark:text-white/80 hover:bg-warm-100 dark:hover:bg-white/10 hover:text-warm-900 dark:hover:text-white";
					}
				});

				// Mobile menu: light/dark solid bg for blog
				const mobileMenu = document.getElementById('mobile-menu');
				if (mobileMenu) {
					mobileMenu.className = "sm:hidden w-full transition-all duration-300 ease-in-out max-h-0 overflow-hidden opacity-0 rounded-b-2xl bg-white/95 dark:bg-warm-950/95 backdrop-blur-lg";
					const mobileMenuBorder = mobileMenu.querySelector('.border-t');
					if (mobileMenuBorder) {
						mobileMenuBorder.classList.remove('border-white/10', 'border-warm-100', 'dark:border-warm-800');
						mobileMenuBorder.classList.add('border-warm-100', 'dark:border-warm-800');
					}
					const mobileLinks = mobileMenu.querySelectorAll('a');
					mobileLinks.forEach(link => {
						const isCurrent = link.getAttribute('aria-current') === 'page';
						if (isCurrent) {
							link.className = "rounded-lg px-4 py-3 text-base font-medium transition-colors bg-warm-100 dark:bg-white/20 text-warm-900 dark:text-white";
						} else {
							link.className = "rounded-lg px-4 py-3 text-base font-medium transition-colors text-warm-700 dark:text-warm-300 hover:bg-warm-100 dark:hover:bg-warm-800 hover:text-warm-800 dark:hover:text-warm-100";
						}
					});
					const donateSection = mobileMenu.querySelector('.pt-3');
					if (donateSection) {
						donateSection.classList.remove('border-white/10', 'border-warm-100', 'dark:border-warm-800');
						donateSection.classList.add('border-warm-100', 'dark:border-warm-800');
					}
				}
			} else {
				// Solid header for other pages
				header.classList.add('bg-white', 'border-b', 'border-primary-100', 'dark:bg-warm-950', 'dark:border-warm-800');
				capsule.className = "mx-auto w-full max-w-none rounded-none border border-transparent bg-transparent text-primary-800 dark:text-warm-200 transition-all duration-500 ease-in-out";
				nav.className = "flex items-center justify-between px-4 py-3.5 sm:py-4 sm:px-8 transition-all duration-500 ease-in-out";
			}
		}
	}

	window.addEventListener('scroll', handleScroll, { passive: true });
	handleScroll();
</script>
