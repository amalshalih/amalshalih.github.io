---
import { getCollection, render } from 'astro:content'
import Card from '../../components/ui/Card.astro'
import Icon from '../../components/ui/Icon.astro'
import { CONTACT, SITE } from '../../data/site'
import BaseLayout from '../../layouts/BaseLayout.astro'
import { KATEGORI_LABELS } from '../../lib/constants'
import { getKegiatanItem, getKegiatanList, getSiteSettings } from '../../lib/sanity/client'
import { renderPortableText } from '../../lib/sanity/render'

// SSR mode for Cloudflare Workers (not static prerender)
export const prerender = false

const { slug } = Astro.params
if (!slug) {
	return Astro.redirect('/kegiatan')
}

type PageData = {
	title: string
	description: string
	date: Date
	kategori: string
	image?: string
	fromSanity: boolean
	bodyHtml: string
}

let pageData: PageData | null = null
let crumbLabels: Record<string, string> = {}
let kategoriLabels: Record<string, string> = {}

try {
	const settings = await getSiteSettings()
	if (settings?.breadcrumbLabels) {
		crumbLabels = settings.breadcrumbLabels
	}
	if (settings?.kategoriLabels) {
		kategoriLabels = { ...KATEGORI_LABELS, ...settings.kategoriLabels }
	}
} catch (error) {
	console.error('[Kegiatan Detail] Site settings fetch failed:', error)
}

let Content = null

// Sanity CMS sebagai sumber utama, fallback ke static markdown jika body/image kosong
try {
	const sanityItem = await getKegiatanItem(slug)
	if (sanityItem) {
		const bodyHtml = sanityItem.body ? renderPortableText(sanityItem.body) : ''
		let image = sanityItem.imageUrl || undefined

		// Jika Sanity body atau image kosong, coba fallback ke local markdown
		if (!bodyHtml || !image) {
			const localItems = await getCollection('kegiatan')
			const localItem = localItems.find((item) => item.id === slug)
			if (localItem) {
				if (!bodyHtml) {
					const rendered = await render(localItem)
					Content = rendered.Content
				}
				if (!image && localItem.data.image) {
					image = localItem.data.image
				}
			}
		}

		pageData = {
			title: sanityItem.title,
			description: sanityItem.excerpt ?? '',
			date: new Date(sanityItem.date),
			kategori: sanityItem.category,
			image,
			fromSanity: true,
			bodyHtml,
		}
	}
} catch (error) {
	console.error(`[Kegiatan Detail] Sanity kegiatanItem fetch failed for slug "${slug}":`, error)
}

if (!pageData) {
	const localItems = await getCollection('kegiatan')
	const localItem = localItems.find((item) => item.id === slug)
	if (localItem) {
		const rendered = await render(localItem)
		Content = rendered.Content
		pageData = {
			title: localItem.data.title,
			description: localItem.data.description,
			date: localItem.data.date,
			kategori: localItem.data.kategori,
			image: localItem.data.image,
			fromSanity: false,
			bodyHtml: '',
		}
	}
}

if (!pageData) {
	return Astro.redirect('/kegiatan')
}

const { title, description, date, kategori, image, fromSanity, bodyHtml } = pageData

const formattedDate = date.toLocaleDateString('id-ID', {
	weekday: 'long',
	year: 'numeric',
	month: 'long',
	day: 'numeric',
})

const canonicalUrl = `${SITE.url}/kegiatan/${slug}/`

// Related articles (exclude current, sort by date desc, take 3)
const allSlugs = new Set<string>()
try {
	const sanityItems = await getKegiatanList()
	for (const item of sanityItems) allSlugs.add(item.slug)
} catch (error) {
	console.error('[Kegiatan Detail] Sanity kegiatanList fetch failed:', error)
}
const localAll = await getCollection('kegiatan')
for (const item of localAll) allSlugs.add(item.id)

const relatedSlugs = Array.from(allSlugs)
	.filter((s) => s !== slug)
	.slice(0, 3)

// Build related items data
const relatedItems: {
	slug: string
	title: string
	description: string
	kategori: string
	date: Date
}[] = []

for (const rSlug of relatedSlugs) {
	// Try local first (cheaper)
	const localItem = localAll.find((i) => i.id === rSlug)
	if (localItem) {
		relatedItems.push({
			slug: rSlug,
			title: localItem.data.title,
			description: localItem.data.description,
			kategori: localItem.data.kategori,
			date: localItem.data.date,
		})
	}
}

const shareUrl = encodeURIComponent(canonicalUrl)
const shareTitle = encodeURIComponent(title)

// JSON-LD structured data for Article
const jsonLd = {
	'@context': 'https://schema.org',
	'@type': 'Article',
	headline: title,
	description: description,
	datePublished: date.toISOString(),
	dateModified: date.toISOString(),
	author: {
		'@type': 'Organization',
		name: SITE.name,
		url: SITE.url,
	},
	publisher: {
		'@type': 'Organization',
		name: SITE.name,
		url: SITE.url,
		logo: {
			'@type': 'ImageObject',
			url: `${SITE.url}/logo-yayasan.webp`,
		},
	},
	mainEntityOfPage: {
		'@type': 'WebPage',
		'@id': canonicalUrl,
	},
	articleSection: kategoriLabels[kategori] || KATEGORI_LABELS[kategori] || kategori,
	keywords: ['yayasan', 'amal shalih', 'insan bantul', 'kegiatan', kategori],
}

// BreadcrumbList JSON-LD
const crumbBeranda = crumbLabels.beranda || 'Beranda'
const crumbKegiatan = crumbLabels.kegiatan || 'Kegiatan'
const breadcrumbJsonLd = {
	'@context': 'https://schema.org',
	'@type': 'BreadcrumbList',
	itemListElement: [
		{ '@type': 'ListItem', position: 1, name: crumbBeranda, item: SITE.url },
		{ '@type': 'ListItem', position: 2, name: crumbKegiatan, item: `${SITE.url}/kegiatan/` },
		{ '@type': 'ListItem', position: 3, name: title, item: canonicalUrl },
	],
}
---

<BaseLayout
	title={`${title} — Kegiatan Yayasan ASIB`}
	description={description}
	image={image || '/logo-yayasan.webp'}
	pageType="article"
>
	<!-- JSON-LD Structured Data -->
<script is:inline type="application/ld+json" set:html={JSON.stringify(jsonLd)} />
<script is:inline type="application/ld+json" set:html={JSON.stringify(breadcrumbJsonLd)} />

	<!-- Article-specific OG meta (og:type + og:image handled by BaseHead via pageType + image props) -->
	<meta property="article:published_time" content={date.toISOString()} />
	<meta property="article:section" content={kategoriLabels[kategori] || KATEGORI_LABELS[kategori] || kategori} />

	<!-- Hero Section -->
	<div class="relative w-full overflow-hidden bg-primary-950 hero-section" data-hero="true">
		{image ? (
			<div class="relative h-[45vh] min-h-[320px] sm:h-[55vh] sm:min-h-[380px] lg:min-h-[460px]">
				<img 
					src={image}
					alt={title}
					class="absolute inset-0 w-full h-full object-cover hero-image"
					loading="eager"
					decoding="async"
				/>
				<!-- Dual gradient overlay: top fade + bottom fade for text readability -->
				<div class="absolute inset-0 bg-gradient-to-b from-primary-950/70 via-primary-950/10 via-40% to-primary-950/90" style="-webkit-mask-image: linear-gradient(to bottom, transparent 0%, black 25%, black 75%, transparent 100%); mask-image: linear-gradient(to bottom, transparent 0%, black 25%, black 75%, transparent 100%);" />
				
				<!-- Content overlay at bottom of hero -->
				<div class="absolute bottom-0 left-0 right-0 p-4 sm:p-8 lg:p-12 pb-8 sm:pb-12 lg:pb-16">
					<div class="mx-auto max-w-3xl">
						<div class="mb-2 sm:mb-3 flex flex-wrap items-center gap-2 sm:gap-3">
							<span class="inline-block rounded-full bg-primary-500/20 backdrop-blur-sm px-2.5 sm:px-3 py-0.5 sm:py-1 text-[10px] sm:text-xs font-semibold text-primary-200 ring-1 ring-inset ring-primary-400/30 drop-shadow-md text-shadow-sm hero-badge">
								{kategoriLabels[kategori] || KATEGORI_LABELS[kategori] || kategori}
							</span>
							<time datetime={date.toISOString()} class="text-[10px] sm:text-xs text-primary-300/80 drop-shadow-md font-medium tracking-wide text-shadow-sm drop-shadow-lg" itemprop="datePublished">
								{formattedDate}
							</time>
						</div>
						<h1 class="text-xl sm:text-2xl lg:text-5xl font-extrabold leading-tight tracking-tight text-white drop-shadow-2xl text-shadow-xl hero-title" itemprop="name headline">
							{title}
						</h1>
					</div>
				</div>
			</div>
		) : (
			<div class="relative h-[30vh] min-h-[200px] sm:h-[35vh] sm:min-h-[260px] flex items-center justify-center bg-gradient-to-br from-primary-800 to-primary-950">
				<div class="text-center px-4">
					<div class="mx-auto mb-3 sm:mb-4 flex h-12 w-12 sm:h-16 sm:w-16 items-center justify-center rounded-full border-2 border-primary-400/20 bg-primary-800/50 backdrop-blur-sm">
						<Icon name="book" size={6} class="text-primary-300" aria-hidden="true" />
					</div>
					<p class="text-[10px] sm:text-xs font-medium uppercase tracking-widest text-primary-400">Arsip Kegiatan</p>
					<h1 class="mt-2 text-lg sm:text-xl font-bold text-white">{title}</h1>
				</div>
</div>
  )}
  
  <!-- Scroll indicator -->
  <div class="absolute bottom-4 left-1/2 transform -translate-x-1/2 opacity-60 scroll-indicator">
    <span class="text-[10px] text-white uppercase tracking-widest">Scroll untuk melihat konten</span>
  </div>
</div>

		<!-- Article Content -->
	<article class="mx-auto max-w-3xl px-4 sm:px-6" itemscope itemtype="https://schema.org/Article">
		<!-- Breadcrumb Navigation -->
		<nav class="py-3 sm:py-6 text-sm" aria-label="Breadcrumb">
			<ol class="flex items-center gap-2 text-text-muted overflow-x-auto whitespace-nowrap">
				<li><a href="/" class="hover:text-primary-600 dark:hover:text-primary-400 transition-colors">{crumbBeranda}</a></li>
				<li class="text-text-muted">/</li>
				<li><a href="/kegiatan" class="hover:text-primary-600 dark:hover:text-primary-400 transition-colors">{crumbKegiatan}</a></li>
				<li class="text-text-muted">/</li>
				<li class="text-text-secondary font-medium truncate max-w-[50vw]" aria-current="page">{title}</li>
			</ol>
		</nav>

		<!-- Metadata bar (simplified — kategori + date already on hero) -->
		<div class="mb-6 flex items-center gap-2 text-xs text-text-muted">
			<Icon name="calendar" size={4} class="shrink-0" aria-hidden="true" />
			<span>Arsip #{slug}</span>
		</div>

		<!-- Lead / Description -->
		<p class="mb-6 sm:mb-8 text-sm leading-relaxed text-text-secondary sm:text-base" itemprop="description">
			{description}
		</p>

		<!-- Article Body with Prose Typography -->
		<div class="prose prose-warm max-w-none sm:prose-lg
			prose-headings:font-display prose-headings:font-bold prose-headings:tracking-tight
			prose-headings:text-warm-900 dark:prose-headings:text-warm-100
			prose-p:text-warm-800 dark:prose-p:text-warm-200
			prose-a:text-primary-600 dark:prose-a:text-primary-400 prose-a:no-underline prose-a:font-medium hover:prose-a:underline
			prose-blockquote:border-l-4 prose-blockquote:border-primary-400 prose-blockquote:bg-primary-50/50 dark:prose-blockquote:bg-primary-900/30 prose-blockquote:px-4 prose-blockquote:py-2.5 prose-blockquote:rounded-r-xl prose-blockquote:not-italic prose-blockquote:leading-relaxed prose-blockquote:font-normal
			prose-img:rounded-xl prose-img:shadow-md
			prose-table:overflow-x-auto prose-table:block prose-table:w-full prose-table:border prose-table:border-warm-200 dark:prose-table:border-warm-700 prose-table:rounded-lg
			prose-thead:bg-primary-50 dark:prose-thead:bg-primary-900/60 prose-thead:text-primary-800 dark:prose-thead:text-primary-200
			prose-th:px-4 prose-th:py-2 prose-th:text-left prose-th:text-sm prose-th:font-semibold prose-th:uppercase prose-th:tracking-wider
			prose-td:px-4 prose-td:py-2 prose-td:text-sm
			prose-tr:border-b prose-tr:border-warm-100 dark:prose-tr:border-warm-800
			prose-code:bg-primary-50 dark:prose-code:bg-primary-900/40 prose-code:px-1.5 prose-code:py-0.5 prose-code:rounded prose-code:text-sm prose-code:font-mono
			prose-pre:bg-warm-900 prose-pre:text-warm-100 prose-pre:rounded-xl prose-pre:p-4 prose-pre:overflow-x-auto
			prose-hr:border-warm-200 dark:prose-hr:border-warm-700
		">
			{fromSanity && bodyHtml ? <div set:html={bodyHtml} /> : Content && <Content />}
		</div>

		<!-- Share & Navigation -->
		<div class="mt-8 sm:mt-12 flex flex-col items-start gap-4 border-t border-border-secondary/60 pt-5 sm:pt-6 sm:flex-row sm:items-center sm:justify-between">
			<div class="flex items-center gap-3">
				<span class="text-sm font-medium text-text-secondary">Bagikan:</span>
				<div class="flex gap-2" data-share-buttons>
					<a
						href={`https://wa.me/?text=${shareTitle}%20${shareUrl}`}
						target="_blank"
						rel="noopener noreferrer"
						class="inline-flex items-center justify-center rounded-lg bg-green-600 p-2.5 text-white shadow-sm transition-colors duration-200 hover:bg-green-700 hover:shadow-md focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-green-500 focus-visible:ring-offset-2"
						aria-label="Bagikan via WhatsApp"
					>
						<Icon name="whatsapp" size={5} aria-hidden="true" />
					</a>
					<a
						href={`https://www.facebook.com/sharer/sharer.php?u=${shareUrl}`}
						target="_blank"
						rel="noopener noreferrer"
						class="inline-flex items-center justify-center rounded-lg bg-blue-600 p-2.5 text-white shadow-sm transition-colors duration-200 hover:bg-blue-700 hover:shadow-md focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-blue-500 focus-visible:ring-offset-2"
						aria-label="Bagikan via Facebook"
					>
						<Icon name="facebook" size={5} aria-hidden="true" />
					</a>
					<button
						type="button"
						data-copy-url={shareUrl}
						class="copy-url-btn inline-flex items-center justify-center rounded-lg bg-warm-600 p-2.5 text-white shadow-sm transition-colors duration-200 hover:bg-warm-700 hover:shadow-md focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-warm-400 focus-visible:ring-offset-2"
						aria-label="Salin tautan"
					>
						<Icon name="external-link" size={5} aria-hidden="true" />
					</button>
				</div>
			</div>
			<a
				href="/kegiatan"
				class="inline-flex items-center gap-1.5 text-sm font-medium text-text-muted hover:text-primary-600 dark:hover:text-primary-400 transition-colors"
			>
				<Icon name="arrow-left" size={4} aria-hidden="true" />
				Kembali ke Daftar Kegiatan
			</a>
		</div>

		<!-- CTA Donasi -->
		<div class="mt-6 sm:mt-8 relative overflow-hidden rounded-xl sm:rounded-2xl bg-gradient-to-br from-primary-700 to-primary-900 p-4 sm:p-6 lg:p-10 text-center shadow-xl">
			<div class="absolute -right-12 -top-12 h-40 w-40 rounded-full bg-white/5" />
			<div class="absolute -bottom-16 -left-16 h-56 w-56 rounded-full bg-white/5" />
			<div class="absolute right-8 top-8 h-2 w-2 rounded-full bg-gold-400/60" />
			<div class="absolute bottom-12 left-12 h-1.5 w-1.5 rounded-full bg-gold-300/40" />

			<div class="relative z-10">
				<div class="mx-auto mb-2 sm:mb-3 flex h-10 w-10 sm:h-14 sm:w-14 items-center justify-center rounded-full bg-white/15">
					<Icon name="heart" size={6} class="text-gold-300 sm:size-7" aria-hidden="true" />
				</div>
				<h2 class="text-lg sm:text-xl lg:text-3xl font-bold text-white">Dukung Program Kami</h2>
				<p class="mx-auto mt-2 max-w-md text-xs sm:text-sm lg:text-base leading-relaxed text-primary-100">
					Setiap donasi Anda membantu kami menjangkau lebih banyak penerima manfaat dan mewujudkan dampak nyata bagi umat.
				</p>
				<div class="mt-3 sm:mt-4 flex flex-col gap-3 sm:flex-row sm:items-center sm:justify-center sm:gap-4 sm:mt-6">
					<a
						href="/donasi"
						class="flex w-full sm:w-auto items-center justify-center gap-2 rounded-lg bg-white px-5 py-3 sm:px-6 sm:py-3 text-sm font-semibold text-primary-700 shadow-lg transition-colors duration-200 hover:bg-primary-50 hover:scale-[1.02] active:scale-95"
					>
						Donasi Sekarang
						<Icon name="arrow-right" size={5} aria-hidden="true" />
					</a>
					<a
						href={CONTACT.whatsapp}
						target="_blank"
						rel="noopener noreferrer"
						class="flex w-full sm:w-auto items-center justify-center gap-2 rounded-lg border border-white/30 px-5 py-3 sm:px-5 sm:py-2.5 text-sm font-medium text-white transition-colors duration-200 hover:bg-white/10 hover:border-white/50"
					>
						<Icon name="whatsapp" size={5} aria-hidden="true" />
						Hubungi Kami
					</a>
				</div>
			</div>
		</div>

		<!-- Related Articles -->
		{relatedItems.length > 0 && (
			<section class="mt-10 sm:mt-16 mb-6 sm:mb-8">
				<h2 class="mb-2 text-xl sm:text-2xl font-bold text-text-primary">Arsip Kegiatan Terkait</h2>
				<p class="mb-6 sm:mb-8 text-xs sm:text-sm text-text-muted">Dokumen kegiatan lain yang mungkin relevan</p>
				<div class="grid gap-4 sm:gap-6 sm:grid-cols-2 lg:grid-cols-3">
					{relatedItems.map((related) => (
						<Card variant="hover" href={`/kegiatan/${related.slug}`}>
							<div class="mb-2 sm:mb-3 flex items-center gap-2 sm:gap-3">
								<span class="inline-block rounded-full bg-primary-50 dark:bg-primary-900/40 px-2 py-0.5 text-[10px] sm:text-xs font-medium text-primary-700 dark:text-primary-200">
									{kategoriLabels[related.kategori] || KATEGORI_LABELS[related.kategori] || related.kategori}
								</span>
								<time datetime={related.date.toISOString()} class="text-[10px] sm:text-xs text-text-muted">
									{related.date.toLocaleDateString('id-ID', {
										year: 'numeric',
										month: 'short',
										day: 'numeric',
									})}
								</time>
							</div>
							<h3 class="text-sm sm:text-base font-bold leading-snug text-text-primary group-hover:text-primary-600 dark:group-hover:text-primary-400 transition-colors line-clamp-2">
								{related.title}
							</h3>
							<p class="mt-1.5 sm:mt-2 text-xs sm:text-sm leading-relaxed text-text-secondary line-clamp-2">
								{related.description}
							</p>
						</Card>
					))}
				</div>
			</section>
		)}
	</article>

	<!-- Spacer before footer -->
	<div class="h-16" />
</BaseLayout>

<!-- Aria-live region for screen reader announcements -->
<div id="share-announcement" class="sr-only" role="status" aria-live="polite" aria-label="Pemberitahuan penyalinan tautan"></div>

<script is:inline>
// Service Worker registration for offline functionality
if ('serviceWorker' in navigator) {
	navigator.serviceWorker.register('/sw.js')
		.then(registration => {
			console.log('Service Worker registered successfully:', registration.scope);
			
			// Listen for updates
			registration.onupdatefound = () => {
				const installingWorker = registration.installing;
				if (installingWorker) {
					installingWorker.onstatechange = () => {
						if (installingWorker.state === 'installed' && navigator.serviceWorker.controller) {
							// New service worker found, show update notification
							if (confirm('Update available. Reload to apply new features?')) {
								window.location.reload();
							}
						}
					};
				}
			};
		})
		.catch(error => {
			console.error('Service Worker registration failed:', error);
		});
}
</script>

<script is:inline>
// Hero component integration - initialize enhanced hero behavior
(() => {
	const heroElement = document.querySelector('.hero-section');
	if (heroElement) {
		// Add scroll listener for scroll indicator
		const scrollIndicator = document.querySelector('.scroll-indicator');
		const heroHeight = heroElement.offsetHeight;
		
		window.addEventListener('scroll', () => {
			const scrollPercent = window.scrollY / heroHeight;
			if (scrollPercent > 0.1) {
				scrollIndicator?.classList.add('opacity-0');
			} else {
				scrollIndicator?.classList.remove('opacity-0');
			}
		});
	}
})();
</script>

<script is:inline>
// Copy-to-clipboard functionality with aria-live announcement
(() => {
	const copyButtons = document.querySelectorAll('[data-copy-url]');
	const announcement = document.getElementById('share-announcement');
	
	copyButtons.forEach(button => {
		button.addEventListener('click', async () => {
			const url = button.getAttribute('data-copy-url');
			if (!url) return;
			
			try {
				await navigator.clipboard.writeText(decodeURIComponent(url));
				button.classList.add('copied');
				
				// Announce to screen readers
				if (announcement) {
					announcement.textContent = 'Tautan berhasil disalin';
					announcement.classList.remove('sr-only');
					setTimeout(() => announcement.classList.add('sr-only'), 3000);
				}
			} catch (err) {
				console.error('Failed to copy:', err);
			}
		});
	});
})();
</script>

<script is:inline>
// Initialize micro-interactions for hero elements
(() => {
	const heroBadge = document.querySelector('.hero-badge');
	const heroTitle = document.querySelector('.hero-title');
	
	if (heroBadge) {
		heroBadge.addEventListener('mouseenter', () => {
			heroBadge.style.transform = 'scale(1.05)';
		});
		heroBadge.addEventListener('mouseleave', () => {
			heroBadge.style.transform = 'scale(1)';
		});
	}
	
	if (heroTitle) {
		heroTitle.addEventListener('mouseenter', () => {
			heroTitle.style.textShadow = '0 0 20px rgba(255, 255, 255, 0.5)';
		});
		heroTitle.addEventListener('mouseleave', () => {
			heroTitle.style.textShadow = 'none';
		});
	}
})();
</script>

<script is:inline>
// Cache-first fetch for hero images
(() => {
	const heroImage = document.querySelector('.hero-image');
	if (heroImage && 'serviceWorker' in navigator) {
		// Try to fetch from cache first
		caches.match(heroImage.src)
			.then(response => {
				if (response) {
					heroImage.src = URL.createObjectURL(response);
				}
			})
			.catch(() => {
				// Fallback to network
				return fetch(heroImage.src);
			});
	}
})();
</script>