---
import BaseLayout from '../../layouts/BaseLayout.astro';
import PageHeader from '../../components/sections/PageHeader.astro';
import Container from '../../components/ui/Container.astro';
import Card from '../../components/ui/Card.astro';
import { getCollection } from 'astro:content';

const posts = await getCollection('blog');
const sortedPosts = posts.sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());
---

<BaseLayout 
	title="Blog & Edukasi" 
	description="Artikel edukasi dan informasi seputar keislaman, sosial kemanusiaan, dan update terbaru Yayasan Amal Shalih Insan Bantul untuk menunjang wawasan umat."
	currentPage="/blog"
>
	<PageHeader 
		label="Wawasan & Edukasi"
		title="Blog Yayasan ASIB"
		description="Kumpulan artikel mendalam mengenai pendidikan Islam, manajemen zakat, wakaf, dan berbagai tips sosial kemanusiaan."
	/>

	<Container as="section" class="py-12 sm:py-20">
		<div class="grid gap-6 sm:gap-8 grid-cols-1 md:grid-cols-2 lg:grid-cols-3">
			{sortedPosts.map(post => (
				<Card 
					variant="hover" 
					href={`/blog/${post.id}`}
					class="flex flex-col h-full"
				>
					{post.data.image && (
						<div class="relative h-48 w-full overflow-hidden rounded-t-xl">
							<img 
								src={post.data.image} 
								alt={post.data.title} 
								class="h-full w-full object-cover transition-transform duration-500 hover:scale-105" 
								loading="lazy" 
							/>
						</div>
					)}
					<div class="p-6">
						<div class="mb-3 flex items-center gap-2">
							<span class="rounded-full bg-primary-50 px-2.5 py-0.5 text-xs font-medium text-primary-700">
								{post.data.category || 'Umum'}
							</span>
							<span class="text-xs text-warm-500">
								{post.data.date.toLocaleDateString('id-ID', { day: 'numeric', month: 'long', year: 'numeric' })}
							</span>
						</div>
						<h3 class="mb-3 text-xl font-bold text-warm-900 line-clamp-2">
							{post.data.title}
						</h3>
						<p class="mb-6 text-sm text-warm-600 line-clamp-3 leading-relaxed">
							{post.data.description}
						</p>
						<div class="mt-auto flex items-center gap-2 text-sm font-semibold text-primary-600 hover:text-primary-700 transition-colors">
							Baca Selengkapnya
							<svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4 transition-transform group-hover:translate-x-1" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
								<path stroke-linecap="round" stroke-linejoin="round" d="M17 8l4 4m0 0l-4 4m4-4H3" />
							</svg>
						</div>
					</div>
				</Card>
			))}
		</div>
	</Container>
</BaseLayout>
