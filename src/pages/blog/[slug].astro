---
import { getCollection, render } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import Container from '../../components/ui/Container.astro';
import Button from '../../components/ui/Button.astro';
import Icon from '../../components/ui/Icon.astro';

export async function getStaticPaths() {
	const blogPosts = await getCollection('blog');
	return blogPosts.map(post => ({
		params: { slug: post.id },
		props: { post },
	}));
}

const { post } = Astro.props;
const { Content } = await render(post);

const formattedDate = post.data.date.toLocaleDateString('id-ID', {
	weekday: 'long',
	year: 'numeric',
	month: 'long',
	day: 'numeric',
});

// Estimate reading time (avg 200 words per minute)
const words = post.body?.split(/\s+/).length || 0;
const readingTime = Math.ceil(words / 200);

// Fetch related posts
const allPosts = await getCollection('blog');
const relatedPosts = allPosts
	.filter(p => p.id !== post.id && p.data.category === post.data.category)
	.slice(0, 3);
---

<BaseLayout 
	title={post.data.title} 
	description={post.data.description} 
	image={post.data.image} 
	pageType="article"
	publishedTime={post.data.date.toISOString()}
	modifiedTime={post.data.date.toISOString()}
	currentPage={`/blog/${post.slug}`}
>
	<Container as="section" class="py-8 sm:py-16">
		<div class="mx-auto max-w-3xl">
			<!-- Breadcrumbs -->
			<nav class="mb-8 flex items-center gap-2 text-xs font-medium text-warm-500">
				<a href="/" class="hover:text-primary-600 transition-colors">Beranda</a>
				<Icon name="chevron-right" size={3} class="shrink-0" />
				<a href="/blog" class="hover:text-primary-600 transition-colors">Blog</a>
				<Icon name="chevron-right" size={3} class="shrink-0" />
				<span class="text-warm-900 truncate">{post.data.title}</span>
			</nav>

			<!-- Article Header -->
			<header class="mb-10 text-center">
				<div class="mb-4 flex flex-wrap justify-center items-center gap-3">
					<span class="rounded-full bg-primary-50 px-3 py-1 text-xs font-semibold text-primary-700 ring-1 ring-inset ring-primary-600/20">
						{post.data.category || 'Edukasi'}
					</span>
					<div class="flex items-center gap-1.5 text-xs text-warm-500">
						<Icon name="calendar" size={4} class="shrink-0" />
						{formattedDate}
					</div>
					<div class="flex items-center gap-1.5 text-xs text-warm-500">
						<Icon name="clock" size={4} class="shrink-0" />
						{readingTime} mnt baca
					</div>
				</div>
				<h1 class="mb-6 text-2xl font-extrabold tracking-tight text-warm-900 sm:text-4xl lg:text-5xl leading-tight">
					{post.data.title}
				</h1>
				<div class="flex items-center justify-center gap-3 text-sm text-warm-600">
					<div class="h-9 w-9 rounded-full bg-primary-100 flex items-center justify-center text-primary-700 font-bold ring-2 ring-white shadow-sm">
						{post.data.author?.[0] || 'A'}
					</div>
					<div class="text-left">
						<p class="font-semibold text-warm-900 leading-none mb-1">{post.data.author}</p>
						<p class="text-xs opacity-80">Penulis Konten</p>
					</div>
				</div>
			</header>

			{post.data.image && (
				<div class="mb-12 overflow-hidden rounded-3xl shadow-2xl ring-1 ring-warm-200">
					<img 
						src={post.data.image} 
						alt={post.data.title} 
						class="w-full object-cover aspect-video sm:aspect-auto" 
						loading="eager" 
					/>
				</div>
			)}

			<!-- Article Content -->
			<div class="prose prose-slate max-w-none 
				prose-headings:text-warm-900 prose-headings:tracking-tight
				prose-p:text-warm-700 prose-p:leading-relaxed
				prose-a:text-primary-600 hover:prose-a:text-primary-700 prose-a:font-medium
				prose-strong:text-warm-900 prose-strong:font-bold
				prose-blockquote:border-l-primary-500 prose-blockquote:bg-primary-50 prose-blockquote:py-1 prose-blockquote:px-4 prose-blockquote:rounded-r-lg
				prose-img:rounded-2xl prose-img:shadow-md
				sm:prose-lg">
				<Content />
			</div>

			<!-- Footer / Engagement Section -->
			<div class="mt-20 space-y-12">
				<!-- Share & CTA -->
				<div class="rounded-3xl bg-gradient-to-br from-primary-800 to-primary-950 p-8 sm:p-12 text-center text-white shadow-xl">
					<h3 class="mb-4 text-2xl font-bold">Suka dengan artikel ini?</h3>
					<p class="mb-8 text-primary-100 opacity-90 max-w-xl mx-auto">
						Bagikan informasi bermanfaat ini kepada keluarga dan kerabat untuk menebar kemaslahatan bersama.
					</p>
					<div class="flex flex-col sm:flex-row justify-center gap-4">
						<a href="https://wa.me/share?text=Baca artikel menarik ini: " target="_blank" rel="noopener noreferrer" class="inline-flex items-center justify-center gap-2 rounded-xl bg-green-600 px-6 py-3 text-sm font-bold text-white hover:bg-green-700 transition-all hover:scale-105 shadow-lg active:scale-95">
							<Icon name="whatsapp" size={4} />
							Bagikan via WhatsApp
						</a>
						<a href="/blog" class="inline-flex items-center justify-center gap-2 rounded-xl bg-white/10 backdrop-blur-sm px-6 py-3 text-sm font-bold text-white border border-white/20 hover:bg-white/20 transition-all hover:scale-105 active:scale-95">
							<Icon name="arrow-left" size={4} />
							Kembali ke Blog
						</a>
					</div>
				</div>

				<!-- Related Posts -->
				{relatedPosts.length > 0 && (
					<div class="pt-12 border-t border-warm-200">
						<h3 class="mb-8 text-2xl font-bold text-warm-900 flex items-center gap-3">
							<span class="h-8 w-1 bg-primary-600 rounded-full"></span>
							Artikel Terkait
						</h3>
						<div class="grid gap-6 sm:grid-cols-2 lg:grid-cols-3">
							{relatedPosts.map(post => (
								<a href={`/blog/${post.id}`} class="group block p-4 rounded-2xl border border-warm-100 bg-white hover:border-primary-200 hover:shadow-md transition-all">
									<div class="aspect-video overflow-hidden rounded-xl mb-4">
										<img src={post.data.image || '/logo-yayasan.webp'} alt={post.data.title} class="h-full w-full object-cover group-hover:scale-105 transition-transform duration-500" />
									</div>
									<h4 class="font-bold text-warm-900 group-hover:text-primary-700 transition-colors line-clamp-2 mb-2">
										{post.data.title}
									</h4>
									<p class="text-xs text-warm-500 line-clamp-2 leading-relaxed">
										{post.data.description}
									</p>
								</a>
							))}
						</div>
					</div>
				)}
			</div>
		</div>
	</Container>
</BaseLayout>
