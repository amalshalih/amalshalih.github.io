---
import BaseLayout from '../layouts/BaseLayout.astro';
import Container from '../components/ui/Container.astro';
import PageHeader from '../components/sections/PageHeader.astro';
import Card from '../components/ui/Card.astro';
import Button from '../components/ui/Button.astro';
import Icon from '../components/ui/Icon.astro';
import { getProgramList } from '../lib/sanity/client';
import type { SanityProgram } from '../lib/sanity/types';

type Item = {
  title: string;
  badge?: string;
  description: string;
  variant: 'default' | 'overflow';
  stats?: { number: string; label: string }[];
};

const FALLBACK: Record<string, Item[]> = {
  pendidikan: [
    { title: 'PKBM Bina Insan Mulia', badge: 'Pendidikan Diniyah', variant: 'default', description: 'Pusat Kegiatan Belajar Masyarakat dengan materi Diniyah untuk mempersiapkan generasi milenial yang beraqidah kuat dan berakhlak mulia.', stats: [{ number: '21', label: 'Ustadz/Ustadzah' }, { number: '70', label: 'Santri' }] },
    { title: 'PAUD Bina Tunas Mulia', badge: 'Usia 1–6 Tahun', variant: 'default', description: 'Program pendidikan non-formal untuk taman pengasuhan anak dan kelompok bermain. Membuka layanan untuk anak usia 1 hingga 6 tahun.', stats: [{ number: '4', label: 'Guru' }, { number: '8', label: 'Siswa' }] },
    { title: 'Rumah Tahfidz', badge: 'Tahfidz & Tahsin', variant: 'default', description: 'Pesantren tahfidz yang diselenggarakan di kantor yayasan. Program tahfidz dan tahsin Al-Qur\'an bagi para santriwati dengan bimbingan ustadzah berpengalaman.', stats: [{ number: '2', label: 'Ustadzah' }, { number: '25', label: 'Santriwati' }] },
    { title: 'Bimbel Proton', badge: 'Bimbingan Belajar', variant: 'default', description: 'Program bimbingan belajar untuk anak-anak binaan yayasan. Membantu meningkatkan prestasi akademik dan pemahaman agama secara terpadu.' },
  ],
  keagamaan: [
    { title: 'Wakaf Lahan Tahfidz', variant: 'default', description: 'Penggalangan wakaf jariyah untuk pengadaan lahan 2.000 m² guna pembangunan Pesantren Tahfidz dan Madrasah.' },
    { title: 'Qurban', variant: 'default', description: 'Penerimaan dan penyaluran daging qurban kepada yatim, dhuafa, dan masyarakat yang membutuhkan di Bantul dan sekitarnya.' },
    { title: 'Zakat, Infaq & Shadaqah', badge: 'LAZIS ASIB', variant: 'default', description: 'Dikelola oleh LAZIS ASIB (Lembaga Amil Zakat Infaq Shadaqah), menerima dan menyalurkan ZIS kepada mustahiq yang berhak. Termasuk zakat fitrah pada bulan Ramadhan.' },
    { title: 'Kafarat', variant: 'default', description: 'Layanan pembayaran kafarat sesuai syariat Islam bagi masyarakat yang membutuhkan.' },
    { title: 'Hari Besar Islam', variant: 'default', description: 'Maulid Bersedekah, Nuzulul Qur\'an, Syawalan, Bazar & Buka Puasa Bersama, serta berbagai peringatan hari besar Islam.' },
    { title: 'Pesantren Ramadhan', variant: 'default', description: 'Program intensif bulan Ramadhan meliputi pengajian, buka puasa bersama, sholat berjamaah, tahfidz, dan wisuda Juz 30.' },
  ],
  sosial: [
    { title: 'Santunan Sembako Bulanan', badge: 'Penerima Binaan', variant: 'overflow', description: 'Santunan untuk anak yatim, fakir miskin, dan dhuafa dalam bentuk sembako yang disalurkan <strong>setiap bulan</strong>. Program ini telah meringankan beban ekonomi masyarakat, terutama yang terdampak Covid-19.', stats: [{ number: '110', label: 'Penerima Binaan Tetap' }] },
    { title: 'Jumat Bersedekah', badge: 'Setiap Hari Jumat', variant: 'overflow', description: 'Pembagian <strong>nasi kotak</strong> kepada dhuafa — tukang becak, pemulung, pengemis, dan kaum yang membutuhkan di sepanjang jalan wilayah Yogyakarta.' },
    { title: 'Sedekah Barang Bekas', badge: 'Program Barkas', variant: 'overflow', description: 'Menerima sedekah berupa <strong>barang bekas layak jual</strong>. Kami siap menjemput donasi atau Anda bisa menyetorkan langsung ke kantor. Hasil penjualan untuk membiayai kegiatan yayasan.' },
    { title: 'Panti Asuhan', badge: 'Yatim & Dhuafa', variant: 'overflow', description: 'Panti asuhan bagi <strong>anak yatim dan dhuafa</strong> yang dikelola secara profesional. Program pembinaan meliputi pendidikan formal, tahfidz, dan life skills untuk mempersiapkan masa depan mereka.' },
    { title: 'Relawan AMMA', badge: 'Terbuka untuk Umum', variant: 'overflow', description: 'Jaringan relawan yang siap bergerak dalam setiap kegiatan sosial dan kemanusiaan yayasan. Terbuka bagi masyarakat umum yang ingin berkontribusi langsung dalam aksi-aksi kebaikan.' },
  ],
};

let programsByCategory: Record<string, Item[]> = {};

try {
  const sanityData: SanityProgram[] = await getProgramList();
  if (sanityData && sanityData.length > 0) {
    programsByCategory = sanityData.reduce<Record<string, Item[]>>((acc, p) => {
      const cat = p.category;
      if (!acc[cat]) acc[cat] = [];
      acc[cat].push({
        title: p.title,
        badge: p.badge,
        description: p.shortDesc ?? '',
        variant: (p.cardVariant as 'default' | 'overflow') || 'default',
        stats: p.stats?.map((s: { number: string; label: string }) => ({ number: s.number, label: s.label })),
      });
      return acc;
    }, {});
  }
} catch {
  // Sanity unavailable
}

if (Object.keys(programsByCategory).length === 0) {
  programsByCategory = FALLBACK;
}

type SectionConfig = {
  id: string;
  icon: 'book' | 'home' | 'heart';
  title: string;
  subtitle: string;
  gridCols: string;
};

const sections: SectionConfig[] = [
  { id: 'pendidikan', icon: 'book', title: 'Bidang Pendidikan', subtitle: 'Membangun generasi Qur\'ani sejak usia dini', gridCols: 'sm:grid-cols-2 lg:grid-cols-4' },
  { id: 'keagamaan', icon: 'home', title: 'Bidang Keagamaan', subtitle: 'Memperkuat iman dan ibadah umat', gridCols: 'sm:grid-cols-2 lg:grid-cols-3' },
  { id: 'sosial', icon: 'heart', title: 'Bidang Sosial Kemanusiaan', subtitle: 'Meringankan beban saudara-saudara kita', gridCols: 'sm:grid-cols-2 lg:grid-cols-3' },
];

const tabLabels: Record<string, string> = {
  pendidikan: 'Pendidikan',
  keagamaan: 'Keagamaan',
  sosial: 'Sosial',
};
---

<BaseLayout
	title="Program"
	description="Program Yayasan Amal Shalih Insan Bantul — Pendidikan Islam, Keagamaan, dan Sosial Kemanusiaan. PKBM, PAUD, Tahfidz, Wakaf, Santunan, dan banyak lagi."
	currentPage="/program"
>
	<PageHeader
		label="Program"
		title="Program &amp; Kegiatan"
		description="Tiga pilar pengabdian kami: Pendidikan Islam, Keagamaan, dan Sosial Kemanusiaan."
		gradient="tr"
	/>

	<Container class="py-8 sm:py-16">
		<!-- Tab List -->
		<div role="tablist" aria-label="Pilar program" data-program-tabs class="flex gap-2 overflow-x-auto scrollbar-hide rounded-lg sm:rounded-xl bg-warm-100 p-1.5">
			{sections.map((section, i) => (
				<button
					role="tab"
					id={`tab-${section.id}`}
					aria-selected={i === 0 ? 'true' : 'false'}
					aria-controls={`panel-${section.id}`}
					tabindex={i === 0 ? 0 : -1}
					data-tab={section.id}
					class:list={[
						'flex items-center gap-2 whitespace-nowrap rounded-lg px-4 py-2.5 text-sm font-semibold transition-colors duration-200 focus:outline-none focus-visible:ring-2 focus-visible:ring-primary-500 focus-visible:ring-offset-2',
						i === 0
							? 'bg-primary-700 text-white shadow-sm'
							: 'text-warm-700 hover:bg-white hover:text-primary-700',
					]}
				>
					<Icon name={section.icon} size={5} aria-hidden="true" />
					{tabLabels[section.id]}
				</button>
			))}
		</div>

		<!-- Tab Panels -->
		{sections.map((section, i) => {
			const items = programsByCategory[section.id] ?? [];
			return (
				<div
					role="tabpanel"
					id={`panel-${section.id}`}
					aria-labelledby={`tab-${section.id}`}
					data-panel={section.id}
					class:list={['mt-6', i !== 0 && 'hidden']}
				>
					<div class="mb-6 flex items-center gap-3">
						<div class="icon-box">
							<Icon name={section.icon} size={7} aria-hidden="true" />
						</div>
						<div>
							<h2 class="text-xl sm:text-2xl font-bold text-warm-900 sm:text-3xl">{section.title}</h2>
							<p class="mt-1 text-sm sm:text-base text-warm-700">{section.subtitle}</p>
						</div>
					</div>

					<div class:list={['grid gap-4 sm:gap-6 items-start', section.gridCols]}>
						{items.map((item) => (
							item.variant === 'overflow' ? (
								<Card variant="overflow">
									<div class="rounded-t-xl sm:rounded-t-2xl bg-primary-700 p-3 sm:p-4 text-white">
										<h3 class="text-base sm:text-lg font-bold text-white">{item.title}</h3>
									</div>
									<div class="p-4 sm:p-6">
										{item.badge && <span class="inline-block rounded-full bg-primary-50 px-3 py-1 text-xs font-medium text-primary-700">{item.badge}</span>}
										{item.stats && item.stats.length > 0 && item.stats.map(s => (
											<div class="mt-3 rounded-lg sm:rounded-xl bg-warm-50 p-3 sm:p-4 text-center">
												<p class="text-3xl sm:text-4xl font-extrabold text-primary-700 tabular-nums">{s.number}</p>
												<p class="mt-1 text-sm font-medium text-warm-700">{s.label}</p>
											</div>
										))}
										<p class="mt-4 text-sm leading-relaxed text-warm-700" set:html={item.description} />
									</div>
								</Card>
							) : (
								<Card variant="default">
									<h3 class:list={['font-bold', section.id === 'keagamaan' ? 'text-warm-900' : 'text-lg sm:text-xl text-primary-700']}>{item.title}</h3>
									{item.badge && <span class="mt-2 inline-block rounded-full bg-primary-50 px-3 py-1 text-xs font-medium text-primary-700">{item.badge}</span>}
									<p class="mt-3 text-sm leading-relaxed text-warm-700" set:html={item.description} />
									{item.stats && item.stats.length > 0 && (
										<div class="mt-4 grid grid-cols-2 gap-3 text-sm">
											{item.stats.map(s => (
												<div class="rounded-lg bg-warm-50 p-3 text-center">
													<p class="font-bold text-primary-700 tabular-nums">{s.number}</p>
													<p class="text-xs text-warm-700">{s.label}</p>
												</div>
											))}
										</div>
									)}
								</Card>
							)
						))}
					</div>
				</div>
			);
		})}
	</Container>

	<section class="bg-primary-800 text-white">
		<Container as="div" class="py-8 sm:py-16 text-center">
			<h2 class="text-2xl sm:text-3xl font-bold text-white sm:text-4xl">Dukung Program Kami</h2>
			<p class="mx-auto mt-3 max-w-2xl text-base sm:text-lg text-primary-200">
				Setiap donasi Anda, sekecil apapun, berarti besar bagi mereka yang membutuhkan.
			</p>
			<div class="mt-6 flex flex-wrap justify-center gap-3 sm:gap-4">
				<Button variant="gold" size="lg" href="/donasi">Donasi Sekarang</Button>
				<Button variant="outline-light" size="lg" href="/tentang">Tentang Kami</Button>
			</div>
		</Container>
	</section>

</BaseLayout>

<!-- Tab switching + keyboard navigation + URL hash -->
<script is:inline>
(() => {
	const tablist = document.querySelector('[data-program-tabs]');
	if (!tablist) return;

	const tabs = Array.from(tablist.querySelectorAll('[role="tab"]'));
	const panels = Array.from(document.querySelectorAll('[data-panel]'));
	const sectionIds = tabs.map(t => t.getAttribute('data-tab'));

	function activateTab(targetId) {
		const idx = sectionIds.indexOf(targetId);
		if (idx === -1) return;

		tabs.forEach((tab, i) => {
			const isActive = i === idx;
			tab.setAttribute('aria-selected', String(isActive));
			tab.setAttribute('tabindex', isActive ? '0' : '-1');
			tab.classList.toggle('bg-primary-700', isActive);
			tab.classList.toggle('text-white', isActive);
			tab.classList.toggle('shadow-sm', isActive);
			tab.classList.toggle('text-warm-700', !isActive);
			tab.classList.toggle('hover:bg-white', !isActive);
			tab.classList.toggle('hover:text-primary-700', !isActive);
		});

		panels.forEach((panel, i) => {
			panel.classList.toggle('hidden', i !== idx);
		});

		// Update URL hash without scroll jump
		history.replaceState(null, '', `#${targetId}`);
	}

	// Click handler
	tabs.forEach((tab) => {
		tab.addEventListener('click', () => {
			activateTab(tab.getAttribute('data-tab') || '');
		});
	});

	// Keyboard navigation (ArrowLeft/ArrowRight/Home/End)
	tablist.addEventListener('keydown', (e) => {
		const currentIdx = tabs.findIndex(t => t.getAttribute('aria-selected') === 'true');
		let newIdx = currentIdx;

		if (e.key === 'ArrowRight') newIdx = (currentIdx + 1) % tabs.length;
		else if (e.key === 'ArrowLeft') newIdx = (currentIdx - 1 + tabs.length) % tabs.length;
		else if (e.key === 'Home') newIdx = 0;
		else if (e.key === 'End') newIdx = tabs.length - 1;
		else return;

		e.preventDefault();
		tabs[newIdx].focus();
		activateTab(sectionIds[newIdx]);
	});

	// Initialize from URL hash
	const hash = window.location.hash.slice(1);
	if (hash && sectionIds.includes(hash)) {
		activateTab(hash);
	}
})();
</script>
