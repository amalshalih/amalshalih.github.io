---
import { Card, Container } from '@components/ui/'
import barkasData from '@data/barkas-products.json'
import BaseLayout from '@layouts/BaseLayout.astro'

const { programInfo } = barkasData
const wa = programInfo.contact.whatsapp.replace(/-/g, '')
---

<BaseLayout title="Donasi Barang - BARKAS" description={programInfo.description} currentPage="/barkas">
	<main>
		<!-- ==================== HERO ==================== -->
		<section
			class="relative -mt-[70px] sm:-mt-[82px] min-h-[300px] sm:min-h-[320px] lg:min-h-[360px] flex items-center overflow-hidden text-white"
			style="background-image: url('https://images.unsplash.com/photo-1488521787991-ed7bbaae773c?w=1400&q=75'); background-size: cover; background-position: center 30%;"
		>
			<div class="absolute inset-0 bg-gradient-to-br from-[rgba(140,60,20,0.82)] via-[rgba(0,50,15,0.78)] to-[rgba(0,20,5,0.6)] pointer-events-none" />
			<Container class="relative z-1 pt-[90px] sm:pt-[110px] pb-6 sm:pb-10 lg:pb-12">
				<div class="grid grid-cols-1 lg:grid-cols-[1.2fr_0.8fr] gap-10 items-center relative z-1">
					<div class="text-center lg:text-left animate-fade-in">
						<Heading level="h1" size="4xl" class="text-white mb-2.5">Donasi Barang untuk BARKAS</Heading>
						<p class="text-2xl mb-5 opacity-95 text-white">Barang bekas Anda bisa menjadi berkah bagi sesama</p>
						<p class="text-lg max-w-[600px] mx-auto lg:mx-0 mb-[30px] text-white/90">Setiap donasi barang yang Anda berikan akan disalurkan atau dijual untuk mendukung program sosial, pendidikan, dan dakwah Yayasan ASIB.</p>
						<div class="flex gap-[15px] justify-center lg:justify-start flex-wrap animate-fade-in-up delay-2">
							<Button variant="outline-light" class="bg-white/90 text-primary-700 hover:bg-white" href={`https://wa.me/${wa}`} target="_blank" rel="noopener noreferrer">📱 Hubungi WhatsApp</Button>
							<Button variant="outline-light" href="/barkas">← Kembali ke Katalog</Button>
						</div>
					</div>
					<div class="flex justify-center items-center animate-fade-in delay-1">
						<div class="w-[180px] h-[180px] rounded-full bg-white/12 backdrop-blur-md border-2 border-white/25 flex items-center justify-center transition-transform duration-[0.6s] hover:scale-105">
							<span class="text-[4.5rem]">🎁</span>
						</div>
					</div>
				</div>
			</Container>
		</section>

		<!-- ==================== CARA DONASI ==================== -->
		<section class="py-[60px] sm:py-16 bg-surface animate-fade-in-up">
			<Container>
				<Heading level="h2" size="3xl" class="mb-2.5">Cara Donasi Barang Bekas</Heading>
				<p class="text-text-secondary text-center mb-10 text-lg">Ikuti langkah mudah berikut untuk mendonasikan barang bekas Anda</p>
				<div class="grid gap-5 grid-cols-1 sm:grid-cols-2 lg:grid-cols-3">
					{programInfo.howToDonate.steps.map((step, index) => (
						<Card variant="hover" padding="md">
							<span class="bg-accent-primary text-white w-10 h-10 rounded-full flex items-center justify-center font-bold flex-shrink-0">{index + 1}</span>
							<p class="text-text-primary m-0 pt-2">{step}</p>
						</div>
					))}
				</div>
			</Container>
		</section>

		<!-- ==================== BARANG DITERIMA ==================== -->
		<section class="py-[60px] sm:py-16 bg-surface-secondary animate-fade-in-up">
			<Container>
				<Heading level="h2" size="3xl" class="mb-2.5">Barang yang Diterima</Heading>
				<p class="text-text-secondary text-center mb-10 text-lg">Kami menerima berbagai jenis barang bekas yang masih layak pakai</p>
				<div class="flex flex-wrap gap-3 justify-center">
					{programInfo.howToDonate.acceptedItems.map(item => (
						<span class="bg-surface-elevated px-5 py-2.5 rounded-full border border-border-primary text-text-primary font-medium transition-all duration-300 hover:-translate-y-0.5 hover:scale-105 hover:shadow-md hover:border-accent-primary">{item}</span>
					))}
				</div>
			</Container>
		</section>

		<!-- ==================== KONTAK ==================== -->
		<section class="py-[60px] sm:py-16 bg-surface animate-fade-in-up">
			<Container>
				<Card variant="default" class="max-w-[650px] mx-auto text-center p-10">
					<Heading level="h2" size="3xl" class="mb-2.5">Hubungi Kami</Heading>
					<p class="text-text-secondary mb-[30px]">Siap mendonasikan barang? Hubungi kami melalui:</p>
					<div class="flex flex-col gap-5 mb-[30px] text-left">
						<div class="flex gap-[15px] items-center">
							<span class="text-2xl">📱</span>
							<div>
								<strong class="block text-text-primary text-sm">WhatsApp</strong>
								<a href={`https://wa.me/${wa}`} class="text-text-secondary hover:text-accent-primary transition-colors">{programInfo.contact.whatsapp}</a>
							</div>
						</div>
						<div class="flex gap-[15px] items-center">
							<span class="text-2xl">📧</span>
							<div>
								<strong class="block text-text-primary text-sm">Email</strong>
								<a href={`mailto:${programInfo.contact.email}`} class="text-text-secondary hover:text-accent-primary transition-colors">{programInfo.contact.email}</a>
							</div>
						</div>
						<div class="flex gap-[15px] items-center">
							<span class="text-2xl">📍</span>
							<div>
								<strong class="block text-text-primary text-sm">Alamat</strong>
								<span class="text-text-secondary">{programInfo.contact.address}</span>
							</div>
						</div>
					</div>
					<Button variant="primary" size="lg" href={`https://wa.me/${wa}`} target="_blank" rel="noopener noreferrer">📱 Hubungi via WhatsApp</Button>
				</div>
			</Container>
		</section>

		<!-- ==================== CTA ==================== -->
		<section class="py-[60px] sm:py-16 bg-surface-secondary animate-fade-in-up">
			<Container>
				<div class="text-center max-w-[600px] mx-auto py-10">
					<Heading level="h2" size="3xl" class="mb-[15px]">Ingin Tahu Dampak Donasi Anda?</Heading>
					<p class="text-text-secondary text-lg mb-[30px]">Setiap barang yang Anda donasikan memberikan manfaat nyata bagi masyarakat.</p>
					<div class="flex gap-[15px] justify-center flex-wrap">
						<Button variant="primary" size="lg" href="/barkas/dampak">Lihat Dampak</Button>
						<Button variant="outline" size="lg" href="/barkas">← Kembali ke Katalog</Button>
					</div>
				</div>
			</Container>
		</section>
	</main>
</BaseLayout>
