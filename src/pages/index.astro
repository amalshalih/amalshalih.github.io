---
import Dampak from '@components/sections/Dampak.astro'
import Hero from '@components/sections/Hero.astro'
import Partners from '@components/sections/Partners.astro'
import Stats from '@components/sections/Stats.astro'
import Wakaf from '@components/sections/Wakaf.astro'
import Card from '@components/ui/Card.astro'
import Container from '@components/ui/Container.astro'
import Heading from '@components/ui/Heading.astro'
import { fetchHeroPhotos } from '@data/hero-photos'
import { STATS } from '@data/site'
import BaseLayout from '@layouts/BaseLayout.astro'
import { getSiteSettings } from '@lib/sanity/client'
import { withFallback } from '@lib/with-fallback'

type StatItem = { number: string; label: string }

let stats: StatItem[] = STATS
let heroTagline = 'Yayasan Amal Shalih Insan Bantul'
let heroTitle = 'Menjadi Lembaga Profesional & Berkarakter,'
let heroHighlight = 'Maslahat Bagi Umat'
let heroDescription =
	'Berdiri sejak 2020, kami berkomitmen membuka akses pendidikan Islam berkualitas, memberdayakan ekonomi umat, dan menyalurkan bantuan sosial kemanusiaan bagi masyarakat Bantul dan sekitarnya.'
let heroCtaText = 'Donasi Sekarang'
let heroCtaLink = '/donasi'

const sanitySettings = await withFallback(() => getSiteSettings(), null, 'Site settings fetch')

if (sanitySettings) {
	if (sanitySettings.stats && sanitySettings.stats.length > 0) {
		stats = sanitySettings.stats
	}
	if (sanitySettings.tagline) heroTagline = sanitySettings.tagline
	if (sanitySettings.heroTitle) {
		const parts = sanitySettings.heroTitle.split(',')
		heroTitle = parts[0] || heroTitle
		heroHighlight = parts[1]?.trim() || heroHighlight
	}
	if (sanitySettings.heroDescription) heroDescription = sanitySettings.heroDescription
	if (sanitySettings.heroCtaText) heroCtaText = sanitySettings.heroCtaText
	if (sanitySettings.heroCtaLink) heroCtaLink = sanitySettings.heroCtaLink
}

// Hero slideshow photos from Google Drive
const heroPhotos = await fetchHeroPhotos()
const safeHeroPhotos = heroPhotos || []
---

<BaseLayout
	title="Beranda"
	description="Yayasan Amal Shalih Insan Bantul (ASIB) — Lembaga profesional berkarakter, maslahat bagi umat. Bergerak di bidang pendidikan Islam, sosial kemanusiaan, dan keagamaan."
	currentPage="/"
>
	<Hero
		tagline={heroTagline}
		title={heroTitle}
		highlight={heroHighlight}
		description={heroDescription}
		ctaText={heroCtaText}
		ctaLink={heroCtaLink}
		photos={safeHeroPhotos}
	/>

	<Stats stats={stats} />

	<Dampak
		title="Dampak Nyata Kami"
		description="Lebih dari sekadar angka, kami menghadirkan perubahan nyata bagi masyarakat Bantul melalui program pendidikan, sosial, dan keagamaan yang terukur dan berkelanjutan."
	/>

	<style is:global>
		/* Performance hints for animated elements in section components */
		.animate-\[wakaf-float\],
		.animate-\[wakaf-pulse-glow\],
		.animate-\[wakaf-shimmer\],
		.animate-\[frieze-slide\],
		.animate-\[frieze-sheen\],
		.animate-\[bg-breath\] {
			will-change: transform, opacity;
		}
		.animate-\[wakaf-gold-shine\] {
			will-change: background-position;
		}
	</style>

	<Wakaf />

	<!-- Program Overview — replicate tab carousel breakout pattern -->
	<Container class="py-8 sm:py-16 lg:py-20 overflow-x-hidden">
		<div class="mb-8 sm:mb-12 text-center">
			<Heading level="h2" size="2xl" class="text-warm-900 dark:text-warm-50">Program Unggulan</Heading>
			<p class="mt-2 text-warm-700 dark:text-warm-300">Tiga pilar utama pengabdian kami untuk umat</p>
		</div>

		<div class="-mx-4 sm:-mx-6 lg:-mx-8 md:mx-0 flex overflow-x-auto snap-x snap-mandatory gap-4 sm:gap-5 md:grid md:grid-cols-3 md:overflow-visible md:snap-none items-start scrollbar-hide px-4 sm:px-6 lg:px-8 md:px-0 py-3 md:py-0 scroll-pl-6 scroll-pr-6 md:scroll-pl-0 md:scroll-pr-0">
			<!-- Pendidikan -->
			<Card variant="hover" class="animate-fade-in-up delay-1 snap-start shrink-0 w-[85vw] xs:w-[80vw] sm:w-[450px] md:w-auto">
				<div class="mb-2 h-1.5 w-8 rounded-full bg-primary-500" />
				<Heading level="h3" size="lg" class="mb-2 text-warm-900 dark:text-warm-50">Pendidikan Islam</Heading>
				<p class="mb-3 text-sm leading-relaxed text-warm-700 dark:text-warm-300">
					PKBM Bina Insan Mulia, PAUD Bina Tunas Mulia, dan Rumah Tahfidz — membina generasi Qur'ani sejak usia dini.
				</p>
				<a href="/program#pendidikan" class="group inline-flex items-center gap-1 text-sm font-semibold text-primary-700 dark:text-primary-400 hover:text-primary-800 dark:hover:text-primary-300 transition-colors">
					Selengkapnya <span class="transition-transform duration-200 group-hover:translate-x-1">→</span>
				</a>
			</Card>

			<!-- Keagamaan -->
			<Card variant="hover" class="animate-fade-in-up delay-2 snap-start shrink-0 w-[85vw] xs:w-[80vw] sm:w-[450px] md:w-auto">
				<div class="mb-2 h-1.5 w-8 rounded-full bg-gold-500" />
				<Heading level="h3" size="lg" class="mb-2 text-warm-900 dark:text-warm-50">Keagamaan</Heading>
				<p class="mb-3 text-sm leading-relaxed text-warm-700 dark:text-warm-300">
					Wakaf lahan Tahfidz 2000m², qurban, zakat fitrah, kafarat, dan peringatan hari besar Islam.
				</p>
				<a href="/program#keagamaan" class="group inline-flex items-center gap-1 text-sm font-semibold text-primary-700 dark:text-primary-400 hover:text-primary-800 dark:hover:text-primary-300 transition-colors">
					Selengkapnya <span class="transition-transform duration-200 group-hover:translate-x-1">→</span>
				</a>
			</Card>

			<!-- Sosial -->
			<Card variant="hover" class="animate-fade-in-up delay-3 snap-start shrink-0 w-[85vw] xs:w-[80vw] sm:w-[450px] md:w-auto">
				<div class="mb-2 h-1.5 w-8 rounded-full bg-primary-400" />
				<Heading level="h3" size="lg" class="mb-2 text-warm-900 dark:text-warm-50">Sosial Kemanusiaan</Heading>
				<p class="mb-3 text-sm leading-relaxed text-warm-700 dark:text-warm-300">
					Santunan sembako bulanan untuk 110 penerima, Jumat Bersedekah, dan program Sedekah Barang Bekas (Barkas).
				</p>
				<a href="/program#sosial" class="group inline-flex items-center gap-1 text-sm font-semibold text-primary-700 dark:text-primary-400 hover:text-primary-800 dark:hover:text-primary-300 transition-colors">
					Selengkapnya <span class="transition-transform duration-200 group-hover:translate-x-1">→</span>
				</a>
			</Card>
		</div>
	</Container>

	<Partners />
</BaseLayout>
