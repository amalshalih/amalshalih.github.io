---
import { env } from 'cloudflare:workers'
import ErrorState from '@components/ErrorState.astro'
import PageHeader from '@components/sections/PageHeader.astro'
import Badge from '@components/ui/Badge.astro'
import Container from '@components/ui/Container.astro'
import EmptyState from '@components/ui/EmptyState.astro'
import Heading from '@components/ui/Heading.astro'
import Icon from '@components/ui/Icon.astro'
import Image from '@components/ui/Image.astro'
import type { GalleryEntry } from '@data/galleries'
import { fetchAllGalleries, filterPublishedGalleries } from '@data/galleries'
import BaseLayout from '@layouts/BaseLayout.astro'
import { KATEGORI_LABELS } from '@lib/constants'
import { getSiteSettings } from '@lib/sanity/client'
import { withNull } from '@lib/with-fallback'

// SSR - Real-time data fetching (Cloudflare Workers compatible)
export const prerender = false

// Direct function call for Cloudflare Workers SSR compatibility
const allGalleries = await withNull(() => fetchAllGalleries(), 'Gallery list fetch')
let galleries: GalleryEntry[] | null = allGalleries ? filterPublishedGalleries(allGalleries) : null

// Server-side like pre-fetching to avoid client-side N+1 fetch
if (galleries) {
	try {
		const likes = env.LIKES
		if (likes) {
			const prefix = 'photo:'
			const listed = await likes.list({ prefix })
			const likesMap: Record<string, number> = {}

			await Promise.all(
				listed.keys.map(async (key: { name: string }) => {
					const count = await likes.get(key.name)
					likesMap[key.name] = parseInt(count || '0', 10)
				}),
			)

			for (const gallery of galleries) {
				if (gallery.images && gallery.images.length > 0) {
					let maxLikes = 0
					let bestImage = gallery.images[0]
					for (const img of gallery.images) {
						const likeKey = `photo:${gallery.slug}:${img.id}`
						const count = likesMap[likeKey] || 0
						if (count > maxLikes) {
							maxLikes = count
							bestImage = img
						}
					}
					if (maxLikes > 0) {
						// Swap the most liked image to the front so it is selected as the cover photo
						const index = gallery.images.findIndex((img) => img.id === bestImage.id)
						if (index > -1) {
							gallery.images.splice(index, 1)
							gallery.images.unshift(bestImage)
						}
					}
				}
			}
		}
	} catch (e) {
		console.error('[Galeri] Failed to prefetch likes for covers:', e)
	}
}

const DEFAULT_GRADIENTS: Record<string, string> = {
	pendidikan: 'from-primary-400 to-primary-600',
	keagamaan: 'from-gold-400 to-gold-600',
	sosial: 'from-primary-500 to-gold-500',
	umum: 'from-warm-400 to-warm-600',
}

const DEFAULT_ICONS: Record<string, string> = {
	pendidikan: 'book',
	keagamaan: 'home',
	sosial: 'heart',
	umum: 'globe',
}

// Hybrid: Try Sanity siteSettings for gallery category config
let kategoriGradients: Record<string, string> = DEFAULT_GRADIENTS
let kategoriIcons: Record<string, string> = DEFAULT_ICONS
let kategoriLabels: Record<string, string> = {}

const ss = await withNull(() => getSiteSettings(), 'Galeri site settings fetch')
if (ss?.galleryCategoryGradients && ss.galleryCategoryGradients.length > 0) {
	const merged = { ...DEFAULT_GRADIENTS }
	for (const item of ss.galleryCategoryGradients) {
		if (item.category && item.gradient) merged[item.category] = item.gradient
	}
	kategoriGradients = merged
}
if (ss?.galleryCategoryIcons && ss.galleryCategoryIcons.length > 0) {
	const merged = { ...DEFAULT_ICONS }
	for (const item of ss.galleryCategoryIcons) {
		if (item.category && item.icon) merged[item.category] = item.icon
	}
	kategoriIcons = merged
}
if (ss?.kategoriLabels) {
	kategoriLabels = { ...KATEGORI_LABELS, ...ss.kategoriLabels }
}
---

<BaseLayout
	title="Galeri Dokumentasi"
	description="Dokumentasi foto kegiatan Yayasan Amal Shalih Insan Bantul — pendidikan, keagamaan, sosial kemanusiaan, dan berbagai program yayasan."
	currentPage="/galeri"
>
	<PageHeader
		label="Galeri"
		title="Dokumentasi Kegiatan"
		description="Foto dan dokumentasi kegiatan Yayasan ASIB dalam setiap program dan aktivitas."
		gradient="r"
	/>

	<Container class="pt-4 sm:pt-6 pb-8 sm:pb-16">
		<div class="flex flex-wrap gap-2 justify-center mb-6 sm:mb-8" data-filter-gallery>
			<button class="filter-btn rounded-full bg-primary-700 px-4 py-2 text-xs sm:text-sm sm:px-5 sm:py-2.5 font-semibold text-white shadow-sm sm:shadow-md transition-colors duration-300 focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-primary-500 focus-visible:ring-offset-2 dark:focus-visible:ring-offset-surface-inverse" data-filter="all">Semua</button>
			{Object.entries({ ...KATEGORI_LABELS, ...kategoriLabels }).map(([key, label]) => (
				<button class="filter-btn rounded-full bg-primary-50 dark:bg-primary-950 px-4 py-2 text-xs sm:text-sm sm:px-5 sm:py-2.5 font-semibold text-primary-700 dark:text-primary-300 transition-colors duration-300 hover:bg-primary-100 dark:hover:bg-primary-900 focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-primary-500 focus-visible:ring-offset-2 dark:focus-visible:ring-offset-surface-inverse" data-filter={key}>{label}</button>
			))}
		</div>

		<div class="grid gap-5 sm:gap-6 lg:gap-8 grid-cols-1 sm:grid-cols-2 lg:grid-cols-3" id="gallery-grid">
			{galleries?.map((gallery) => {
				const coverPhoto = gallery.images && gallery.images.length > 0
					? gallery.images[0]
					: null;
				const coverThumbUrl = coverPhoto
					? coverPhoto.thumbnailUrl.replace('size=400', 'size=320')
					: null;

				return (
				<div class="gallery-item transition-all duration-500 ease-out" data-kategori={gallery.category}>
					<a href={`/galeri/${gallery.slug}`} class="group block rounded-xl sm:rounded-2xl bg-surface-elevated dark:bg-warm-900 shadow-sm dark:shadow-surface-inverse/20 transition-all duration-300 ease-out border border-border-secondary/60 dark:border-white/5 hover:-translate-y-1.5 hover:shadow-lg hover:shadow-primary-500/5 dark:hover:shadow-primary-500/5 hover:border-primary-500/30 dark:hover:border-primary-400/20 overflow-hidden">
						<div class={`relative aspect-[4/3] w-full overflow-hidden ${coverThumbUrl ? '' : `bg-gradient-to-br ${kategoriGradients[gallery.category] || 'from-primary-400 to-primary-600'}`}`}>
							{coverThumbUrl ? (
								<Image
									src={coverThumbUrl}
									alt={gallery.title}
									aspect="aspect-[4/3]"
									class="h-full w-full object-cover transition-all duration-700 ease-out group-hover:scale-105"
									data-cover-image={gallery.slug}
									loading="lazy"
									decoding="async"
								/>
							) : (
								<div class="absolute inset-0 flex items-center justify-center">
									<Icon name={(kategoriIcons[gallery.category] ?? 'book') as 'book' | 'home' | 'heart' | 'globe'} size={16} class="text-white/70" aria-hidden="true" />
								</div>
							)}
							
							<!-- Gradient Overlay -->
							<div class="absolute inset-0 bg-gradient-to-t from-black/75 via-black/30 to-transparent opacity-80 transition-opacity duration-500" />

							<!-- Top: Category & Photo Count -->
							<div class="absolute top-4 left-4 right-4 flex items-start justify-between gap-2">
								<Badge variant="subtle" size="sm" class="backdrop-blur-sm gap-1.5 uppercase tracking-wide">
									<Icon name={(kategoriIcons[gallery.category] ?? 'book') as 'book' | 'home' | 'heart' | 'globe'} size={3.5} aria-hidden="true" />
									{kategoriLabels[gallery.category] || KATEGORI_LABELS[gallery.category] || gallery.category}
								</Badge>
								<Badge variant="outline" size="sm" class="backdrop-blur-sm text-white">
									<Icon name="image" size={3} aria-hidden="true" />
									{gallery.totalImages} foto
								</Badge>
							</div>

							<!-- Bottom: Date -->
							<div class="absolute bottom-4 left-4 right-4">
								<div class="flex items-center gap-2 text-white/90 dark:text-white/70 text-xs font-medium">
									<Icon name="calendar" size={3.5} aria-hidden="true" />
									<time datetime={gallery.eventDate}>
										{new Date(gallery.eventDate).toLocaleDateString('id-ID', {
											day: 'numeric',
											month: 'long',
											year: 'numeric',
										})}
									</time>
								</div>
							</div>

							<!-- Hover: View Button -->
							<div class="absolute inset-0 flex items-center justify-center opacity-0 group-hover:opacity-100 transition-all duration-300">
								<span class="translate-y-2 group-hover:translate-y-0 transition-transform duration-300 inline-flex items-center gap-2 rounded-full bg-white dark:bg-primary-800 px-5 py-2.5 text-sm font-semibold text-primary-700 dark:text-primary-100 shadow-lg">
									Lihat Galeri
									<Icon name="arrow-right" size={4} aria-hidden="true" />
								</span>
							</div>
						</div>

						<!-- Content Section -->
						<div class="p-5 sm:p-6 bg-white dark:bg-warm-900">
							<Heading level="h2" size="lg" class="text-warm-900 dark:text-warm-100 leading-tight line-clamp-2 group-hover:text-primary-700 dark:group-hover:text-primary-400 transition-colors duration-300">
								{gallery.title}
							</Heading>
							<p class="mt-2 text-sm text-warm-600 dark:text-warm-300 leading-relaxed line-clamp-2">
								{gallery.description}
							</p>
							
							<!-- Action Link -->
							<div class="mt-4 flex items-center gap-2 text-sm font-semibold text-primary-700 dark:text-primary-400 group-hover:text-primary-800 dark:group-hover:text-primary-300 transition-colors">
								<span>Lihat detail</span>
								<Icon name="arrow-right" size={4} class="transition-transform group-hover:translate-x-1" aria-hidden="true" />
							</div>
						</div>
					</a>
				</div>
			);
		})}
		</div>

		{galleries === null ? (
			<ErrorState
				title="Gagal Memuat Data"
				message="Galeri tidak dapat dimuat. Silakan coba lagi nanti."
			/>
		) : galleries.length === 0 ? (
			<EmptyState
				icon="image"
				title="Belum Ada Galeri"
				description="Galeri dokumentasi akan diperbarui secara berkala oleh tim yayasan."
			/>
		) : null}
		
		<!-- No Results Message (shown when filter has no matches) -->
		<div class="filter-no-results hidden">
			<EmptyState
				icon="image"
				title="Tidak Ada Galeri Ditemukan"
				description="Belum ada galeri untuk kategori ini. Silakan pilih kategori lain atau lihat semua galeri."
				action={{ label: "Lihat Semua Galeri", datasetFilter: "all" }}
			/>
		</div>
	</Container>
</BaseLayout>

<script is:inline>
(() => {
	const filterRoot = document.querySelector('[data-filter-gallery]');
	if (!filterRoot) return;

	const items = document.querySelectorAll('.gallery-item');
	const buttons = filterRoot.querySelectorAll('.filter-btn');
	const noResultsMsg = document.querySelector('.filter-no-results');

	buttons.forEach((btn) => {
		btn.addEventListener('click', () => {
			const filter = btn.getAttribute('data-filter');

			buttons.forEach((b) => {
				b.classList.remove('bg-primary-700', 'text-white', 'shadow-md');
				b.classList.add('bg-primary-50', 'text-primary-700', 'hover:bg-primary-100');
			});
			btn.classList.remove('bg-primary-50', 'text-primary-700', 'hover:bg-primary-100');
			btn.classList.add('bg-primary-700', 'text-white', 'shadow-md');

			let visibleCount = 0;

			items.forEach((item) => {
				const category = item.getAttribute('data-kategori');
				const matches = filter === 'all' || category === filter;

				if (matches) {
					visibleCount++;
					item.classList.remove('hidden');
					setTimeout(() => {
						item.classList.remove('opacity-0', 'scale-90');
						item.classList.add('opacity-100', 'scale-100');
					}, 10);
				} else {
					item.classList.add('opacity-0', 'scale-90');
					item.classList.remove('opacity-100', 'scale-100');
					setTimeout(() => {
						if (item.classList.contains('opacity-0')) {
							item.classList.add('hidden');
						}
					}, 300);
				}
			});

			// Show/hide no results message
			if (noResultsMsg) {
				if (visibleCount === 0 && filter !== 'all') {
					noResultsMsg.classList.remove('hidden');
				} else {
					noResultsMsg.classList.add('hidden');
				}
			}
		});
	});
})();
</script>
