---
import FAQ from '@components/sections/FAQ.astro'
import PageHeader from '@components/sections/PageHeader.astro'
import Button from '@components/ui/Button.astro'
import Container from '@components/ui/Container.astro'
import FormField from '@components/ui/FormField.astro'
import Heading from '@components/ui/Heading.astro'
import Icon from '@components/ui/Icon.astro'
import RadioCard from '@components/ui/RadioCard.astro'
import { CONTACT } from '@data/site'
import BaseLayout from '@layouts/BaseLayout.astro'
import { getSiteSettings } from '@lib/sanity/client'
import { withFallback } from '@lib/with-fallback'

// Hybrid: try Sanity first, fall back to local data
let address = { ...CONTACT.address }
let phone = CONTACT.phone
let phoneUrl = CONTACT.phoneUrl
let whatsapp = CONTACT.whatsapp
let email = CONTACT.email
let mapsUrl = CONTACT.address.mapsUrl
let hours = { ...CONTACT.hours }

const sanitySettings = await withFallback(() => getSiteSettings(), null, 'Site settings fetch')
if (sanitySettings) {
	if (sanitySettings.address) address = { ...address, ...sanitySettings.address }
	if (sanitySettings.phone) phone = sanitySettings.phone
	if (sanitySettings.email) email = sanitySettings.email
	if (sanitySettings.emails)
		email = sanitySettings.emails.info || sanitySettings.emails.gmail || email
	if (sanitySettings.mapsUrl) mapsUrl = sanitySettings.mapsUrl
	if (sanitySettings.operatingHoursDetail) {
		hours = { ...hours, ...sanitySettings.operatingHoursDetail }
	}
}
---

<BaseLayout
	title="Kontak"
	description="Hubungi Yayasan Amal Shalih Insan Bantul — alamat, telepon, email, dan formulir kontak untuk pertanyaan, konfirmasi donasi, atau informasi program."
	currentPage="/kontak"
>
	<PageHeader
		label="Kontak"
		title="Hubungi Kami"
		description="Punya pertanyaan, ingin konfirmasi donasi, atau butuh informasi lebih lanjut? Jangan ragu untuk menghubungi kami."
		gradient="bl"
	/>

	<section class="relative bg-warm-50 dark:bg-warm-950 overflow-hidden">
		<!-- Subtle textured background watermark — mobile & tablet only, hidden on desktop -->
		<div
			class="absolute inset-0 bg-[url('/images/charity-contact.webp')] bg-cover bg-center opacity-[0.05] lg:hidden pointer-events-none"
			aria-hidden="true"
		></div>

		<Container class="py-8 sm:py-16 relative z-10">
			<div class="grid gap-6 sm:gap-8 lg:grid-cols-5 lg:gap-10">
			<!-- Contact Form — primary action, first on mobile, right column on desktop (60% / 3 cols) -->
			<div class="lg:order-2 lg:col-span-3">
				<div class="rounded-xl sm:rounded-2xl bg-surface-elevated p-5 sm:p-8 shadow-sm">
					<Heading level="h2" size="lg">Kirim Pesan</Heading>
					<p class="mt-1 text-sm text-text-secondary">
						Isi formulir di bawah ini dan kami akan merespons secepatnya.
					</p>

					<!-- Error Summary -->
					<div id="form-error-summary" class="hidden rounded-lg border border-red-300 bg-red-50 p-4 dark:border-red-800 dark:bg-red-950/50" role="alert" aria-live="polite" aria-atomic="true">
						<h3 class="text-sm font-semibold text-red-800 dark:text-red-200 flex items-center gap-2">
							<svg class="h-5 w-5" fill="currentColor" viewBox="0 0 20 20" aria-hidden="true">
								<path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zM8.707 7.293a1 1 0 00-1.414 1.414L8.586 10l-1.293 1.293a1 1 0 101.414 1.414L10 11.414l1.293 1.293a1 1 0 001.414-1.414L11.414 10l1.293-1.293a1 1 0 00-1.414-1.414L10 8.586 8.707 7.293z" clip-rule="evenodd"/>
							</svg>
							Periksa formulir Anda
						</h3>
						<ul id="error-list" class="mt-2 text-sm text-red-700 dark:text-red-300 list-disc list-inside space-y-1"></ul>
					</div>

					<form
						id="contact-form"
						class="mt-5 space-y-4"
						novalidate
						aria-describedby="form-error-summary"
					>
						<div class="grid gap-4 sm:gap-5 md:grid-cols-2">
							<FormField type="text" id="nama" name="nama" label="Nama Lengkap" required autocomplete="name" placeholder="Nama Anda…" />
							<FormField type="tel" id="telepon" name="telepon" label="Nomor Telepon" autocomplete="tel" placeholder="0812-3456-7890…" pattern="[0-9\-+() ]+" />
						</div>

						<FormField type="email" id="email" name="email" label="Email" required autocomplete="email" placeholder="nama@email.com…" />

						<div>
							<label class="block text-sm font-medium text-text-secondary mb-1">Pilih Topik Pesan</label>
							<p class="text-sm text-text-muted mb-3">Pilih topik yang sesuai dengan keperluan Anda.</p>

							<div role="radiogroup" aria-label="Pilih topik pesan" class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-3" id="subjek-group">
								<RadioCard value="donasi" icon="heart" label="Konfirmasi Donasi" description="Laporan &amp; konfirmasi transfer donasi" describedBy="desc-donasi" />
								<RadioCard value="program" icon="book" label="Informasi Program" description="Tanya tentang program &amp; kegiatan" describedBy="desc-program" />
								<RadioCard value="kerjasama" icon="globe" label="Kerja Sama" description="Ajukan kerja sama atau kolaborasi" describedBy="desc-kerjasama" />
								<RadioCard value="pendaftaran" icon="star" label="Pendaftaran Santri" description="Daftarkan anak sebagai santri" describedBy="desc-pendaftaran" />
								<RadioCard value="kritik" icon="email" label="Kritik &amp; Saran" description="Sampaikan kritik, saran, atau masukan" describedBy="desc-kritik" />
								<RadioCard value="lainnya" icon="check-circle" label="Lainnya" description="Pesan atau pertanyaan lainnya" describedBy="desc-lainnya" />
							</div>

							<input type="hidden" id="subjek" name="subjek" value="" />
						</div>

						<FormField type="textarea" id="pesan" name="pesan" label="Pesan" required placeholder="Tulis pesan Anda di sini…" rows={5} />

						<!-- Honeypot — hidden from humans, visible to bots -->
						<div aria-hidden="true" style="position: absolute; left: -9999px;">
							<label for="_website">Website</label>
							<input type="text" id="_website" name="_website" tabindex="-1" autocomplete="off" />
						</div>

						<div id="form-feedback" class="hidden"></div>

						<Button variant="primary" class="w-full" type="submit" id="submit-btn">
							<span id="submit-text">Kirim Pesan</span>
							<svg id="submit-spinner" class="hidden animate-spin h-5 w-5" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" aria-hidden="true">
								<circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle>
								<path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4z"></path>
							</svg>
						</Button>
					</form>
				</div>
			</div>

			<!-- Info Cards — secondary, below form on mobile, left column on desktop (40% / 2 cols) -->
			<div class="lg:order-1 lg:col-span-2 space-y-4 sm:space-y-5 md:grid md:grid-cols-2 md:gap-6 md:space-y-0 lg:block lg:space-y-5">
				<!-- Card 1: Featured Image — Islamic charity visual, top of sidebar in desktop, hidden on mobile & tablet -->
				<div class="hidden lg:block rounded-lg sm:rounded-xl bg-surface-elevated overflow-hidden shadow-sm h-48 sm:h-56 lg:h-64 md:col-span-2 lg:col-span-1 relative">
					<img
						src="/images/charity-contact.webp"
						alt="Tangan memberikan kurma — ilustrasi kebaikan, berbagi, dan kedermawanan dalam Islam"
						class="absolute inset-0 w-full h-full object-cover"
						loading="lazy"
						decoding="async"
						width="640"
						height="360"
					/>
					<div class="absolute inset-0 bg-gradient-to-t from-primary-900/40 to-transparent lg:bg-gradient-to-b lg:from-primary-900/20 lg:to-transparent dark:from-black/60 dark:lg:from-black/40"></div>
				</div>

				<!-- Card 2: Alamat Kantor -->
				<div class="rounded-lg sm:rounded-xl bg-surface-elevated p-5 sm:p-8 shadow-sm">
					<div class="mb-2 icon-box-sm">
						<Icon name="location" size={5} aria-hidden="true" />
					</div>
					<Heading level="h2" size="md">Alamat Kantor</Heading>
					<p class="mt-1.5 text-sm leading-relaxed text-text-secondary">
						{address.street}, {address.village}, {address.district}<br />
						{address.city}, {address.province}<br />
						Kode Pos {address.postalCode}
					</p>
					<a
						href={mapsUrl}
						target="_blank"
						rel="noopener noreferrer"
						class="mt-3 inline-flex items-center gap-1 text-sm font-semibold text-primary-700 dark:text-primary-400 hover:text-primary-800 dark:hover:text-primary-300 transition-colors"
					>
						Lihat di Google Maps
						<Icon name="external-link" size={4} aria-hidden="true" />
					</a>
				</div>

				<!-- Card 3: Telepon & WhatsApp -->
				<div class="rounded-lg sm:rounded-xl bg-surface-elevated p-5 sm:p-8 shadow-sm">
					<div class="mb-2 icon-box-sm">
						<Icon name="phone" size={5} aria-hidden="true" />
					</div>
					<Heading level="h2" size="md">Telepon &amp; WhatsApp</Heading>
					<p class="mt-1.5 text-sm text-text-secondary">
						<a href={phoneUrl} class="text-primary-700 dark:text-primary-400 hover:underline">{phone}</a>
					</p>
					<Button variant="primary" href={whatsapp} class="mt-3 w-full" target="_blank" rel="noopener noreferrer">
						<Icon name="whatsapp" size={4} aria-hidden="true" />
						WhatsApp
					</Button>
				</div>

				<!-- Card 4: Email -->
				<div class="rounded-lg sm:rounded-xl bg-surface-elevated p-5 sm:p-8 shadow-sm">
					<div class="mb-2 icon-box-sm">
						<Icon name="email" size={5} aria-hidden="true" />
					</div>
					<Heading level="h2" size="md">Email</Heading>
					<div class="mt-1.5 space-y-2 text-sm">
						<div>
							<span class="text-xs font-semibold uppercase tracking-wider text-primary-500 dark:text-primary-400">Kontak Umum</span>
							<br />
							<a href={`mailto:${email}`} class="text-primary-700 dark:text-primary-400 break-all hover:underline font-medium">
								{email}
							</a>
						</div>
						<div>
							<span class="text-xs font-semibold uppercase tracking-wider text-primary-500 dark:text-primary-400">Donasi</span>
							<br />
							<a href={`mailto:donasi@amalshalih.or.id`} class="text-primary-700 dark:text-primary-400 break-all hover:underline font-medium">
								donasi@amalshalih.or.id
							</a>
						</div>
						<div>
							<span class="text-xs font-semibold uppercase tracking-wider text-primary-500 dark:text-primary-400">Administrasi</span>
							<br />
							<a href={`mailto:admin@amalshalih.or.id`} class="text-primary-700 dark:text-primary-400 break-all hover:underline font-medium">
								admin@amalshalih.or.id
							</a>
						</div>
						<div>
							<span class="text-xs font-semibold uppercase tracking-wider text-primary-500 dark:text-primary-400">Humas &amp; Media</span>
							<br />
							<a href={`mailto:humas@amalshalih.or.id`} class="text-primary-700 dark:text-primary-400 break-all hover:underline font-medium">
								humas@amalshalih.or.id
							</a>
						</div>
					</div>
				</div>

				<!-- Card 5: Jam Operasional -->
				<div class="rounded-lg sm:rounded-xl bg-surface-elevated p-5 sm:p-8 shadow-sm">
					<div class="mb-2 icon-box-sm">
						<Icon name="clock" size={5} aria-hidden="true" />
					</div>
					<Heading level="h2" size="md">Jam Operasional</Heading>
					<div class="mt-2.5 space-y-2 text-sm text-text-secondary">
						<div class="flex justify-between">
							<span>Senin–Jumat</span>
							<span class="font-medium text-text-primary">{hours.weekdays}</span>
						</div>
						<div class="flex justify-between">
							<span>Sabtu</span>
							<span class="font-medium text-text-primary">{hours.saturday}</span>
						</div>
						<div class="flex justify-between">
							<span>Minggu</span>
							<span class="font-medium text-text-primary">{hours.sunday}</span>
						</div>
					</div>
				</div>
			</div>
		</div>
	</Container>
	</section>

<script>
		const form = document.getElementById('contact-form') as HTMLFormElement | null;
		if (!form) throw new Error('Form not found');

		const submitBtn = document.getElementById('submit-btn') as HTMLButtonElement | null;
		const submitText = document.getElementById('submit-text') as HTMLSpanElement | null;
		const submitSpinner = document.getElementById('submit-spinner') as HTMLElement | null;
		const feedback = document.getElementById('form-feedback') as HTMLDivElement | null;
		const errorSummary = document.getElementById('form-error-summary') as HTMLDivElement | null;
		const errorList = document.getElementById('error-list') as HTMLUListElement | null;

		// Form fields
		const namaInput = document.getElementById('nama') as HTMLInputElement;
		const teleponInput = document.getElementById('telepon') as HTMLInputElement;
		const emailInput = document.getElementById('email') as HTMLInputElement;
		const pesanInput = document.getElementById('pesan') as HTMLTextAreaElement;

		// Error elements
		const namaError = document.getElementById('nama-error') as HTMLParagraphElement;
		const teleponError = document.getElementById('telepon-error') as HTMLParagraphElement;
		const emailError = document.getElementById('email-error') as HTMLParagraphElement;
		const pesanError = document.getElementById('pesan-error') as HTMLParagraphElement;

		// Validation functions
		function validateEmail(email: string): boolean {
			const emailRegex = /^[^\s@]+@[^\s@]+\.[^\s@]+$/;
			return emailRegex.test(email);
		}

		function validateTelepon(tel: string): boolean {
			if (!tel) return true; // Optional field
			const telRegex = /^[0-9\-+() ]+$/;
			return telRegex.test(tel) && tel.replace(/\D/g, '').length >= 10;
		}

		function clearErrors() {
			errorSummary?.classList.add('hidden');
			if (errorList) errorList.innerHTML = '';
			
			[namaInput, teleponInput, emailInput, pesanInput].forEach(input => {
				input.setAttribute('aria-invalid', 'false');
			});
			
			[namaError, teleponError, emailError, pesanError].forEach(errorEl => {
				errorEl.classList.add('hidden');
				errorEl.textContent = '';
			});
		}

		function showFieldError(input: HTMLInputElement | HTMLTextAreaElement, errorEl: HTMLParagraphElement, message: string) {
			input.setAttribute('aria-invalid', 'true');
			errorEl.textContent = message;
			errorEl.classList.remove('hidden');
		}

		function showErrors(errors: Array<{ field: string; message: string }>) {
			if (!errorList) return;
			
			clearErrors();
			
			if (errors.length === 0) return;

			errorSummary?.classList.remove('hidden');
			
			errors.forEach(({ field, message }) => {
				const li = document.createElement('li');
				li.textContent = message;
				errorList.appendChild(li);

				switch (field) {
					case 'nama':
						showFieldError(namaInput, namaError, message);
						break;
					case 'telepon':
						showFieldError(teleponInput, teleponError, message);
						break;
					case 'email':
						showFieldError(emailInput, emailError, message);
						break;
					case 'pesan':
						showFieldError(pesanInput, pesanError, message);
						break;
				}
			});

			// Focus first invalid field
			const firstInvalidField = errors[0].field;
			document.getElementById(firstInvalidField)?.focus();
		}

		function validateForm(): boolean {
			const errors: Array<{ field: string; message: string }> = [];

			// Validate nama
			const nama = namaInput.value.trim();
			if (!nama) {
				errors.push({ field: 'nama', message: 'Nama lengkap wajib diisi' });
			} else if (nama.length < 3) {
				errors.push({ field: 'nama', message: 'Nama minimal 3 karakter' });
			}

			// Validate email
			const email = emailInput.value.trim();
			if (!email) {
				errors.push({ field: 'email', message: 'Email wajib diisi' });
			} else if (!validateEmail(email)) {
				errors.push({ field: 'email', message: 'Format email tidak valid' });
			}

			// Validate telepon (optional but must be valid if filled)
			const telepon = teleponInput.value.trim();
			if (telepon && !validateTelepon(telepon)) {
				errors.push({ field: 'telepon', message: 'Format nomor telepon tidak valid (min. 10 digit)' });
			}

			// Validate pesan
			const pesan = pesanInput.value.trim();
			if (!pesan) {
				errors.push({ field: 'pesan', message: 'Pesan wajib diisi' });
			} else if (pesan.length < 10) {
				errors.push({ field: 'pesan', message: 'Pesan minimal 10 karakter' });
			} else if (pesan.length > 5000) {
				errors.push({ field: 'pesan', message: 'Pesan terlalu panjang (maks. 5.000 karakter)' });
			}

			if (errors.length > 0) {
				showErrors(errors);
				return false;
			}

			return true;
		}

		// Real-time validation on blur
		namaInput.addEventListener('blur', () => {
			const nama = namaInput.value.trim();
			if (!nama) {
				showFieldError(namaInput, namaError, 'Nama wajib diisi');
			} else if (nama.length < 3) {
				showFieldError(namaInput, namaError, 'Nama minimal 3 karakter');
			} else {
				namaInput.setAttribute('aria-invalid', 'false');
				namaError.classList.add('hidden');
			}
		});

		emailInput.addEventListener('blur', () => {
			const email = emailInput.value.trim();
			if (!email) {
				showFieldError(emailInput, emailError, 'Email wajib diisi');
			} else if (!validateEmail(email)) {
				showFieldError(emailInput, emailError, 'Format email tidak valid');
			} else {
				emailInput.setAttribute('aria-invalid', 'false');
				emailError.classList.add('hidden');
			}
		});

		teleponInput.addEventListener('blur', () => {
			const telepon = teleponInput.value.trim();
			if (telepon && !validateTelepon(telepon)) {
				showFieldError(teleponInput, teleponError, 'Format nomor telepon tidak valid');
			} else {
				teleponInput.setAttribute('aria-invalid', 'false');
				teleponError.classList.add('hidden');
			}
		});

		pesanInput.addEventListener('blur', () => {
			const pesan = pesanInput.value.trim();
			if (!pesan) {
				showFieldError(pesanInput, pesanError, 'Pesan wajib diisi');
			} else if (pesan.length < 10) {
				showFieldError(pesanInput, pesanError, 'Pesan minimal 10 karakter');
			} else if (pesan.length > 5000) {
				showFieldError(pesanInput, pesanError, 'Pesan terlalu panjang (maks. 5.000 karakter)');
			} else {
				pesanInput.setAttribute('aria-invalid', 'false');
				pesanError.classList.add('hidden');
			}
		});

		// --- Card selector for subjek ---
	const subjekCards = document.querySelectorAll('.subjek-card') as NodeListOf<HTMLButtonElement>;
	const subjekInput = document.getElementById('subjek') as HTMLInputElement;
	const subjekGroup = document.getElementById('subjek-group') as HTMLDivElement;

	function clearSubjekSelection() {
		subjekCards.forEach((card) => {
			card.dataset.selected = 'false';
			card.setAttribute('aria-checked', 'false');
			const check = card.querySelector('.subjek-check') as HTMLElement;
			if (check) check.classList.add('hidden');
		});
	}

	function selectSubjekCard(card: HTMLButtonElement) {
		clearSubjekSelection();
		card.dataset.selected = 'true';
		card.setAttribute('aria-checked', 'true');
		const check = card.querySelector('.subjek-check') as HTMLElement;
		if (check) check.classList.remove('hidden');
		subjekInput.value = card.dataset.value || '';
	}

	subjekCards.forEach((card) => {
		card.addEventListener('click', () => {
			selectSubjekCard(card);
		});
	});

	// Allow keyboard navigation within radiogroup
	subjekGroup.addEventListener('keydown', (e: KeyboardEvent) => {
		const cards = Array.from(subjekCards);
		const currentIdx = cards.findIndex((c) => c.dataset.selected === 'true');
		let nextIdx = currentIdx;

		if (e.key === 'ArrowRight' || e.key === 'ArrowDown') {
			e.preventDefault();
			nextIdx = (currentIdx + 1) % cards.length;
		} else if (e.key === 'ArrowLeft' || e.key === 'ArrowUp') {
			e.preventDefault();
			nextIdx = (currentIdx - 1 + cards.length) % cards.length;
		}

		if (nextIdx !== currentIdx) {
			cards[nextIdx].focus();
			selectSubjekCard(cards[nextIdx]);
		}
	});
	// --- End card selector ---

	form.addEventListener('submit', async (e: Event) => {
		e.preventDefault();

		if (!feedback || !submitBtn || !submitText || !submitSpinner) return;

		// Clear previous errors
		clearErrors();
		feedback.classList.add('hidden');
		feedback.textContent = '';

		// Validate form
		if (!validateForm()) {
			return;
		}

		const nama = namaInput.value.trim();
		const email = emailInput.value.trim();
		const telepon = teleponInput.value.trim();
		const subjek = (document.getElementById('subjek') as HTMLInputElement).value;
		const pesan = pesanInput.value.trim();
		const honeypot = (document.getElementById('_website') as HTMLInputElement).value.trim();

		submitText.textContent = 'Mengirim...';
		submitSpinner.classList.remove('hidden');
		submitBtn.disabled = true;

		try {
			const response = await fetch('/api/kontak', {
				method: 'POST',
				headers: { 'Content-Type': 'application/json' },
				body: JSON.stringify({ nama, email, telepon, subjek, pesan, _website: honeypot }),
			});

			const result = await response.json();

			if (result.success) {
				showFeedback('success', 'Terima kasih! Pesan Anda telah terkirim. Kami akan merespons dalam 1×24 jam.');
				form.reset();
				clearSubjekSelection();
				subjekInput.value = '';
			} else if (result.errors) {
				showFeedback('error', result.errors.join(' '));
			} else {
				showFeedback('error', 'Terjadi kesalahan. Silakan coba lagi.');
			}
		} catch {
			showFeedback('error', 'Gagal mengirim pesan. Periksa koneksi Anda dan coba lagi.');
		} finally {
			submitText.textContent = 'Kirim Pesan';
			submitSpinner.classList.add('hidden');
			submitBtn.disabled = false;
		}
	});

	function showFeedback(type: 'success' | 'error', message: string) {
		if (!feedback) return;
		feedback.className = `mt-4 p-4 rounded-lg text-sm font-medium ${
			type === 'success'
				? 'bg-green-50 text-green-800 border border-green-200 dark:bg-green-950 dark:text-green-200 dark:border-green-800'
				: 'bg-red-50 text-red-800 border border-red-200 dark:bg-red-950 dark:text-red-200 dark:border-red-800'
		}`;
		feedback.textContent = message;
		feedback.classList.remove('hidden');
		feedback.setAttribute('role', 'alert');
	}
</script>

