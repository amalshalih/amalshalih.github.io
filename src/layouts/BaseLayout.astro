---
import BaseHead from '../components/BaseHead.astro'
import Container from '../components/ui/Container.astro'
import Icon from '../components/ui/Icon.astro'
import { CONTACT, SITE, SOCIAL } from '../data/site'
import { NAV_ITEMS } from '../lib/constants'
import { getSiteSettings } from '../lib/sanity/client'

interface Props {
	title: string
	description: string
	image?: string
	currentPage?: string
	pageType?: 'website' | 'article'
	publishedTime?: string
	modifiedTime?: string
}

const { title, description, image, currentPage, pageType, publishedTime, modifiedTime } =
	Astro.props

// Hybrid: Try Sanity for footer data, fallback to hardcoded
let footerShortName = SITE.shortName
let footerDescription = SITE.description
let footerAddress = CONTACT.address.full
let footerPhone = CONTACT.phone
let footerPhoneUrl = CONTACT.phoneUrl
let footerWhatsapp = CONTACT.whatsapp
let footerEmailInfo = CONTACT.emails.info
let footerEmailDonasi = CONTACT.emails.donasi
let footerSocialFacebook = SOCIAL.facebook
let footerSocialInstagram = SOCIAL.instagram
let footerSocialYoutube = SOCIAL.youtube
let footerSocialTiktok = SOCIAL.tiktok
let footerLinktreeUrl = SOCIAL.linktree.url
let footerLinktreeLabel = SOCIAL.linktree.label
let footerCopyright = `\u00a9 ${new Date().getFullYear()} ${SITE.name}. Seluruh hak cipta dilindungi.`
let navItems = NAV_ITEMS

try {
	const ss = await getSiteSettings()
	if (ss) {
		if (ss.siteName) footerShortName = ss.siteName
		if (ss.shortName) footerShortName = ss.shortName
		if (ss.description) footerDescription = ss.description
		if (ss.address) {
			const a = ss.address
			footerAddress = [a.street, a.village, a.district, a.city].filter(Boolean).join(', ')
		}
		if (ss.phone) {
			footerPhone = ss.phone
			footerPhoneUrl = `tel:${ss.phone.replace(/\s/g, '')}`
		}
		if (ss.email) footerEmailInfo = ss.email
		if (ss.emails) {
			if (ss.emails.info) footerEmailInfo = ss.emails.info
			if (ss.emails.donasi) footerEmailDonasi = ss.emails.donasi
		}
		if (ss.socialMedia) {
			if (ss.socialMedia.facebook)
				footerSocialFacebook = { ...footerSocialFacebook, url: ss.socialMedia.facebook }
			if (ss.socialMedia.instagram)
				footerSocialInstagram = { ...footerSocialInstagram, url: ss.socialMedia.instagram }
			if (ss.socialMedia.youtube)
				footerSocialYoutube = { ...footerSocialYoutube, url: ss.socialMedia.youtube }
			if (ss.socialMedia.tiktok)
				footerSocialTiktok = { ...footerSocialTiktok, url: ss.socialMedia.tiktok }
		}
		if (ss.linktree) {
			footerLinktreeUrl = ss.linktree
		}
		if (ss.footerCopyright) footerCopyright = ss.footerCopyright
		if (ss.navItems && ss.navItems.length > 0) {
			navItems = ss.navItems
		}
	}
} catch (error) {
	console.error('[Layout] Sanity siteSettings fetch failed:', error)
}
---

<!doctype html>
<html lang="id">
	<head>
		<BaseHead 
		title={title} 
		description={description} 
		image={image} 
		pageType={pageType} 
		publishedTime={publishedTime} 
		modifiedTime={modifiedTime} 
	/>
	</head>
	<body class="flex min-h-screen flex-col">
		<a href="#main-content" class="sr-only focus:not-sr-only focus:fixed focus:left-4 focus:top-4 focus:z-[100] focus:rounded-lg focus:bg-primary-600 focus:px-4 focus:py-3 focus:text-sm focus:font-semibold focus:text-white focus:shadow-lg">
			Langsung ke konten utama
		</a>
		<header
			id="main-header"
			class={`sticky top-0 z-50 w-full transition-all duration-500 ease-in-out ${
				currentPage === '/'
					? 'pt-0 px-0'
					: 'pt-0 px-0 bg-white border-b border-primary-100'
			}`}
			data-page={currentPage}
		>
			<!-- Floating Glassmorphism Capsule -->
			<div
				id="header-capsule"
				class={`mx-auto w-full max-w-none rounded-none border border-transparent transition-all duration-500 ease-in-out ${
					currentPage === '/'
						? 'bg-transparent text-white'
						: 'bg-transparent text-primary-800'
				}`}
			>
				<nav id="header-nav" class="mx-auto flex items-center justify-between px-4 py-3.5 sm:py-4 sm:px-8 transition-all duration-500 ease-in-out">
					<a href="/" class="flex items-center gap-2 sm:gap-3 shrink-0">
						<img src="/logo-yayasan-sm.webp" alt="Logo Yayasan ASIB" class="h-10 w-10 sm:h-12 sm:w-12 rounded-full object-cover" width="48" height="48" fetchpriority="high" decoding="async" />
						<div class="hidden sm:block whitespace-nowrap">
							<p id="logo-text-1" class={`text-sm font-bold leading-tight transition-colors duration-300 ${currentPage === '/' ? 'text-white' : 'text-primary-800'}`}>Yayasan Amal Shalih</p>
							<p id="logo-text-2" class={`text-xs transition-colors duration-300 ${currentPage === '/' ? 'text-white/70' : 'text-warm-700'}`}>Insan Bantul</p>
						</div>
						<div class="sm:hidden">
							<p id="logo-text-mobile" class={`text-sm font-bold transition-colors duration-300 ${currentPage === '/' ? 'text-white' : 'text-primary-800'}`}>Yayasan ASIB</p>
						</div>
					</a>

					<!-- Desktop Nav -->
					<div class="hidden sm:flex items-center justify-end gap-1 overflow-hidden">
						<div class="flex items-center gap-1 overflow-x-auto scrollbar-hide whitespace-nowrap snap-x snap-mandatory min-w-0 max-w-[320px] lg:max-w-none">
							{navItems.map((item) => (
								<a
								href={item.href}
								aria-current={currentPage === item.href ? 'page' : undefined}
								class={`desktop-nav-link rounded-lg px-3 py-2 text-sm font-medium transition-colors shrink-0 snap-start ${
									currentPage === item.href
										? currentPage === '/'
											? 'bg-white/20 text-white'
											: 'bg-primary-50 text-primary-700'
										: currentPage === '/'
											? 'text-white/80 hover:bg-white/10 hover:text-white'
											: 'text-warm-700 hover:bg-warm-100 hover:text-warm-800'
								}`}
							>
								{item.label}
								</a>
							))}
						</div>
						<a
							href="/donasi"
							class="ml-2 rounded-lg bg-primary-700 px-4 py-2 text-sm font-semibold text-white hover:bg-primary-800 transition-colors shrink-0"
						>
							Donasi
						</a>
					</div>

					<!-- Mobile Menu Button -->
					<button
						id="mobile-menu-button"
						type="button"
						class={`sm:hidden p-1.5 rounded-lg transition-colors duration-200 focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-offset-2 ${
							currentPage === '/'
								? 'text-white hover:bg-white/10 focus-visible:ring-white focus-visible:ring-offset-primary-900'
								: 'text-primary-800 hover:bg-primary-50 focus-visible:ring-primary-500 focus-visible:ring-offset-2'
						}`}
						aria-expanded="false"
						aria-controls="mobile-menu"
						aria-label="Buka menu navigasi"
					>
						<Icon name="menu" size={5} class="menu-icon" aria-hidden="true" />
						<Icon name="close" size={5} class="close-icon hidden" aria-hidden="true" />
					</button>
				</nav>

				<!-- Mobile Nav Drawer (Nested inside the capsule with absolute bottom border removed) -->
				<div
					id="mobile-menu"
					class={`sm:hidden w-full transition-all duration-300 ease-in-out max-h-0 overflow-hidden opacity-0 rounded-b-2xl ${
						currentPage === '/'
							? 'bg-primary-950/95 backdrop-blur-lg'
							: 'bg-white/95 backdrop-blur-lg'
					}`}
					aria-hidden="true"
				>
					<div class={`flex flex-col p-4 pt-0 space-y-1 border-t ${currentPage === '/' ? 'border-white/10' : 'border-warm-100'}`}>
						{navItems.map((item) => (
							<a
							href={item.href}
							aria-current={currentPage === item.href ? 'page' : undefined}
							class={`rounded-lg px-4 py-3 text-base font-medium transition-colors ${
								currentPage === item.href
									? currentPage === '/'
										? 'bg-white/20 text-white'
										: 'bg-primary-50 text-primary-700'
									: currentPage === '/'
										? 'text-white/80 hover:bg-white/10 hover:text-white'
										: 'text-warm-700 hover:bg-warm-100 hover:text-warm-800'
							}`}
						>
							{item.label}
							</a>
						))}
						<div class={`pt-3 border-t ${currentPage === '/' ? 'border-white/10' : 'border-warm-100'}`}>
							<a
								href="/donasi"
								class="block w-full text-center rounded-lg bg-primary-700 px-4 py-3 text-base font-semibold text-white hover:bg-primary-800 transition-colors"
							>
								Donasi Sekarang
							</a>
						</div>
					</div>
				</div>
			</div>
		</header>

		<script>
			const menuButton = document.getElementById('mobile-menu-button');
			const mobileMenu = document.getElementById('mobile-menu');
			const menuIcon = menuButton?.querySelector('.menu-icon');
			const closeIcon = menuButton?.querySelector('.close-icon');

			function getFocusableElements() {
				if (!mobileMenu) return [];
				return Array.from(
					mobileMenu.querySelectorAll('a[href], button:not([disabled])')
				).filter((el) => el instanceof HTMLElement && el.offsetParent !== null) as HTMLElement[];
			}

			function toggleMenu() {
				if (!menuButton || !mobileMenu || !menuIcon || !closeIcon) return;

				const isExpanded = menuButton.getAttribute('aria-expanded') === 'true';
				menuButton.setAttribute('aria-expanded', String(!isExpanded));
				mobileMenu.setAttribute('aria-hidden', String(isExpanded));

				if (!isExpanded) {
					mobileMenu.classList.remove('max-h-0', 'opacity-0');
					mobileMenu.classList.add('max-h-96', 'opacity-100');
					menuIcon.classList.add('hidden');
					closeIcon.classList.remove('hidden');
					// Focus first link for keyboard users
					const firstLink = mobileMenu.querySelector('a');
					if (firstLink instanceof HTMLElement) {
						firstLink.focus();
					}
				} else {
					mobileMenu.classList.remove('max-h-96', 'opacity-100');
					mobileMenu.classList.add('max-h-0', 'opacity-0');
					menuIcon.classList.remove('hidden');
					closeIcon.classList.add('hidden');
					// Return focus to menu button
					menuButton.focus();
				}
			}

			menuButton?.addEventListener('click', toggleMenu);

			// Close on Escape key + focus trap
			document.addEventListener('keydown', (e) => {
				if (!menuButton || menuButton.getAttribute('aria-expanded') !== 'true') return;

				if (e.key === 'Escape') {
					e.preventDefault();
					toggleMenu();
					return;
				}

				// Focus trap inside mobile menu
				if (e.key === 'Tab') {
					const focusables = getFocusableElements();
					if (focusables.length === 0) return;
					const first = focusables[0];
					const last = focusables[focusables.length - 1];
					const active = document.activeElement;

					if (e.shiftKey) {
						if (active === first || !mobileMenu?.contains(active as Node)) {
							e.preventDefault();
							last.focus();
						}
					} else {
						if (active === last || !mobileMenu?.contains(active as Node)) {
							e.preventDefault();
							first.focus();
						}
					}
				}
			});

			// Close when clicking outside
			document.addEventListener('click', (e) => {
				if (
					menuButton?.getAttribute('aria-expanded') === 'true' &&
					!mobileMenu?.contains(e.target as Node) &&
					!menuButton?.contains(e.target as Node)
				) {
					toggleMenu();
				}
			});

			// Scroll Header Transition
			const header = document.getElementById('main-header');
			const capsule = document.getElementById('header-capsule');
			const nav = document.getElementById('header-nav');
			const logoText1 = document.getElementById('logo-text-1');
			const logoText2 = document.getElementById('logo-text-2');
			const logoTextMobile = document.getElementById('logo-text-mobile');
			const isHomepage = header?.dataset.page === '/';

			let lastIsScrolled: boolean | undefined = undefined;

			function handleScroll() {
				if (!header || !capsule || !nav) return;
				const isScrolled = window.scrollY > 40;

				if (isScrolled === lastIsScrolled) return;
				lastIsScrolled = isScrolled;

				if (isScrolled) {
					header.classList.remove('pt-0', 'px-0', 'bg-white', 'border-b', 'border-primary-100');
					header.classList.add('pt-3', 'sm:pt-4', 'px-3', 'sm:px-4');

					capsule.className = "mx-auto max-w-6xl rounded-2xl border border-warm-200/80 bg-white/90 backdrop-blur-md shadow-lg shadow-primary-900/5 text-primary-800 transition-all duration-500 ease-in-out";
					nav.className = "flex items-center justify-between px-4 py-2.5 sm:py-3 sm:px-6 transition-all duration-500 ease-in-out";

					if (isHomepage) {
						if (logoText1) { logoText1.classList.remove('text-white'); logoText1.classList.add('text-primary-800'); }
						if (logoText2) { logoText2.classList.remove('text-white/70'); logoText2.classList.add('text-warm-700'); }
						if (logoTextMobile) { logoTextMobile.classList.remove('text-white'); logoTextMobile.classList.add('text-primary-800'); }
						if (menuButton) {
							menuButton.classList.remove('text-white', 'hover:bg-white/10', 'focus-visible:ring-white', 'focus-visible:ring-offset-primary-900');
							menuButton.classList.add('text-primary-800', 'hover:bg-primary-50', 'focus-visible:ring-primary-500', 'focus-visible:ring-offset-2');
						}

						const links = document.querySelectorAll('.desktop-nav-link');
						links.forEach(link => {
							const isCurrent = link.getAttribute('aria-current') === 'page';
							if (isCurrent) {
								link.className = "desktop-nav-link rounded-lg px-3 py-2 text-sm font-medium transition-colors shrink-0 snap-start bg-primary-50 text-primary-700";
							} else {
								link.className = "desktop-nav-link rounded-lg px-3 py-2 text-sm font-medium transition-colors shrink-0 snap-start text-warm-700 hover:bg-warm-100 hover:text-warm-800";
							}
						});
					}
				} else {
					header.classList.remove('pt-3', 'sm:pt-4', 'px-3', 'sm:px-4');
					header.classList.add('pt-0', 'px-0');

					if (isHomepage) {
						header.classList.add('bg-transparent');
						header.classList.remove('bg-white', 'border-b', 'border-primary-100');
						capsule.className = "mx-auto w-full max-w-none rounded-none border border-transparent bg-transparent text-white transition-all duration-500 ease-in-out";
						nav.className = "flex items-center justify-between px-4 py-3.5 sm:py-4 sm:px-8 transition-all duration-500 ease-in-out";

						if (logoText1) { logoText1.classList.remove('text-primary-800'); logoText1.classList.add('text-white'); }
						if (logoText2) { logoText2.classList.remove('text-warm-700'); logoText2.classList.add('text-white/70'); }
						if (logoTextMobile) { logoTextMobile.classList.remove('text-primary-800'); logoTextMobile.classList.add('text-white'); }
						if (menuButton) {
							menuButton.classList.add('text-white', 'hover:bg-white/10', 'focus-visible:ring-white', 'focus-visible:ring-offset-primary-900');
							menuButton.classList.remove('text-primary-800', 'hover:bg-primary-50', 'focus-visible:ring-primary-500', 'focus-visible:ring-offset-2');
						}

						const links = document.querySelectorAll('.desktop-nav-link');
						links.forEach(link => {
							const isCurrent = link.getAttribute('aria-current') === 'page';
							if (isCurrent) {
								link.className = "desktop-nav-link rounded-lg px-3 py-2 text-sm font-medium transition-colors shrink-0 snap-start bg-white/20 text-white";
							} else {
								link.className = "desktop-nav-link rounded-lg px-3 py-2 text-sm font-medium transition-colors shrink-0 snap-start text-white/80 hover:bg-white/10 hover:text-white";
							}
						});
					} else {
						header.classList.add('bg-white', 'border-b', 'border-primary-100');
						capsule.className = "mx-auto w-full max-w-none rounded-none border border-transparent bg-transparent text-primary-800 transition-all duration-500 ease-in-out";
						nav.className = "flex items-center justify-between px-4 py-3.5 sm:py-4 sm:px-8 transition-all duration-500 ease-in-out";
					}
				}
			}

			window.addEventListener('scroll', handleScroll, { passive: true });
			handleScroll();
		</script>

		<main id="main-content" class="flex-1" tabindex="-1">
			<slot />
	</main>

		<slot name="after-main" />

		<footer class="bg-primary-950 text-white">
				<Container as="div" class="py-6 sm:py-8 lg:py-12">
					<!-- Grid: mobile 1 col, tablet 2 paired cols, desktop 4 cols -->
					<div class="grid gap-5 sm:gap-6 lg:gap-8 grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 items-start justify-center">
					<!-- Left Pair: About + Kontak (heavy content) -->
					<div class="flex flex-col gap-5 sm:gap-6 lg:contents">
						<!-- About -->
						<div class="min-w-0">
							<h3 class="mb-2 sm:mb-3 text-base sm:text-lg font-bold text-white">{footerShortName}</h3>
							<p class="text-sm text-primary-200 leading-relaxed break-words mb-3">
								{footerDescription}
							</p>
							<div class="space-y-1.5 mt-3">
								<a href={`mailto:${footerEmailInfo}`} class="text-xs sm:text-sm text-primary-300 hover:text-white transition-colors block break-all">
									{footerEmailInfo}
								</a>
								<a href={`mailto:${footerEmailDonasi}`} class="text-xs sm:text-sm text-primary-300 hover:text-white transition-colors block break-all">
									{footerEmailDonasi}
								</a>
							</div>
						</div>
						<!-- Kontak -->
						<div class="min-w-0">
							<h3 class="mb-2 sm:mb-3 text-xs sm:text-sm font-semibold uppercase tracking-wider text-primary-300">Kontak</h3>
							<ul class="space-y-2 text-sm text-primary-200 break-words">
								<li class="break-words">{footerAddress}</li>
								<li class="flex flex-wrap gap-2">
									<a href={footerPhoneUrl} class="inline-flex items-center gap-1.5 rounded-md bg-primary-900 px-2.5 py-1.5 text-xs sm:text-sm font-medium text-white hover:bg-primary-800 transition-colors">
										<Icon name="phone" size={4} aria-hidden="true" />
										{footerPhone}
									</a>
									<a href={footerWhatsapp} target="_blank" rel="noopener noreferrer" class="inline-flex items-center gap-1.5 rounded-md bg-primary-900 px-2.5 py-1.5 text-xs sm:text-sm font-medium text-white hover:bg-primary-800 transition-colors">
										<Icon name="whatsapp" size={4} aria-hidden="true" />
										WhatsApp
									</a>
									<a href={footerLinktreeUrl} target="_blank" rel="noopener noreferrer" class="inline-flex items-center gap-1.5 rounded-md bg-primary-900 px-2.5 py-1.5 text-xs sm:text-sm font-medium text-white hover:bg-primary-800 transition-colors">
										<Icon name="external-link" size={4} aria-hidden="true" />
										{footerLinktreeLabel}
									</a>
								</li>
							</ul>
						</div>
					</div>
					<!-- Right Pair: Navigasi + Social (light content) -->
					<div class="flex flex-col gap-5 sm:grid sm:grid-cols-2 sm:gap-6 lg:contents justify-center">
						<!-- Navigasi -->
						<div class="min-w-0">
							<h3 class="mb-2 sm:mb-3 text-xs sm:text-sm font-semibold uppercase tracking-wider text-primary-300">Navigasi</h3>
							<ul class="grid grid-cols-3 sm:grid-cols-1 lg:grid-cols-2 gap-x-4 gap-y-1.5 text-sm">
								<li><a href="/" aria-current={currentPage === '/' ? 'page' : undefined} class="text-primary-200 hover:text-white transition-colors">Beranda</a></li>
								<li><a href="/tentang" aria-current={currentPage === '/tentang' ? 'page' : undefined} class="text-primary-200 hover:text-white transition-colors">Tentang Kami</a></li>
								<li><a href="/program" aria-current={currentPage === '/program' ? 'page' : undefined} class="text-primary-200 hover:text-white transition-colors">Program</a></li>
								<li><a href="/kegiatan" aria-current={currentPage === '/kegiatan' ? 'page' : undefined} class="text-primary-200 hover:text-white transition-colors">Kegiatan</a></li>
								<li><a href="/blog" aria-current={currentPage === '/blog' ? 'page' : undefined} class="text-primary-200 hover:text-white transition-colors">Blog</a></li>
								<li><a href="/galeri" aria-current={currentPage === '/galeri' ? 'page' : undefined} class="text-primary-200 hover:text-white transition-colors">Galeri</a></li>
								<li><a href="/donasi" aria-current={currentPage === '/donasi' ? 'page' : undefined} class="text-primary-200 hover:text-white transition-colors">Donasi</a></li>
								<li><a href="/kontak" aria-current={currentPage === '/kontak' ? 'page' : undefined} class="text-primary-200 hover:text-white transition-colors">Kontak</a></li>
								<li><a href="/faq" aria-current={currentPage === '/faq' ? 'page' : undefined} class="text-primary-200 hover:text-white transition-colors">FAQ</a></li>
								<li><a href="/kebijakan-privasi" aria-current={currentPage === '/kebijakan-privasi' ? 'page' : undefined} class="text-primary-200 hover:text-white transition-colors">Kebijakan Privasi</a></li>
								<li><a href="/syarat-ketentuan" aria-current={currentPage === '/syarat-ketentuan' ? 'page' : undefined} class="text-primary-200 hover:text-white transition-colors">Syarat &amp; Ketentuan</a></li>
							</ul>
						</div>
						<!-- Social -->
						<div class="min-w-0">
							<h3 class="mb-2 sm:mb-3 text-xs sm:text-sm font-semibold uppercase tracking-wider text-primary-300 text-center sm:text-left">Ikuti Kami</h3>
							<!-- Mobile: icon-only horizontal row -->
							<div class="flex flex-wrap justify-center gap-2 text-primary-300 sm:hidden">
								<a href={footerSocialFacebook.url} target="_blank" rel="noopener noreferrer" class="p-2 rounded-lg hover:text-white transition-colors duration-200 focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-white/50 focus-visible:ring-offset-2 focus-visible:ring-offset-primary-950" aria-label={footerSocialFacebook.ariaLabel}>
									<Icon name="facebook" size={4} aria-hidden="true" />
								</a>
								<a href={footerSocialInstagram.url} target="_blank" rel="noopener noreferrer" class="p-2 rounded-lg hover:text-white transition-colors duration-200 focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-white/50 focus-visible:ring-offset-2 focus-visible:ring-offset-primary-950" aria-label={footerSocialInstagram.ariaLabel}>
									<Icon name="instagram" size={4} aria-hidden="true" />
								</a>
								<a href={footerSocialTiktok.url} target="_blank" rel="noopener noreferrer" class="p-2 rounded-lg hover:text-white transition-colors duration-200 focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-white/50 focus-visible:ring-offset-2 focus-visible:ring-offset-primary-950" aria-label={footerSocialTiktok.ariaLabel}>
									<Icon name="tiktok" size={4} aria-hidden="true" />
								</a>
