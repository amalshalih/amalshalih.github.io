---
import AmbientBlossom from '@components/AmbientBlossom.astro'
import BaseHead from '@components/BaseHead.astro'
import Footer from '@components/Footer.astro'
import Navbar from '@components/Navbar.astro'

interface Props {
	title: string
	description: string
	image?: string
	currentPage?: string
	pageType?: 'website' | 'article'
	publishedTime?: string
	modifiedTime?: string
}

const { title, description, image, currentPage, pageType, publishedTime, modifiedTime } =
	Astro.props
---

<!doctype html>
<html lang="id">
	<head>
		<meta name="color-scheme" content="light dark" />
		<meta name="theme-color" content="#166534" media="(prefers-color-scheme: light)" />
		<meta name="theme-color" content="#052e16" media="(prefers-color-scheme: dark)" />
		<script is:inline>
			(function () {
				const storedTheme = localStorage.getItem('theme');
				const prefersDark = window.matchMedia('(prefers-color-scheme: dark)').matches;
				if (storedTheme === 'dark' || (!storedTheme && prefersDark)) {
					document.documentElement.classList.add('dark');
				} else {
					document.documentElement.classList.remove('dark');
				}
			})();
		</script>
		<BaseHead 
			title={title} 
			description={description} 
			image={image} 
			pageType={pageType} 
			publishedTime={publishedTime} 
			modifiedTime={modifiedTime} 
		/>
		
		<!-- JSON-LD Structured Data for SEO -->
		<script is:inline type="application/ld+json" is:raw>
		{
			"@context": "https://schema.org",
			"@graph": [
				{
					"@type": "Organization",
					"@id": "https://amalshalih.or.id/#organization",
					"name": "Yayasan Amal Shalih Insan Bantul",
					"alternateName": "ASIB",
					"url": "https://amalshalih.or.id",
					"logo": {
						"@type": "ImageObject",
						"url": "https://amalshalih.or.id/logo-yayasan.webp",
						"width": 512,
						"height": 512
					},
					"description": "Lembaga profesional berkarakter, maslahat bagi umat. Bergerak di bidang pendidikan Islam, sosial kemanusiaan, dan keagamaan sejak 2020.",
					"address": {
						"@type": "PostalAddress",
						"addressLocality": "Bantul",
						"addressRegion": "DI Yogyakarta",
						"addressCountry": "ID"
					},
					"contactPoint": {
						"@type": "ContactPoint",
						"telephone": "+62-xxx-xxx-xxxx",
						"contactType": "customer service",
						"availableLanguage": ["Indonesian", "Arabic"]
					},
					"sameAs": [
						"https://www.facebook.com/amalshalih",
						"https://www.instagram.com/amalshalih",
						"https://www.youtube.com/@amalshalih"
					]
				},
				{
					"@type": "WebSite",
					"@id": "https://amalshalih.or.id/#website",
					"url": "https://amalshalih.or.id",
					"name": "Yayasan ASIB",
					"description": "Website resmi Yayasan Amal Shalih Insan Bantul",
					"publisher": {
						"@id": "https://amalshalih.or.id/#organization"
					},
					"inLanguage": "id-ID",
					"potentialAction": {
						"@type": "SearchAction",
						"target": "https://amalshalih.or.id/search?q={search_term_string}",
						"query-input": "required name=search_term_string"
					}
				}
			]
		}
		</script>
	</head>
	<body class="flex min-h-screen flex-col">
		<a href="#main-content" class="sr-only focus:not-sr-only focus:fixed focus:left-4 focus:top-4 focus:z-[100] focus:rounded-lg focus:bg-primary-600 focus:px-4 focus:py-3 focus:text-sm focus:font-semibold focus:text-white focus:shadow-lg">
			Langsung ke konten utama
		</a>
		
		<AmbientBlossom />

		<Navbar currentPage={currentPage} />

		<main id="main-content" class="flex-1 relative" tabindex="-1">
			
			<slot />
		</main>

		<slot name="after-main" />

		<Footer currentPage={currentPage} />
	<!-- Client-side initialization -->
	<script>
		import { initWebVitalsMonitoring } from '@lib/web-vitals'
		import { initGlobalErrorHandling } from '@lib/error-handler'

		initWebVitalsMonitoring()
		initGlobalErrorHandling()
	</script>
	</body>
</html>
